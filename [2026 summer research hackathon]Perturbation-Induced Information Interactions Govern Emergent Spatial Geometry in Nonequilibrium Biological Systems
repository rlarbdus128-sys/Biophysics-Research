def lagged_mi_proxy(source_series, target_series, n_bins=8):
    s0 = np.asarray(source_series[:-1]).reshape(-1, 1)
    t0 = np.asarray(target_series[:-1]).reshape(-1, 1)
    t1 = np.asarray(target_series[1:]).reshape(-1, 1)
    return float(max(normalized_mi(s0, t1, n_bins) - normalized_mi(t0, t1, n_bins), 0.0))

def temporal_layer_summary(profile_df, layer_col, time_col="t", onset_fraction=0.20, saturation_fraction=0.90):
    t = profile_df[time_col].values.astype(float)
    y = profile_df[layer_col].values.astype(float)
    if len(y) < 2 or np.allclose(y, y[0]):
        return {
            f"{layer_col}_onset_time": np.nan,
            f"{layer_col}_derivative_peak_time": np.nan,
            f"{layer_col}_peak_time": np.nan,
            f"{layer_col}_saturation_time": np.nan,
            f"{layer_col}_first_crossing_time_70": np.nan,
            f"{layer_col}_temporal_auc": 0.0,
            f"{layer_col}_max_derivative": 0.0,
        }
    y_scaled = (y - np.nanmin(y)) / max(np.nanmax(y) - np.nanmin(y), 1e-12)
    dy = np.gradient(y_scaled, t)
    onset_candidates = np.where(y_scaled >= onset_fraction)[0]
    saturation_candidates = np.where(y_scaled >= saturation_fraction)[0]
    crossing_candidates = np.where(y_scaled >= 0.70)[0]
    return {
        f"{layer_col}_onset_time": float(t[onset_candidates[0]]) if len(onset_candidates) else np.nan,
        f"{layer_col}_derivative_peak_time": float(t[np.nanargmax(dy)]),
        f"{layer_col}_peak_time": float(t[np.nanargmax(y_scaled)]),
        f"{layer_col}_saturation_time": float(t[saturation_candidates[0]]) if len(saturation_candidates) else np.nan,
        f"{layer_col}_first_crossing_time_70": float(t[crossing_candidates[0]]) if len(crossing_candidates) else np.nan,
        f"{layer_col}_temporal_auc": float(np.trapz(y_scaled, t) / max(t[-1] - t[0], 1e-12)),
        f"{layer_col}_max_derivative": float(np.nanmax(dy)),
    }

def summarize_temporal_ordering(profile_df, config):
    layer_cols = [
        "temporal_probability_redistribution_js",
        "temporal_information_interaction_mi",
        "temporal_information_propagation_te",
        "temporal_information_organization_efficiency",
        "temporal_geometry_cluster_size",
        "temporal_topology_betti1",
    ]
    summary = {}
    for col in layer_cols:
        summary.update(temporal_layer_summary(profile_df, col, onset_fraction=config.temporal_onset_fraction, saturation_fraction=config.temporal_saturation_fraction))
    probability_onset = summary["temporal_probability_redistribution_js_onset_time"]
    information_onset = summary["temporal_information_interaction_mi_onset_time"]
    network_onset = summary["temporal_information_organization_efficiency_onset_time"]
    geometry_onset = summary["temporal_geometry_cluster_size_onset_time"]
    summary["temporal_order_probability_onset"] = probability_onset
    summary["temporal_order_information_onset"] = information_onset
    summary["temporal_order_network_onset"] = network_onset
    summary["temporal_order_geometry_onset"] = geometry_onset
    summary["temporal_order_topology_onset"] = summary["temporal_topology_betti1_onset_time"]
    checks = [probability_onset <= information_onset, information_onset <= network_onset, network_onset <= geometry_onset]
    summary["mechanism_order_score"] = float(np.nanmean(checks))
    return summary

def scaled_for_plot(series):
    x = np.asarray(series, dtype=float)
    denom = np.nanmax(x) - np.nanmin(x)
    if denom <= 1e-12:
        return np.zeros_like(x)
    return (x - np.nanmin(x)) / denom

def initialize_gray_scott(n, rng):
    U = np.ones((n, n), dtype=np.float32)
    V = np.zeros((n, n), dtype=np.float32)
    center = n // 2
    radius = n // 10
    U[center - radius:center + radius, center - radius:center + radius] = 0.50
    V[center - radius:center + radius, center - radius:center + radius] = 0.25
    U += rng.normal(0, 0.015, size=(n, n)).astype(np.float32)
    V += rng.normal(0, 0.015, size=(n, n)).astype(np.float32)
    return np.clip(U, 0, 1), np.clip(V, 0, 1)

def run_simulation(config, noise_level, perturb_level, feed_level, replicate_id, seed):
    rng = np.random.default_rng(seed)
    n = config.grid_size
    U, V = initialize_gray_scott(n, rng)
    initial_state_for_temporal = state_labels(U.copy(), V.copy(), config.n_bins)
    mask = perturbation_mask(n, config.perturb_radius)
    ring_masks = rings(n, n_rings=5)
    saved_U, saved_V, saved_t = [], [], []
    source_series, far_series, global_u, global_v = [], [], [], []
    temporal_rows = []
    sim_id = f"noise{noise_level}_perturb{perturb_level}_feed{feed_level}_rep{replicate_id}"

    for t in range(config.time_steps):
        F = feed_level
        K = config.kill
        if config.perturb_start <= t <= config.perturb_end:
            V[mask] = np.clip(V[mask] + config.perturb_v_strength * perturb_level * 0.04, 0, 1)
            local_feed = np.zeros((n, n), dtype=np.float32)
            local_feed[mask] = config.perturb_feed_shift * perturb_level
        else:
            local_feed = 0.0
        reaction = U * V * V
        dU = config.du * laplacian_periodic(U) - reaction + (F + local_feed) * (1 - U)
        dV = config.dv * laplacian_periodic(V) + reaction - (F + K) * V
        U = U + config.dt * dU + rng.normal(0, config.noise_sigma * noise_level, size=(n, n))
        V = V + config.dt * dV + rng.normal(0, config.noise_sigma * noise_level, size=(n, n))
        U = np.clip(U, 0, 1).astype(np.float32)
        V = np.clip(V, 0, 1).astype(np.float32)
        source_series.append(float(np.mean(V[mask])))
        far_series.append(float(np.mean(V[ring_masks[-1]])))
        global_u.append(float(np.mean(U)))
        global_v.append(float(np.mean(V)))

        if t % config.temporal_metric_every == 0 or t == config.time_steps - 1:
            current_state = state_labels(U, V, config.n_bins)
            temporal_js = js_divergence_from_labels(initial_state_for_temporal, current_state)
            temporal_kl = kl_divergence_from_labels(initial_state_for_temporal, current_state)
            temporal_entropy = entropy_from_labels(current_state)
            temporal_local_mi = normalized_mi(U, V, config.n_bins)
            temporal_neighbor_mi = normalized_mi(V, 0.25 * (np.roll(V, 1, 0) + np.roll(V, -1, 0) + np.roll(V, 1, 1) + np.roll(V, -1, 1)), config.n_bins)
            temporal_te = lagged_mi_proxy(source_series, far_series, config.n_bins) if len(source_series) > 5 else 0.0
            if len(saved_V) >= 1:
                temporal_net_desc, _ = network_descriptors([saved_V[-1], V], config.patch_size, config.n_bins, config.network_quantile)
            else:
                temporal_net_desc = {"network_global_efficiency": 0.0, "network_degree_entropy": 0.0, "network_clustering_coeff": 0.0, "network_modularity_like": 0.0, "network_assortativity": 0.0}
            temporal_geom = cluster_and_topology(V, config.cluster_quantile)
            temporal_rows.append({
                "simulation_id": sim_id,
                "t": int(t),
                "noise_level": noise_level,
                "perturb_level": perturb_level,
                "feed_level": feed_level,
                "replicate_id": replicate_id,
                "temporal_probability_redistribution_js": temporal_js,
                "temporal_probability_redistribution_kl": temporal_kl,
                "temporal_entropy": temporal_entropy,
                "temporal_information_interaction_mi": temporal_local_mi,
                "temporal_neighbor_information_mi": temporal_neighbor_mi,
                "temporal_information_propagation_te": temporal_te,
                "temporal_information_organization_efficiency": temporal_net_desc["network_global_efficiency"],
                "temporal_information_organization_degree_entropy": temporal_net_desc["network_degree_entropy"],
                "temporal_information_organization_clustering": temporal_net_desc["network_clustering_coeff"],
                "temporal_information_organization_modularity_like": temporal_net_desc["network_modularity_like"],
                "temporal_information_organization_assortativity": temporal_net_desc["network_assortativity"],
                "temporal_geometry_cluster_size": temporal_geom["max_cluster_size"],
                "temporal_geometry_interface_length": temporal_geom["interface_length"],
                "temporal_geometry_correlation_length": spatial_correlation_length(V),
                "temporal_topology_betti0": temporal_geom["betti0_like"],
                "temporal_topology_betti1": temporal_geom["betti1_like"],
                "temporal_topology_euler": temporal_geom["euler_characteristic_like"],
            })
        if t % config.save_every == 0 or t == config.time_steps - 1:
            saved_U.append(U.copy())
            saved_V.append(V.copy())
            saved_t.append(t)

    pre_idx = max(0, np.searchsorted(saved_t, config.perturb_start) - 1)
    mid_idx = len(saved_t) // 2
    pre_U, pre_V = saved_U[pre_idx], saved_V[pre_idx]
    final_U, final_V = saved_U[-1], saved_V[-1]
    state_pre = state_labels(pre_U, pre_V, config.n_bins)
    state_post = state_labels(final_U, final_V, config.n_bins)
    local_js = local_js_map(state_pre, state_post)
    local_kl = local_kl_map(state_pre, state_post)
    local_mi_final = local_mi_map(final_U, final_V, config.n_bins)
    local_mi_pre = local_mi_map(pre_U, pre_V, config.n_bins)
    delta_local_mi = local_mi_final - local_mi_pre
    neighbor_mi_final = neighbor_mi_map(final_V, config.n_bins)
    net_desc, W = network_descriptors(saved_V, config.patch_size, config.n_bins, config.network_quantile)
    geom = cluster_and_topology(final_V, config.cluster_quantile)
    radii = [front_radius(s >= np.quantile(s, config.cluster_quantile)) for s in saved_V]
    temporal_profile = pd.DataFrame(temporal_rows)
    temporal_summary = summarize_temporal_ordering(temporal_profile, config)
    flux_imbalance = float(np.mean(np.abs(U * V * V - feed_level * (1 - U))) + np.mean(np.abs(U * V * V - (feed_level + config.kill) * V)))
    idx = rng.choice(np.arange(n * n), size=min(config.max_pixel_samples_per_sim, n * n), replace=False)
    pixel_df = pd.DataFrame({
        "simulation_id": sim_id,
        "local_js": local_js.ravel()[idx],
        "local_kl": local_kl.ravel()[idx],
        "delta_local_mi": delta_local_mi.ravel()[idx],
        "delta_V": (final_V - pre_V).ravel()[idx],
        "delta_U": (final_U - pre_U).ravel()[idx],
        "cluster_label": geom["binary"].astype(int).ravel()[idx],
    })
    summary = {
        "simulation_id": sim_id,
        "noise_level": noise_level,
        "perturb_level": perturb_level,
        "feed_level": feed_level,
        "replicate_id": replicate_id,
        "mean_U_final": float(np.mean(final_U)),
        "mean_V_final": float(np.mean(final_V)),
        "delta_mean_U": float(np.mean(final_U - pre_U)),
        "delta_mean_V": float(np.mean(final_V - pre_V)),
        "global_js_divergence": js_divergence_from_labels(state_pre, state_post),
        "global_kl_divergence": kl_divergence_from_labels(state_pre, state_post),
        "mean_local_js": float(np.mean(local_js)),
        "mean_local_kl": float(np.mean(local_kl)),
        "entropy_pre": entropy_from_labels(state_pre),
        "entropy_post": entropy_from_labels(state_post),
