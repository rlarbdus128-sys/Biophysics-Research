.80\n    network_quantile: float = 0.75\n    max_pixel_samples_per_sim: int = 1400\n    temporal_metric_every: int = 20\n    temporal_onset_fraction: float = 0.20\n    temporal_saturation_fraction: float = 0.90\n\nBASE_CONFIG = Config()\nNOISE_LEVELS = [0.4, 0.8, 1.2, 1.8]\nPERTURB_LEVELS = [0.6, 1.0, 1.4]\nFEED_LEVELS = [0.055, 0.060]\nN_REPLICATES = 4\nwith open(os.path.join(OUTPUT_DIR, \"simulation_config.json\"), \"w\") as f:\n    json.dump(asdict(BASE_CONFIG), f, indent=2)","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-07-17T21:03:32.074178Z","iopub.execute_input":"2026-07-17T21:03:32.07476Z","iopub.status.idle":"2026-07-17T21:03:32.903498Z","shell.execute_reply.started":"2026-07-17T21:03:32.074708Z","shell.execute_reply":"2026-07-17T21:03:32.902417Z"}},"outputs":[],"execution_count":2},{"cell_type":"code","source":"def laplacian_periodic(x):\n    return np.roll(x, 1, 0) + np.roll(x, -1, 0) + np.roll(x, 1, 1) + np.roll(x, -1, 1) - 4.0 * x\n\ndef perturbation_mask(n, radius):\n    yy, xx = np.mgrid[0:n, 0:n]\n    cy, cx = n // 2, n // 2\n    return np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2) <= radius\n\ndef rings(n, n_rings=5):\n    yy, xx = np.mgrid[0:n, 0:n]\n    cy, cx = n // 2, n // 2\n    r = np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2)\n    edges = np.linspace(0, r.max(), n_rings + 1)\n    return [(r >= edges[i]) & (r < edges[i + 1]) for i in range(n_rings)]\n\ndef discretize(x, n_bins=8):\n    edges = np.unique(np.quantile(np.asarray(x).ravel(), np.linspace(0, 1, n_bins + 1)))\n    if len(edges) <= 2:\n        return np.zeros_like(x, dtype=np.int16)\n    return np.digitize(x, edges[1:-1]).astype(np.int16)\n\ndef label_prob(labels):\n    values, counts = np.unique(labels.ravel(), return_counts=True)\n    p = counts.astype(float) / max(counts.sum(), 1)\n    return values.astype(int), p\n\ndef entropy_from_labels(labels):\n    _, p = label_prob(labels)\n    return float(-np.sum(p * np.log2(p + 1e-12)))\n\ndef kl_divergence_from_labels(a, b):\n    va, pa = label_prob(a)\n    vb, pb = label_prob(b)\n    keys = np.union1d(va, vb)\n    da = dict(zip(va, pa))\n    db = dict(zip(vb, pb))\n    p = np.array([da.get(k, 0.0) for k in keys])\n    q = np.array([db.get(k, 0.0) for k in keys])\n    return float(np.sum(p * np.log2((p + 1e-12) / (q + 1e-12))))\n\ndef js_divergence_from_labels(a, b):\n    va, pa = label_prob(a)\n    vb, pb = label_prob(b)\n    keys = np.union1d(va, vb)\n    da = dict(zip(va, pa))\n    db = dict(zip(vb, pb))\n    p = np.array([da.get(k, 0.0) for k in keys])\n    q = np.array([db.get(k, 0.0) for k in keys])\n    m = 0.5 * (p + q)\n    return float(0.5 * np.sum(p * np.log2((p + 1e-12) / (m + 1e-12))) + 0.5 * np.sum(q * np.log2((q + 1e-12) / (m + 1e-12))))\n\ndef normalized_mi(x, y, n_bins=8):\n    xb = discretize(x, n_bins).ravel()\n    yb = discretize(y, n_bins).ravel()\n    mi = mutual_info_score(xb, yb)\n    hx = mutual_info_score(xb, xb)\n    hy = mutual_info_score(yb, yb)\n    return float(mi / max(np.sqrt(hx * hy), 1e-12))\n\ndef state_labels(U, V, n_bins=8):\n    return discretize(U, n_bins) * n_bins + discretize(V, n_bins)\n\ndef local_window_metric(A, B, radius, func):\n    n = A.shape[0]\n    size = 2 * radius + 1\n    Ap = np.pad(A, radius, mode=\"wrap\")\n    Bp = np.pad(B, radius, mode=\"wrap\")\n    out = np.zeros_like(A, dtype=np.float32)\n    for i in range(n):\n        for j in range(n):\n            out[i, j] = func(Ap[i:i + size, j:j + size], Bp[i:i + size, j:j + size])\n    return out\n\ndef local_mi_map(U, V, n_bins=8):\n    return local_window_metric(U, V, radius=2, func=lambda a, b: normalized_mi(a, b, n_bins))\n\ndef local_js_map(state_pre, state_post):\n    return local_window_metric(state_pre, state_post, radius=2, func=js_divergence_from_labels)\n\ndef local_kl_map(state_pre, state_post):\n    return local_window_metric(state_pre, state_post, radius=2, func=kl_divergence_from_labels)\n\ndef neighbor_mi_map(V, n_bins=8):\n    neighbor = 0.25 * (np.roll(V, 1, 0) + np.roll(V, -1, 0) + np.roll(V, 1, 1) + np.roll(V, -1, 1))\n    return local_mi_map(V, neighbor, n_bins)\n\ndef spatial_correlation_length(field):\n    x = field - np.mean(field)\n    var = np.var(x)\n    if var <= 1e-12:\n        return 0.0\n    for lag in range(1, field.shape[0] // 2 + 1):\n        corr = 0.5 * (np.mean(x * np.roll(x, lag, 0)) / var + np.mean(x * np.roll(x, lag, 1)) / var)\n        if corr < np.exp(-1):\n            return float(lag)\n    return float(field.shape[0] // 2)\n\ndef cluster_and_topology(field, quantile=0.80):\n    binary = field >= np.quantile(field, quantile)\n    labels, n_components = ndimage.label(binary)\n    sizes = np.asarray(ndimage.sum(binary, labels, index=np.arange(1, n_components + 1)), dtype=float)\n    filled = ndimage.binary_fill_holes(binary)\n    holes = filled & (~binary)\n    _, n_holes = ndimage.label(holes)\n    eroded = ndimage.binary_erosion(binary)\n    interface = binary ^ eroded\n    return {\n        \"binary\": binary,\n        \"n_clusters\": int(n_components),\n        \"mean_cluster_size\": float(np.mean(sizes)) if len(sizes) else 0.0,\n        \"max_cluster_size\": float(np.max(sizes)) if len(sizes) else 0.0,\n        \"interface_length\": float(np.sum(interface)),\n        \"betti0_like\": int(n_components),\n        \"betti1_like\": int(n_holes),\n        \"euler_characteristic_like\": int(n_components - n_holes),\n    }\n\ndef front_radius(binary):\n    n = binary.shape[0]\n    yy, xx = np.mgrid[0:n, 0:n]\n    cy, cx = n // 2, n // 2\n    r = np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2)\n    return float(np.mean(r[binary])) if np.sum(binary) else 0.0\n\ndef anisotropy(field):\n    gy, gx = np.gradient(field)\n    tensor = np.array([[np.mean(gx * gx), np.mean(gx * gy)], [np.mean(gx * gy), np.mean(gy * gy)]])\n    vals = np.linalg.eigvalsh(tensor)\n    return float((vals[-1] - vals[0]) / (np.sum(vals) + 1e-12))\n\ndef patch_means(field, patch_size):\n    n = field.shape[0]\n    m = n // patch_size\n    cropped = field[:m * patch_size, :m * patch_size]\n    return cropped.reshape(m, patch_size, m, patch_size).mean(axis=(1, 3)).ravel()\n\ndef patch_series(saved_fields, patch_size):\n    return np.vstack([patch_means(f, patch_size) for f in saved_fields])\n\ndef network_descriptors(saved_V, patch_size, n_bins=8, network_quantile=0.75):\n    X = patch_series(saved_V, patch_size)\n    n_nodes = X.shape[1]\n    W = np.zeros((n_nodes, n_nodes), dtype=np.float32)\n    for i in range(n_nodes):\n        for j in range(i + 1, n_nodes):\n            W[i, j] = normalized_mi(X[:, i], X[:, j], n_bins)\n            W[j, i] = W[i, j]\n    nonzero = W[W > 0]\n    if len(nonzero) == 0:\n        empty = {\n            \"network_edge_density\": 0.0,\n            \"network_mean_weight\": 0.0,\n            \"network_degree_entropy\": 0.0,\n            \"network_clustering_coeff\": 0.0,\n            \"network_average_path_length\": 0.0,\n            \"network_global_efficiency\": 0.0,\n            \"network_assortativity\": 0.0,\n            \"network_modularity_like\": 0.0,\n        }\n        return empty, W\n    threshold = np.quantile(nonzero, network_quantile)\n    A = (W >= threshold).astype(float)\n    np.fill_diagonal(A, 0)\n    degree = A.sum(axis=1)\n    edge_density = float(A.sum() / max(n_nodes * (n_nodes - 1), 1))\n    mean_weight = float(W[A > 0].mean()) if np.any(A > 0) else 0.0\n    p_degree = degree / max(degree.sum(), 1e-12)\n    degree_entropy = float(-np.sum(p_degree[p_degree > 0] * np.log2(p_degree[p_degree > 0])))\n    clustering_vals = []\n    for i in range(n_nodes):\n        neigh = np.where(A[i] > 0)[0]\n        k = len(neigh)\n        clustering_vals.append(0.0 if k < 2 else A[np.ix_(neigh, neigh)].sum() / (k * (k - 1)))\n    clustering_coeff = float(np.mean(clustering_vals))\n    dist = np.where(A > 0, 1.0, np.inf)\n    np.fill_diagonal(dist, 0)\n    for k in range(n_nodes):\n        dist = np.minimum(dist, dist[:, [k]] + dist[[k], :])\n    finite_dist = dist[np.isfinite(dist) & (dist > 0)]\n    average_path_length = float(np.mean(finite_dist)) if len(finite_dist) else 0.0\n    inv_dist = np.where(np.isfinite(dist) & (dist > 0), 1.0 / dist, 0.0)\n    global_efficiency = float(inv_dist.sum() / max(n_nodes * (n_nodes - 1), 1))\n    edge_i, edge_j = np.where(np.triu(A, 1) > 0)\n    if len(edge_i) > 1 and np.std(degree[edge_i]) > 1e-12 and np.std(degree[edge_j]) > 1e-12:\n        assortativity = float(np.corrcoef(degree[edge_i], degree[edge_j])[0, 1])\n    else:\n        assortativity = 0.0\n    labels, n_comp = ndimage.label(A > 0)\n    component_sizes = np.array([np.sum(labels == i) for i in range(1, n_comp + 1)], dtype=float)\n    modularity_like = float(np.max(component_sizes) / n_nodes) if len(component_sizes) else 0.0\n    return {\n        \"network_edge_density\": edge_density,\n        \"network_mean_weight\": mean_weight,\n        \"network_degree_entropy\": degree_entropy,\n        \"network_clustering_coeff\": clustering_coeff,\n        \"network_average_path_length\": average_path_length,\n        \"network_global_efficiency\": global_efficiency,\n        \"network_assortativity\": assortativity,\n        \"network_modularity_like\": modularity_like,\n    }, W","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T21:03:32.905313Z","iopub.execute_input":"2026-07-17T21:03:32.905993Z","iopub.status.idle":"2026-07-17T21:03:33.081258Z","shell.execute_reply.started":"2026-07-17T21:03:32.905956Z","shell.execute_reply":"2026-07-17T21:03:33.080051Z"}},"outputs":[],"execution_count":3},{"cell_type":"code","source":"def lagged_mi_proxy(source_series, target_series, n_bins=8):\n    s0 = np.asarray(source_series[:-1]).reshape(-1, 1)\n    t0 = np.asarray(target_series[:-1]).reshape(-1, 1)\n    t1 = np.asarray(target_series[1:]).reshape(-1, 1)\n    return float(max(normalized_mi(s0, t1, n_bins) - normalized_mi(t0, t1, n_bins), 0.0))\n\ndef temporal_layer_summary(profile_df, layer_col, time_col=\"t\", onset_fraction=0.20, saturation_fraction=0.90):\n    t = profile_df[time_col].values.astype(float)\n    y = profile_df[layer_col].values.astype(float)\n    if len(y) < 2 or np.allclose(y, y[0]):\n        return {\n            f\"{layer_col}_onset_time\": np.nan,\n            f\"{layer_col}_derivative_peak_time\": np.nan,\n            f\"{layer_col}_peak_time\": np.nan,\n            f\"{layer_col}_saturation_time\": np.nan,\n            f\"{layer_col}_first_crossing_time_70\": np.nan,\n            f\"{layer_col}_temporal_auc\": 0.0,\n            f\"{layer_col}_max_derivative\": 0.0,\n        }\n    y_scaled = (y - np.nanmin(y)) / max(np.nanmax(y) - np.nanmin(y), 1e-12)\n    dy = np.gradient(y_scaled, t)\n    onset_candidates = np.where(y_scaled >= onset_fraction)[0]\n    saturation_candidates = np.where(y_scaled >= saturation_fraction)[0]\n    crossing_candidates = np.where(y_scaled >= 0.70)[0]\n    return {\n        f\"{layer_col}_onset_time\": float(t[onset_candidates[0]]) if len(onset_candidates) else np.nan,\n        f\"{layer_col}_derivative_peak_time\": float(t[np.nanargmax(dy)]),\n        f\"{layer_col}_peak_time\": float(t[np.nanargmax(y_scaled)]),\n        f\"{layer_col}_saturation_time\": float(t[saturation_candidates[0]]) if len(saturation_candidates) else np.nan,\n        f\"{layer_col}_first_crossing_time_70\": float(t[crossing_candidates[0]]) if len(crossing_candidates) else np.nan,\n        f\"{layer_col}_temporal_auc\": float(np.trapz(y_scaled, t) / max(t[-1] - t[0], 1e-12)),\n        f\"{layer_col}_max_derivative\": float(np.nanmax(dy)),\n    }\n\ndef summarize_temporal_ordering(profile_df, config):\n    layer_cols = [\n        \"temporal_probability_redistribution_js\",\n        \"temporal_information_interaction_mi\",\n        \"temporal_information_propagation_te\",\n        \"temporal_information_organization_efficiency\",\n        \"temporal_geometry_cluster_size\",\n        \"temporal_topology_betti1\",\n    ]\n    summary = {}\n    for col in layer_cols:\n        summary.update(temporal_layer_summary(profile_df, col, onset_fraction=config.temporal_onset_fraction, saturation_fraction=config.temporal_saturation_fraction))\n    probability_onset = summary[\"temporal_probability_redistribution_js_onset_time\"]\n    information_onset = summary[\"temporal_information_interaction_mi_onset_time\"]\n    network_onset = summary[\"temporal_information_organization_efficiency_onset_time\"]\n    geometry_onset = summary[\"temporal_geometry_cluster_size_onset_time\"]\n    summary[\"temporal_order_probability_onset\"] = probability_onset\n    summary[\"temporal_order_information_onset\"] = information_onset\n    summary[\"temporal_order_network_onset\"] = network_onset\n    summary[\"temporal_order_geometry_onset\"] = geometry_onset\n    summary[\"temporal_order_topology_onset\"] = summary[\"temporal_topology_betti1_onset_time\"]\n    checks = [probability_onset <= information_onset, information_onset <= network_onset, network_onset <= geometry_onset]\n    summary[\"mechanism_order_score\"] = float(np.nanmean(checks))\n    return summary\n\ndef scaled_for_plot(series):\n    x = np.asarray(series, dtype=float)\n    denom = np.nanmax(x) - np.nanmin(x)\n    if denom <= 1e-12:\n        return np.zeros_like(x)\n    return (x - np.nanmin(x)) / denom\n\ndef initialize_gray_scott(n, rng):\n    U = np.ones((n, n), dtype=np.float32)\n    V = np.zeros((n, n), dtype=np.float32)\n    center = n // 2\n    radius = n // 10\n    U[center - radius:center + radius, center - radius:center + radius] = 0.50\n    V[center - radius:center + radius, center - radius:center + radius] = 0.25\n    U += rng.normal(0, 0.015, size=(n, n)).astype(np.float32)\n    V += rng.normal(0, 0.015, size=(n, n)).astype(np.float32)\n    return np.clip(U, 0, 1), np.clip(V, 0, 1)\n\ndef run_simulation(config, noise_level, perturb_level, feed_level, replicate_id, seed):\n    rng = np.random.default_rng(seed)\n    n = config.grid_size\n    U, V = initialize_gray_scott(n, rng)\n    initial_state_for_temporal = state_labels(U.copy(), V.copy(), config.n_bins)\n    mask = perturbation_mask(n, config.perturb_radius)\n    ring_masks = rings(n, n_rings=5)\n    saved_U, saved_V, saved_t = [], [], []\n    source_series, far_series, global_u, global_v = [], [], [], []\n    temporal_rows = []\n    sim_id = f\"noise{noise_level}_perturb{perturb_level}_feed{feed_level}_rep{replicate_id}\"\n\n    for t in range(config.time_steps):\n        F = feed_level\n        K = config.kill\n        if config.perturb_start <= t <= config.perturb_end:\n            V[mask] = np.clip(V[mask] + config.perturb_v_strength * perturb_level * 0.04, 0, 1)\n            local_feed = np.zeros((n, n), dtype=np.float32)\n            local_feed[mask] = config.perturb_feed_shift * perturb_level\n        else:\n            local_feed = 0.0\n        reaction = U * V * V\n        dU = config.du * laplacian_periodic(U) - reaction + (F + local_feed) * (1 - U)\n        dV = config.dv * laplacian_periodic(V) + reaction - (F + K) * V\n        U = U + config.dt * dU + rng.normal(0, config.noise_sigma * noise_level, size=(n, n))\n        V = V + config.dt * dV + rng.normal(0, config.noise_sigma * noise_level, size=(n, n))\n        U = np.clip(U, 0, 1).astype(np.float32)\n        V = np.clip(V, 0, 1).astype(np.float32)\n        source_series.append(float(np.mean(V[mask])))\n        far_series.append(float(np.mean(V[ring_masks[-1]])))\n        global_u.append(float(np.mean(U)))\n        global_v.append(float(np.mean(V)))\n\n        if t % config.temporal_metric_every == 0 or t == config.time_steps - 1:\n            current_state = state_labels(U, V, config.n_bins)\n            temporal_js = js_divergence_from_labels(initial_state_for_temporal, current_state)\n            temporal_kl = kl_divergence_from_labels(initial_state_for_temporal, current_state)\n            temporal_entropy = entropy_from_labels(current_state)\n            temporal_local_mi = normalized_mi(U, V, config.n_bins)\n            temporal_neighbor_mi = normalized_mi(V, 0.25 * (np.roll(V, 1, 0) + np.roll(V, -1, 0) + np.roll(V, 1, 1) + np.roll(V, -1, 1)), config.n_bins)\n            temporal_te = lagged_mi_proxy(source_series, far_series, config.n_bins) if len(source_series) > 5 else 0.0\n            if len(saved_V) >= 1:\n                temporal_net_desc, _ = network_descriptors([saved_V[-1], V], config.patch_size, config.n_bins, config.network_quantile)\n            else:\n                temporal_net_desc = {\"network_global_efficiency\": 0.0, \"network_degree_entropy\": 0.0, \"network_clustering_coeff\": 0.0, \"network_modularity_like\": 0.0, \"network_assortativity\": 0.0}\n            temporal_geom = cluster_and_topology(V, config.cluster_quantile)\n            temporal_rows.append({\n                \"simulation_id\": sim_id,\n                \"t\": int(t),\n                \"noise_level\": noise_level,\n                \"perturb_level\": perturb_level,\n                \"feed_level\": feed_level,\n                \"replicate_id\": replicate_id,\n                \"temporal_probability_redistribution_js\": temporal_js,\n                \"temporal_probability_redistribution_kl\": temporal_kl,\n                \"temporal_entropy\": temporal_entropy,\n                \"temporal_information_interaction_mi\": temporal_local_mi,\n                \"temporal_neighbor_information_mi\": temporal_neighbor_mi,\n                \"temporal_information_propagation_te\": temporal_te,\n                \"temporal_information_organization_efficiency\": temporal_net_desc[\"network_global_efficiency\"],\n                \"temporal_information_organization_degree_entropy\": temporal_net_desc[\"network_degree_entropy\"],\n                \"temporal_information_organization_clustering\": temporal_net_desc[\"network_clustering_coeff\"],\n                \"temporal_information_organization_modularity_like\": temporal_net_desc[\"network_modularity_like\"],\n                \"temporal_information_organization_assortativity\": temporal_net_desc[\"network_assortativity\"],\n                \"temporal_geometry_cluster_size\": temporal_geom[\"max_cluster_size\"],\n                \"temporal_geometry_interface_length\": temporal_geom[\"interface_length\"],\n                \"temporal_geometry_correlation_length\": spatial_correlation_length(V),\n                \"temporal_topology_betti0\": temporal_geom[\"betti0_like\"],\n                \"temporal_topology_betti1\": temporal_geom[\"betti1_like\"],\n                \"temporal_topology_euler\": temporal_geom[\"euler_characteristic_like\"],\n            })\n        if t % config.save_every == 0 or t == config.time_steps - 1:\n            saved_U.append(U.copy())\n            saved_V.append(V.copy())\n            saved_t.append(t)\n\n    pre_idx = max(0, np.searchsorted(saved_t, config.perturb_start) - 1)\n    mid_idx = len(saved_t) // 2\n    pre_U, pre_V = saved_U[pre_idx], saved_V[pre_idx]\n    final_U, final_V = saved_U[-1], saved_V[-1]\n    state_pre = state_labels(pre_U, pre_V, config.n_bins)\n    state_post = state_labels(final_U, final_V, config.n_bins)\n    local_js = local_js_map(state_pre, state_post)\n    local_kl = local_kl_map(state_pre, state_post)\n    local_mi_final = local_mi_map(final_U, final_V, config.n_bins)\n    local_mi_pre = local_mi_map(pre_U, pre_V, config.n_bins)\n    delta_local_mi = local_mi_final - local_mi_pre\n    neighbor_mi_final = neighbor_mi_map(final_V, config.n_bins)\n    net_desc, W = network_descriptors(saved_V, config.patch_size, config.n_bins, config.network_quantile)\n    geom = cluster_and_topology(final_V, config.cluster_quantile)\n    radii = [front_radius(s >= np.quantile(s, config.cluster_quantile)) for s in saved_V]\n    temporal_profile = pd.DataFrame(temporal_rows)\n    temporal_summary = summarize_temporal_ordering(temporal_profile, config)\n    flux_imbalance = float(np.mean(np.abs(U * V * V - feed_level * (1 - U))) + np.mean(np.abs(U * V * V - (feed_level + config.kill) * V)))\n    idx = rng.choice(np.arange(n * n), size=min(config.max_pixel_samples_per_sim, n * n), replace=False)\n    pixel_df = pd.DataFrame({\n        \"simulation_id\": sim_id,\n        \"local_js\": local_js.ravel()[idx],\n        \"local_kl\": local_kl.ravel()[idx],\n        \"delta_local_mi\": delta_local_mi.ravel()[idx],\n        \"delta_V\": (final_V - pre_V).ravel()[idx],\n        \"delta_U\": (final_U - pre_U).ravel()[idx],\n        \"cluster_label\": geom[\"binary\"].astype(int).ravel()[idx],\n    })\n    summary = {\n        \"simulation_id\": sim_id,\n        \"noise_level\": noise_level,\n        \"perturb_level\": perturb_level,\n        \"feed_level\": feed_level,\n        \"replicate_id\": replicate_id,\n        \"mean_U_final\": float(np.mean(final_U)),\n        \"mean_V_final\": float(np.mean(final_V)),\n        \"delta_mean_U\": float(np.mean(final_U - pre_U)),\n        \"delta_mean_V\": float(np.mean(final_V - pre_V)),\n        \"global_js_divergence\": js_divergence_from_labels(state_pre, state_post),\n        \"global_kl_divergence\": kl_divergence_from_labels(state_pre, state_post),\n        \"mean_local_js\": float(np.mean(local_js)),\n        \"mean_local_kl\": float(np.mean(local_kl)),\n        \"entropy_pre\": entropy_from_labels(state_pre),\n        \"entropy_post\": entropy_from_labels(state_post),\n        \"delta_entropy\": float(entropy_from_labels(state_post) - entropy_from_labels(state_pre)),\n        \"mean_local_mi_final\": float(np.mean(local_mi_final)),\n        \"mean_delta_local_mi\": float(np.mean(delta_local_mi)),\n        \"mean_neighbor_mi_final\": float(np.mean(neighbor_mi_final)),\n        \"te_like_source_to_far\": lagged_mi_proxy(source_series, far_series, config.n_bins),\n        \"flux_imbalance_proxy\": flux_imbalance,\n        \"spatial_correlation_length\": spatial_correlation_length(final_V),\n        \"front_velocity_proxy\": float((radii[-1] - radii[0]) / max(saved_t[-1] - saved_t[0], 1)),\n        \"pattern_anisotropy\": anisotropy(final_V),\n        \"n_clusters\": geom[\"n_clusters\"],\n        \"mean_cluster_size\": geom[\"mean_cluster_size\"],\n        \"max_cluster_size\": geom[\"max_cluster_size\"],\n        \"interface_length\": geom[\"interface_length\"],\n        \"betti0_like\": geom[\"betti0_like\"],\n        \"betti1_like\": geom[\"betti1_like\"],\n        \"euler_characteristic_like\": geom[\"euler_characteristic_like\"],\n        **net_desc,\n        **temporal_summary,\n    }\n    timeseries = pd.DataFrame({\n        \"simulation_id\": sim_id,\n        \"t\": np.arange(config.time_steps),\n        \"source_V\": source_series,\n        \"far_V\": far_series,\n        \"global_U\": global_u,\n        \"global_V\": global_v,\n        \"noise_level\": noise_level,\n        \"perturb_level\": perturb_level,\n        \"feed_level\": feed_level,\n        \"replicate_id\": replicate_id,\n    })\n    snapshots = {\"V_pre\": pre_V, \"V_mid\": saved_V[mid_idx], \"V_final\": final_V, \"local_js\": local_js, \"local_kl\": local_kl, \"delta_local_mi\": delta_local_mi, \"neighbor_mi_final\": neighbor_mi_final, \"cluster_binary\": geom[\"binary\"].astype(float), \"network_matrix\": W}\n    return summary, pixel_df, timeseries, snapshots, temporal_profile\n\nall_summaries, all_pixels, all_timeseries, all_temporal_profiles = [], [], [], []\nrepresentative_snapshots, representative_key = None, None\nrun_counter = 0\ntotal_runs = len(NOISE_LEVELS) * len(PERTURB_LEVELS) * len(FEED_LEVELS) * N_REPLICATES","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T21:03:33.083234Z","iopub.execute_input":"2026-07-17T21:03:33.083616Z","iopub.status.idle":"2026-07-17T21:03:33.130613Z","shell.execute_reply.started":"2026-07-17T21:03:33.08358Z","shell.execute_reply":"2026-07-17T21:03:33.129466Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"import os\nimport json\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nfrom sklearn.ensemble import RandomForestRegressor, RandomForestClassifier\nfrom sklearn.model_selection import cross_val_score, KFold, StratifiedKFold\nfrom sklearn.inspection import permutation_importance\nfrom sklearn.metrics import roc_auc_score\n\n# --- 1. 시뮬레이션 루프 및 데이터 수집 ---\nrun_counter = 0\nfor noise in NOISE_LEVELS:\n    for perturb in PERTURB_LEVELS:\n        for feed in FEED_LEVELS:\n            for rep in range(N_REPLICATES):\n                seed = GLOBAL_SEED + run_counter * 1009\n                summary, pixel_df_temp, ts, snapshots, temporal_profile = run_simulation(\n                    BASE_CONFIG, noise, perturb, feed, rep, seed\n                )\n                all_summaries.append(summary)\n                all_pixels.append(pixel_df_temp)\n                all_timeseries.append(ts)\n                all_temporal_profiles.append(temporal_profile)\n                \n                if (representative_snapshots is None \n                        and noise == 0.8 \n                        and perturb == 1.0 \n                        and feed == 0.060 \n                        and rep == 0):\n                    representative_snapshots = snapshots\n                    representative_key = summary[\"simulation_id\"]\n                \n                run_counter += 1\n                print(f\"Completed {run_counter}/{total_runs}: {summary['simulation_id']}\")\n\n# --- 2. 데이터프레임 병합 및 저장 ---\nsummary_df = pd.DataFrame(all_summaries)\npixel_df = pd.concat(all_pixels, ignore_index=True)\ntimeseries_df = pd.concat(all_timeseries, ignore_index=True)\ntemporal_profile_df = pd.concat(all_temporal_profiles, ignore_index=True)\n\nsummary_df.to_csv(os.path.join(OUTPUT_DIR, \"summary_metrics.csv\"), index=False)\npixel_df.to_csv(os.path.join(OUTPUT_DIR, \"pixel_level_compact_metrics.csv\"), index=False)\ntimeseries_df.to_csv(os.path.join(OUTPUT_DIR, \"compact_timeseries.csv\"), index=False)\ntemporal_profile_df.to_csv(os.path.join(OUTPUT_DIR, \"on_the_fly_temporal_metrics.csv\"), index=False)\n\ntemporal_summary_cols = [col for col in summary_df.columns if col.startswith(\"temporal_\") or col == \"mechanism_order_score\"]\ntemporal_summary_df = summary_df[[\"simulation_id\", \"noise_level\", \"perturb_level\", \"feed_level\", \"replicate_id\"] + temporal_summary_cols]\ntemporal_summary_df.to_csv(os.path.join(OUTPUT_DIR, \"temporal_ordering_summary.csv\"), index=False)\n\n# --- 3. 피처 세트 정의 ---\nfeature_sets = {\n    \"M0_baseline\": [\"noise_level\", \"perturb_level\", \"feed_level\"],\n    \"M1_concentration\": [\"delta_mean_U\", \"delta_mean_V\", \"mean_U_final\", \"mean_V_final\"],\n    \"M2_probability_redistribution\": [\"global_js_divergence\", \"global_kl_divergence\", \"mean_local_js\", \"mean_local_kl\", \"delta_entropy\", \"flux_imbalance_proxy\"],\n    \"M3_information\": [\"mean_local_mi_final\", \"mean_delta_local_mi\", \"mean_neighbor_mi_final\", \"te_like_source_to_far\"],\n    \"M4_network\": [\"network_edge_density\", \"network_mean_weight\", \"network_degree_entropy\", \"network_clustering_coeff\", \"network_average_path_length\", \"network_global_efficiency\", \"network_assortativity\", \"network_modularity_like\"],\n    \"M6_temporal_mechanism\": [\"temporal_probability_redistribution_js_onset_time\", \"temporal_information_interaction_mi_onset_time\", \"temporal_information_propagation_te_onset_time\", \"temporal_information_organization_efficiency_onset_time\", \"temporal_geometry_cluster_size_onset_time\", \"temporal_probability_redistribution_js_derivative_peak_time\", \"temporal_information_interaction_mi_derivative_peak_time\", \"temporal_information_organization_efficiency_derivative_peak_time\", \"temporal_geometry_cluster_size_derivative_peak_time\", \"temporal_probability_redistribution_js_temporal_auc\", \"temporal_information_interaction_mi_temporal_auc\", \"temporal_information_organization_efficiency_temporal_auc\", \"temporal_geometry_cluster_size_temporal_auc\", \"mechanism_order_score\"],\n}\nfeature_sets[\"M5_full_static\"] = list(dict.fromkeys(feature_sets[\"M0_baseline\"] + feature_sets[\"M1_concentration\"] + feature_sets[\"M2_probability_redistribution\"] + feature_sets[\"M3_information\"] + feature_sets[\"M4_network\"]))\nfeature_sets[\"M7_full_plus_temporal\"] = list(dict.fromkeys(feature_sets[\"M5_full_static\"] + feature_sets[\"M6_temporal_mechanism\"]))\n\n# --- 4. 모델 훈련 및 평가 (R2 & AUC) ---\ncontinuous_outcomes = [\"max_cluster_size\", \"spatial_correlation_length\", \"interface_length\", \"betti1_like\", \"euler_characteristic_like\"]\nsummary_df[\"cluster_emergence\"] = (summary_df[\"max_cluster_size\"] >= summary_df[\"max_cluster_size\"].quantile(0.70)).astype(int)\nmodel_rows = []\n\nfor model_name, current_cols in feature_sets.items():\n    X = summary_df[current_cols].replace([np.inf, -np.inf], np.nan).fillna(0).values\n    \n    # 연속형 타겟 평가 (Regression R2)\n    for outcome in continuous_outcomes:\n        y = summary_df[outcome].values\n        model = RandomForestRegressor(n_estimators=220, max_depth=5, random_state=GLOBAL_SEED, n_jobs=-1)\n        scores = cross_val_score(model, X, y, cv=KFold(n_splits=4, shuffle=True, random_state=GLOBAL_SEED), scoring=\"r2\")\n        model_rows.append({\n            \"model\": model_name, \n            \"outcome\": outcome, \n            \"task\": \"regression\", \n            \"metric\": \"cross_validated_R2\", \n            \"mean_score\": float(np.mean(scores)), \n            \"std_score\": float(np.std(scores)), \n            \"features\": \",\".join(current_cols)\n        })\n        \n    # 이진 분류 타겟 평가 (Classification AUC)\n    yb = summary_df[\"cluster_emergence\"].values\n    if len(np.unique(yb)) > 1:\n        clf = RandomForestClassifier(n_estimators=220, max_depth=5, random_state=GLOBAL_SEED, n_jobs=-1, class_weight=\"balanced\")\n        scores = cross_val_score(clf, X, yb, cv=StratifiedKFold(n_splits=4, shuffle=True, random_state=GLOBAL_SEED), scoring=\"roc_auc\")\n        model_rows.append({\n            \"model\": model_name, \n            \"outcome\": \"cluster_emergence\", \n            \"task\": \"classification\", \n            \"metric\": \"cross_validated_AUC\", \n            \"mean_score\": float(np.mean(scores)), \n            \"std_score\": float(np.std(scores)), \n            \"features\": \",\".join(current_cols)\n        })\n\nmodel_comparison_df = pd.DataFrame(model_rows)\nmodel_comparison_df.to_csv(os.path.join(OUTPUT_DIR, \"comparative_model_results.csv\"), index=False)\n\n# --- 5. 픽셀 수준 분석 (Pixel AUC) ---\ndef pixel_auc(cols_to_use):\n    y = pixel_df[\"cluster_label\"].values\n    if len(np.unique(y)) < 2:\n        return np.nan\n    X = pixel_df[cols_to_use].replace([np.inf, -np.inf], np.nan).fillna(0).values\n    clf = RandomForestClassifier(n_estimators=180, max_depth=6, random_state=GLOBAL_SEED, n_jobs=-1, class_weight=\"balanced\")\n    clf.fit(X, y)\n    return float(roc_auc_score(y, clf.predict_proba(X)[:, 1]))\n\npixel_auc_df = pd.DataFrame({\n    \"model\": [\"information_only\", \"concentration_only\", \"redistribution_only\", \"full_local\"], \n    \"auc\": [\n        pixel_auc([\"delta_local_mi\"]), \n        pixel_auc([\"delta_U\", \"delta_V\"]), \n        pixel_auc([\"local_js\", \"local_kl\"]), \n        pixel_auc([\"local_js\", \"local_kl\", \"delta_local_mi\", \"delta_U\", \"delta_V\"])\n    ]\n})\npixel_auc_df.to_csv(os.path.join(OUTPUT_DIR, \"pixel_cluster_prediction_auc.csv\"), index=False)\n\n# --- 6. 임계값 및 노이즈 반응성 분석 ---\nsummary_df[\"high_network_info\"] = (summary_df[\"network_global_efficiency\"] >= summary_df[\"network_global_efficiency\"].quantile(0.70)).astype(int)\nthreshold_df = summary_df.groupby(\"high_network_info\")[[\"max_cluster_size\", \"spatial_correlation_length\", \"interface_length\", \"betti0_like\", \"betti1_like\", \"euler_characteristic_like\"]].mean().reset_index()\nthreshold_df.to_csv(os.path.join(OUTPUT_DIR, \"network_threshold_geometry_summary.csv\"), index=False)\n\nnoise_df = summary_df.groupby(\"noise_level\")[[\"mean_delta_local_mi\", \"te_like_source_to_far\", \"network_global_efficiency\", \"max_cluster_size\", \"spatial_correlation_length\", \"betti1_like\"]].mean().reset_index()\nnoise_df.to_csv(os.path.join(OUTPUT_DIR, \"noise_response_summary.csv\"), index=False)\n\n# --- 7. 순열 중요도 (Permutation Importance) ---\nfull_features = feature_sets[\"M7_full_plus_temporal\"]\nX_full = summary_df[full_features].replace([np.inf, -np.inf], np.nan).fillna(0)\ny_full = summary_df[\"max_cluster_size\"].values\n\nrf = RandomForestRegressor(n_estimators=260, max_depth=5, random_state=GLOBAL_SEED, n_jobs=-1)\nrf.fit(X_full, y_full)\n\nperm = permutation_importance(rf, X_full, y_full, n_repeats=20, random_state=GLOBAL_SEED, n_jobs=-1)\nimportance_df = pd.DataFrame({\n    \"feature\": full_features, \n    \"importance_mean\": perm.importances_mean, \n    \"importance_std\": perm.importances_std\n}).sort_values(\"importance_mean\", ascending=False)\nimportance_df.to_csv(os.path.join(OUTPUT_DIR, \"feature_importance_max_cluster_size.csv\"), index=False)\n\n# --- 8. SHAP 분석 ---\nshap_status = {\"available\": False, \"message\": \"SHAP not installed or skipped.\"}\ntry:\n    import shap\n    explainer = shap.TreeExplainer(rf)\n    shap_values = explainer.shap_values(X_full)\n    # 회귀 모델의 경우 2차원 array이므로 직접 평균을 취하며, 분류의 경우 리스트 구조 방어\n    if isinstance(shap_values, list):\n        shap_abs = np.abs(shap_values[1]).mean(axis=0)\n    else:\n        shap_abs = np.abs(shap_values).mean(axis=0)\n        \n    shap_df = pd.DataFrame({\"feature\": full_features, \"mean_abs_shap\": shap_abs}).sort_values(\"mean_abs_shap\", ascending=False)\n    shap_df.to_csv(os.path.join(OUTPUT_DIR, \"shap_summary_max_cluster_size.csv\"), index=False)\n    shap_status = {\"available\": True, \"message\": \"SHAP summary CSV saved.\"}\nexcept Exception as e:\n    shap_df = pd.DataFrame({\"feature\": full_features, \"mean_abs_shap\": np.nan})\n    shap_status = {\"available\": False, \"message\": str(e)}\n\n# --- 9. 안전한 상관관계 계산 함수 ---\ndef safe_corr(a, b):\n    # 인덱스 미스매치와 무한대(inf) 값을 깔끔하게 방어한 피어슨 상관계수\n    a_clean = pd.Series(a).replace([np.inf, -np.inf], np.nan).dropna()\n    b_clean = pd.Series(b).replace([np.inf, -np.inf], np.nan).dropna()\n    \n    common_idx = a_clean.index.intersection(b_clean.index)\n    if len(common_idx) < 2:\n        return np.nan\n        \n    va = a_clean.loc[common_idx].values\n    vb = b_clean.loc[common_idx].values\n    \n    if np.nanstd(va) <= 1e-12 or np.nanstd(vb) <= 1e-12:\n        return np.nan\n    return float(np.corrcoef(va, vb)[0, 1])\n\n# --- 10. 가설 분석 결과 요약 생성 및 저장 ---\nanalysis_summary = {\n    \"main_hypothesis_pixel_auc\": pixel_auc_df.to_dict(orient=\"records\"),\n    \"best_models_by_outcome\": model_comparison_df.sort_values(\"mean_score\", ascending=False).groupby(\"outcome\").head(1).to_dict(orient=\"records\"),\n    \"H2_corr_te_front_velocity\": safe_corr(summary_df[\"te_like_source_to_far\"], summary_df[\"front_velocity_proxy\"]),\n    \"H3_network_threshold_summary\": threshold_df.to_dict(orient=\"records\"),\n    \"H4_corr_js_network_efficiency\": safe_corr(summary_df[\"global_js_divergence\"], summary_df[\"network_global_efficiency\"]),\n    \"H4_corr_kl_network_efficiency\": safe_corr(summary_df[\"global_kl_divergence\"], summary_df[\"network_global_efficiency\"]),\n    \"H4_corr_flux_network_efficiency\": safe_corr(summary_df[\"flux_imbalance_proxy\"], summary_df[\"network_global_efficiency\"]),\n    \"H5_noise_response\": noise_df.to_dict(orient=\"records\"),\n    \"temporal_mechanism_summary\": {\n        \"mean_mechanism_order_score\": float(summary_df[\"mechanism_order_score\"].mean()), \n        \"interpretation\": \"Higher mechanism_order_score supports a temporal sequence in which probability redistribution precedes information interaction, network organization, and later geometry em