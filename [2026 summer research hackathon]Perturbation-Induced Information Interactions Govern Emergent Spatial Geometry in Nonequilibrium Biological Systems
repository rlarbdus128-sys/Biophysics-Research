def laplacian_periodic(x):
    return np.roll(x, 1, 0) + np.roll(x, -1, 0) + np.roll(x, 1, 1) + np.roll(x, -1, 1) - 4.0 * x

def perturbation_mask(n, radius):
    yy, xx = np.mgrid[0:n, 0:n]
    cy, cx = n // 2, n // 2
    return np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2) <= radius

def rings(n, n_rings=5):
    yy, xx = np.mgrid[0:n, 0:n]
    cy, cx = n // 2, n // 2
    r = np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2)
    edges = np.linspace(0, r.max(), n_rings + 1)
    return [(r >= edges[i]) & (r < edges[i + 1]) for i in range(n_rings)]

def discretize(x, n_bins=8):
    edges = np.unique(np.quantile(np.asarray(x).ravel(), np.linspace(0, 1, n_bins + 1)))
    if len(edges) <= 2:
        return np.zeros_like(x, dtype=np.int16)
    return np.digitize(x, edges[1:-1]).astype(np.int16)

def label_prob(labels):
    values, counts = np.unique(labels.ravel(), return_counts=True)
    p = counts.astype(float) / max(counts.sum(), 1)
    return values.astype(int), p

def entropy_from_labels(labels):
    _, p = label_prob(labels)
    return float(-np.sum(p * np.log2(p + 1e-12)))

def kl_divergence_from_labels(a, b):
    va, pa = label_prob(a)
    vb, pb = label_prob(b)
    keys = np.union1d(va, vb)
    da = dict(zip(va, pa))
    db = dict(zip(vb, pb))
    p = np.array([da.get(k, 0.0) for k in keys])
    q = np.array([db.get(k, 0.0) for k in keys])
    return float(np.sum(p * np.log2((p + 1e-12) / (q + 1e-12))))

def js_divergence_from_labels(a, b):
    va, pa = label_prob(a)
    vb, pb = label_prob(b)
    keys = np.union1d(va, vb)
    da = dict(zip(va, pa))
    db = dict(zip(vb, pb))
    p = np.array([da.get(k, 0.0) for k in keys])
    q = np.array([db.get(k, 0.0) for k in keys])
    m = 0.5 * (p + q)
    return float(0.5 * np.sum(p * np.log2((p + 1e-12) / (m + 1e-12))) + 0.5 * np.sum(q * np.log2((q + 1e-12) / (m + 1e-12))))

def normalized_mi(x, y, n_bins=8):
    xb = discretize(x, n_bins).ravel()
    yb = discretize(y, n_bins).ravel()
    mi = mutual_info_score(xb, yb)
    hx = mutual_info_score(xb, xb)
    hy = mutual_info_score(yb, yb)
    return float(mi / max(np.sqrt(hx * hy), 1e-12))

def state_labels(U, V, n_bins=8):
    return discretize(U, n_bins) * n_bins + discretize(V, n_bins)

def local_window_metric(A, B, radius, func):
    n = A.shape[0]
    size = 2 * radius + 1
    Ap = np.pad(A, radius, mode="wrap")
    Bp = np.pad(B, radius, mode="wrap")
    out = np.zeros_like(A, dtype=np.float32)
    for i in range(n):
        for j in range(n):
            out[i, j] = func(Ap[i:i + size, j:j + size], Bp[i:i + size, j:j + size])
    return out

def local_mi_map(U, V, n_bins=8):
    return local_window_metric(U, V, radius=2, func=lambda a, b: normalized_mi(a, b, n_bins))

def local_js_map(state_pre, state_post):
    return local_window_metric(state_pre, state_post, radius=2, func=js_divergence_from_labels)

def local_kl_map(state_pre, state_post):
    return local_window_metric(state_pre, state_post, radius=2, func=kl_divergence_from_labels)

def neighbor_mi_map(V, n_bins=8):
    neighbor = 0.25 * (np.roll(V, 1, 0) + np.roll(V, -1, 0) + np.roll(V, 1, 1) + np.roll(V, -1, 1))
    return local_mi_map(V, neighbor, n_bins)

def spatial_correlation_length(field):
    x = field - np.mean(field)
    var = np.var(x)
    if var <= 1e-12:
        return 0.0
    for lag in range(1, field.shape[0] // 2 + 1):
        corr = 0.5 * (np.mean(x * np.roll(x, lag, 0)) / var + np.mean(x * np.roll(x, lag, 1)) / var)
        if corr < np.exp(-1):
            return float(lag)
    return float(field.shape[0] // 2)

def cluster_and_topology(field, quantile=0.80):
    binary = field >= np.quantile(field, quantile)
    labels, n_components = ndimage.label(binary)
    sizes = np.asarray(ndimage.sum(binary, labels, index=np.arange(1, n_components + 1)), dtype=float)
    filled = ndimage.binary_fill_holes(binary)
    holes = filled & (~binary)
    _, n_holes = ndimage.label(holes)
    eroded = ndimage.binary_erosion(binary)
    interface = binary ^ eroded
    return {
        "binary": binary,
        "n_clusters": int(n_components),
        "mean_cluster_size": float(np.mean(sizes)) if len(sizes) else 0.0,
        "max_cluster_size": float(np.max(sizes)) if len(sizes) else 0.0,
        "interface_length": float(np.sum(interface)),
        "betti0_like": int(n_components),
        "betti1_like": int(n_holes),
        "euler_characteristic_like": int(n_components - n_holes),
    }

def front_radius(binary):
    n = binary.shape[0]
    yy, xx = np.mgrid[0:n, 0:n]
    cy, cx = n // 2, n // 2
    r = np.sqrt((yy - cy) ** 2 + (xx - cx) ** 2)
    return float(np.mean(r[binary])) if np.sum(binary) else 0.0

def anisotropy(field):
    gy, gx = np.gradient(field)
    tensor = np.array([[np.mean(gx * gx), np.mean(gx * gy)], [np.mean(gx * gy), np.mean(gy * gy)]])
    vals = np.linalg.eigvalsh(tensor)
    return float((vals[-1] - vals[0]) / (np.sum(vals) + 1e-12))

def patch_means(field, patch_size):
    n = field.shape[0]
    m = n // patch_size
    cropped = field[:m * patch_size, :m * patch_size]
    return cropped.reshape(m, patch_size, m, patch_size).mean(axis=(1, 3)).ravel()

def patch_series(saved_fields, patch_size):
    return np.vstack([patch_means(f, patch_size) for f in saved_fields])

def network_descriptors(saved_V, patch_size, n_bins=8, network_quantile=0.75):
    X = patch_series(saved_V, patch_size)
    n_nodes = X.shape[1]
    W = np.zeros((n_nodes, n_nodes), dtype=np.float32)
    for i in range(n_nodes):
        for j in range(i + 1, n_nodes):
            W[i, j] = normalized_mi(X[:, i], X[:, j], n_bins)
            W[j, i] = W[i, j]
    nonzero = W[W > 0]
    if len(nonzero) == 0:
        empty = {
            "network_edge_density": 0.0,
            "network_mean_weight": 0.0,
            "network_degree_entropy": 0.0,
            "network_clustering_coeff": 0.0,
            "network_average_path_length": 0.0,
            "network_global_efficiency": 0.0,
            "network_assortativity": 0.0,
            "network_modularity_like": 0.0,
        }
        return empty, W
    threshold = np.quantile(nonzero, network_quantile)
    A = (W >= threshold).astype(float)
    np.fill_diagonal(A, 0)
    degree = A.sum(axis=1)
    edge_density = float(A.sum() / max(n_nodes * (n_nodes - 1), 1))
    mean_weight = float(W[A > 0].mean()) if np.any(A > 0) else 0.0
    p_degree = degree / max(degree.sum(), 1e-12)
    degree_entropy = float(-np.sum(p_degree[p_degree > 0] * np.log2(p_degree[p_degree > 0])))
    clustering_vals = []
    for i in range(n_nodes):
        neigh = np.where(A[i] > 0)[0]
        k = len(neigh)
        clustering_vals.append(0.0 if k < 2 else A[np.ix_(neigh, neigh)].sum() / (k * (k - 1)))
    clustering_coeff = float(np.mean(clustering_vals))
    dist = np.where(A > 0, 1.0, np.inf)
    np.fill_diagonal(dist, 0)
    for k in range(n_nodes):
        dist = np.minimum(dist, dist[:, [k]] + dist[[k], :])
    finite_dist = dist[np.isfinite(dist) & (dist > 0)]
    average_path_length = float(np.mean(finite_dist)) if len(finite_dist) else 0.0
    inv_dist = np.where(np.isfinite(dist) & (dist > 0), 1.0 / dist, 0.0)
    global_efficiency = float(inv_dist.sum() / max(n_nodes * (n_nodes - 1), 1))
    edge_i, edge_j = np.where(np.triu(A, 1) > 0)
    if len(edge_i) > 1 and np.std(degree[edge_i]) > 1e-12 and np.std(degree[edge_j]) > 1e-12:
        assortativity = float(np.corrcoef(degree[edge_i], degree[edge_j])[0, 1])
    else:
        assortativity = 0.0
    labels, n_comp = ndimage.label(A > 0)
    component_sizes = np.array([np.sum(labels == i) for i in range(1, n_comp + 1)], dtype=float)
    modularity_like = float(np.max(component_sizes) / n_nodes) if len(component_sizes) else 0.0
    return {
        "network_edge_density": edge_density,
        "network_mean_weight": mean_weight,
        "network_degree_entropy": degree_entropy,
        "network_clustering_coeff": clustering_coeff,
        "network_average_path_length": average_path_length,
        "network_global_efficiency": global_efficiency,
        "network_assortativity": assortativity,
        "network_modularity_like": modularity_like,
    }, W

