def safe_corr(a, b):
    a_clean = pd.Series(a).replace([np.inf, -np.inf], np.nan).dropna()
    b_clean = pd.Series(b).replace([np.inf, -np.inf], np.nan).dropna()
    
    common_idx = a_clean.index.intersection(b_clean.index)
    if len(common_idx) < 2:
        return np.nan
        
    va = a_clean.loc[common_idx].values
    vb = b_clean.loc[common_idx].values
    
    if np.nanstd(va) <= 1e-12 or np.nanstd(vb) <= 1e-12:
        return np.nan
    return float(np.corrcoef(va, vb)[0, 1])

