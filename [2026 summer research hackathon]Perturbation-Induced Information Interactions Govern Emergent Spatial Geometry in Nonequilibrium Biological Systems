    ("delta_entropy", "max_cluster_size"),
    ("global_js_divergence", "mean_delta_local_mi"),
    ("mean_delta_local_mi", "max_cluster_size"),
    ("network_global_efficiency", "max_cluster_size"),
    ("network_global_efficiency", "interface_length"),
    ("network_mean_weight", "max_cluster_size"),
    ("noise_level", "mean_delta_local_mi"),
    ("noise_level", "betti1_like"),
    ("temporal_probability_redistribution_js_temporal_auc", "max_cluster_size"),
    ("temporal_information_interaction_mi_temporal_auc", "max_cluster_size"),
]

rows = []
for x, y in pairs:
    if x in summary.columns and y in summary.columns:
        valid = summary[[x, y]].dropna()
        if len(valid) > 2:
            pr = pearsonr(valid[x], valid[y])[0]
            sr = spearmanr(valid[x], valid[y])[0]
            rows.append({
                "x": x,
                "y": y,
                "pearson_r": pr,
                "spearman_rho": sr,
                "n": len(valid),
            })

corr_df = pd.DataFrame(rows)
corr_df.to_csv(f"{outdir}/paper_selected_correlations.csv", index=False)

