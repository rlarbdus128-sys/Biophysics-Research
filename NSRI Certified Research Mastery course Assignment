import pandas as pd\nfrom scipy import sparse\nfrom scipy.stats import pearsonr, spearmanr\nfrom scipy.spatial.distance import pdist\nfrom sklearn.decomposition import TruncatedSVD\nimport matplotlib.pyplot as plt\n\n\n# ------------------------------------------------------------\n# 0. Paths\n# ------------------------------------------------------------\n\nOUT = Path(\"/kaggle/working/norman_response_compression_outputs\")\nDERIVED = OUT / \"derived_downstream_outputs\"\nDERIVED.mkdir(parents=True, exist_ok=True)\n\nprint(\"Input output directory:\", OUT)\nprint(\"Derived output directory:\", DERIVED)\n\n\n# ------------------------------------------------------------\n# 1. Utility functions\n# ------------------------------------------------------------\n\ndef file_status(path):\n    path = Path(path)\n    return {\n        \"file\": str(path),\n        \"exists\": path.exists(),\n        \"size_bytes\": path.stat().st_size if path.exists() else 0\n    }\n\n\ndef load_first_column_csv(path):\n    df = pd.read_csv(path)\n    return df.iloc[:, 0].astype(str).to_numpy()\n\n\ndef normalize_bool_series(s):\n    if s.dtype == bool:\n        return s.fillna(False)\n\n    x = s.astype(str).str.lower().str.strip()\n    return x.isin((\"true\", \"1\", \"yes\", \"y\", \"control\", \"ctrl\"))\n\n\ndef safe_pearson(x, y):\n    x = np.asarray(x).ravel()\n    y = np.asarray(y).ravel()\n\n    if len(x) < 3:\n        return np.nan\n\n    if np.nanstd(x) == 0 or np.nanstd(y) == 0:\n        return np.nan\n\n    return pearsonr(x, y)[0]\n\n\ndef safe_spearman(x, y):\n    x = np.asarray(x).ravel()\n    y = np.asarray(y).ravel()\n\n    if len(x) < 3:\n        return np.nan\n\n    if np.nanstd(x) == 0 or np.nanstd(y) == 0:\n        return np.nan\n\n    return spearmanr(x, y).correlation\n\n\ndef vector_metrics(obs, pred):\n    obs = np.asarray(obs).ravel()\n    pred = np.asarray(pred).ravel()\n\n    residual = obs - pred\n\n    obs_l2 = np.sqrt(np.sum(obs ** 2))\n    pred_l2 = np.sqrt(np.sum(pred ** 2))\n    residual_l2 = np.sqrt(np.sum(residual ** 2))\n\n    rmse = np.sqrt(np.mean(residual ** 2))\n    obs_rms = np.sqrt(np.mean(obs ** 2))\n    relative_rmse = rmse / (obs_rms + 1e-12)\n\n    denom = obs_l2 * pred_l2\n\n    cosine = np.dot(obs, pred) / denom if denom > 0 else np.nan\n\n    return {\n        \"pearson\": safe_pearson(obs, pred),\n        \"spearman\": safe_spearman(obs, pred),\n        \"cosine_similarity\": cosine,\n        \"rmse\": rmse,\n        \"relative_rmse\": relative_rmse,\n        \"observed_l2_norm\": obs_l2,\n        \"predicted_l2_norm\": pred_l2,\n        \"residual_l2_norm\": residual_l2,\n        \"mean_abs_residual\": np.mean(np.abs(residual)),\n        \"max_abs_residual\": np.max(np.abs(residual))\n    }\n\n\n# ------------------------------------------------------------\n# 2. Load data\n# ------------------------------------------------------------\n\nmeta_path = OUT / \"perturbation_metadata_with_type.csv\"\nR_hvg_path = OUT / \"R_hvg_response_matrix.npz\"\nhvg_gene_path = OUT / \"hvg_genes.csv\"\n\nmeta = pd.read_csv(meta_path)\nR_hvg = sparse.load_npz(R_hvg_path).tocsr()\n\nif hvg_gene_path.exists():\n    hvg_genes = load_first_column_csv(hvg_gene_path)\nelse:\n    hvg_genes = np.array([f\"hvg_{i}\" for i in range(R_hvg.shape[1])])\n\nprint(\"Metadata shape:\", meta.shape)\nprint(\"R_hvg shape:\", R_hvg.shape)\n\n\n# ------------------------------------------------------------\n# 3. Response strength metrics\n# ------------------------------------------------------------\n\nprint(\"\\nGenerating response strength metrics...\")\n\nabs_R = abs(R_hvg)\n\nresponse_strength = meta.copy()\n\nresponse_strength[\"response_l2_norm_hvg\"] = np.sqrt(\n    R_hvg.power(2).sum(axis=1)\n).A1\n\nresponse_strength[\"response_l1_norm_hvg\"] = abs_R.sum(axis=1).A1\n\nresponse_strength[\"mean_abs_response_hvg\"] = (\n    abs_R.sum(axis=1).A1 / R_hvg.shape[1]\n)\n\nresponse_strength[\"max_abs_response_hvg\"] = (\n    abs_R.max(axis=1).toarray().ravel()\n)\n\nfor threshold in (0.01, 0.05, 0.10, 0.20):\n    col = f\"n_hvg_abs_response_gt_{str(threshold).replace('.', 'p')}\"\n    response_strength[col] = (abs_R > threshold).sum(axis=1).A1\n\nresponse_strength.to_csv(\n    DERIVED / \"perturbation_response_strength_metrics.csv\",\n    index=False\n)\n\nprint(\"Saved response strength metrics\")\n\n\n# ------------------------------------------------------------\n# 4. Response strength distribution plot\n# ------------------------------------------------------------\n\nplt.figure(figsize=(8, 5))\n\nplt.hist(\n    response_strength[\"response_l2_norm_hvg\"],\n    bins=50\n)\n\nplt.xlabel(\"HVG response L2 norm\")\nplt.ylabel(\"Number of perturbations\")\nplt.title(\"Perturbation response strength distribution\")\n\nplt.tight_layout()\n\nplt.savefig(\n    DERIVED / \"fig_response_strength_distribution.png\",\n    dpi=200\n)\n\nplt.close()\n\nprint(\"Saved response strength figure\")\n\n\n# ------------------------------------------------------------\n# 5. Latent coordinates with TruncatedSVD\n# ------------------------------------------------------------\n\nprint(\"\\nGenerating latent coordinates...\")\n\nn_perturbations, n_genes = R_hvg.shape\n\ncandidate_k = [2, 3, 5, 10, 20]\n\ncandidate_k = [\n    k for k in candidate_k\n    if k < min(n_perturbations, n_genes)\n]\n\nlatent_geometry_rows = []\n\nR_dense = R_hvg.toarray()\n\noriginal_dist = pdist(R_dense, metric=\"euclidean\")\n\nfor k in candidate_k:\n\n    print(\"Running SVD with k =\", k)\n\n    svd = TruncatedSVD(\n        n_components=k,\n        random_state=0\n    )\n\n    Z = svd.fit_transform(R_hvg)\n\n    coord_df = meta.copy()\n\n    for j in range(k):\n        coord_df[f\"latent_{j+1}\"] = Z[:, j]\n\n    coord_path = DERIVED / f\"latent_coordinates_svd_k{k}.csv\"\n\n    coord_df.to_csv(coord_path, index=False)\n\n    loading_df = pd.DataFrame({\n        \"gene\": hvg_genes\n    })\n\n    for j in range(k):\n        loading_df[f\"component_{j+1}\"] = svd.components_[j]\n\n    loading_path = DERIVED / f\"latent_gene_loadings_svd_k{k}.csv\"\n\n    loading_df.to_csv(loading_path, index=False)\n\n    latent_dist = pdist(Z, metric=\"euclidean\")\n\n    latent_geometry_rows.append({\n        \"model\": \"TruncatedSVD\",\n        \"n_components\": k,\n        \"explained_variance_ratio_sum\":\n            float(np.sum(svd.explained_variance_ratio_)),\n        \"geometry_pearson\":\n            safe_pearson(original_dist, latent_dist),\n        \"geometry_spearman\":\n            safe_spearman(original_dist, latent_dist)\n    })\n\nlatent_geometry_df = pd.DataFrame(latent_geometry_rows)\n\nlatent_geometry_df.to_csv(\n    DERIVED / \"latent_geometry_metrics.csv\",\n    index=False\n)\n\nprint(\"Saved latent geometry metrics\")\n\n\n# ------------------------------------------------------------\n# 6. Double perturbation additive residuals\n# ------------------------------------------------------------\n\nprint(\"\\nGenerating additive residual metrics...\")\n\npairs_path = OUT / \"double_perturbation_pairs_detected.csv\"\n\nif pairs_path.exists():\n\n    pairs = pd.read_csv(pairs_path)\n\n    pert_to_idx = {\n        str(p): i\n        for i, p in enumerate(\n            meta[\"perturbation\"].astype(str)\n        )\n    }\n\n    residual_rows = []\n\n    for row in pairs.itertuples(index=False):\n\n        if not (\n            hasattr(row, \"pair\")\n            and hasattr(row, \"gene_a\")\n            and hasattr(row, \"gene_b\")\n        ):\n            continue\n\n        double_name = str(row.pair)\n        a_name = str(row.gene_a)\n        b_name = str(row.gene_b)\n\n        if (\n            double_name not in pert_to_idx\n            or a_name not in pert_to_idx\n            or b_name not in pert_to_idx\n        ):\n            continue\n\n        obs = R_hvg[\n            pert_to_idx[double_name]\n        ].toarray().ravel()\n\n        pred = (\n            R_hvg[pert_to_idx[a_name]].toarray().ravel()\n            + R_hvg[pert_to_idx[b_name]].toarray().ravel()\n        )\n\n        metrics = vector_metrics(obs, pred)\n\n        out = {\n            \"double_perturbation\": double_name,\n            \"perturbation_a\": a_name,\n            \"perturbation_b\": b_name\n        }\n\n        out.update(metrics)\n\n        residual_rows.append(out)\n\n    residual_df = pd.DataFrame(residual_rows)\n\n    residual_df.to_csv(\n        DERIVED / \"double_additive_residual_metrics_hvg.csv\",\n        index=False\n    )\n\n    print(\"Saved additive residual metrics\")\n\n\n# ------------------------------------------------------------\n# 7. Final inventory\n# ------------------------------------------------------------\n\ngenerated_files = sorted(DERIVED.glob(\"*\"))\n\ninventory = pd.DataFrame([\n    file_status(f)\n    for f in generated_files\n])\n\ninventory.to_csv(\n    DERIVED / \"analysis_file_inventory_generated.csv\",\n    index=False\n)\n\nprint(\"\\nGenerated files:\")\ndisplay(inventory)\n\nprint(\"\\nDONE\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-15T05:53:27.332583Z","iopub.execute_input":"2026-05-15T05:53:27.332941Z","iopub.status.idle":"2026-05-15T05:53:28.911414Z","shell.execute_reply.started":"2026-05-15T05:53:27.332910Z","shell.execute_reply":"2026-05-15T05:53:28.910743Z"}},"outputs":[{"name":"stdout","text":"Input output directory: /kaggle/working/norman_response_compression_outputs\nDerived output directory: /kaggle/working/norman_response_compression_outputs/derived_downstream_outputs\nMetadata shape: (290, 4)\nR_hvg shape: (290, 2000)\n\nGenerating response strength metrics...\nSaved response strength metrics\nSaved response strength figure\n\nGenerating latent coordinates...\nRunning SVD with k = 2\nRunning SVD with k = 3\nRunning SVD with k = 5\nRunning SVD with k = 10\nRunning SVD with k = 20\nSaved latent geometry metrics\n\nGenerating additive residual metrics...\n\nGenerated files:\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"                                                 file  exists  size_bytes\n0   /kaggle/working/norman_response_compression_ou...    True       46914\n1   /kaggle/working/norman_response_compression_ou...    True       47890\n2   /kaggle/working/norman_response_compression_ou...    True       20088\n3   /kaggle/working/norman_response_compression_ou...    True       83105\n4   /kaggle/working/norman_response_compression_ou...    True       23489\n5   /kaggle/working/norman_response_compression_ou...    True       30390\n6   /kaggle/working/norman_response_compression_ou...    True      283004\n7   /kaggle/working/norman_response_compression_ou...    True       81937\n8   /kaggle/working/norman_response_compression_ou...    True      534298\n9   /kaggle/working/norman_response_compression_ou...    True      107104\n10  /kaggle/working/norman_response_compression_ou...    True      157440\n11  /kaggle/working/norman_response_compression_ou...    True         447\n12  /kaggle/working/norman_response_compression_ou...    True       29467","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>file</th>\n      <th>exists</th>\n      <th>size_bytes</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>0</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>46914</td>\n    </tr>\n    <tr>\n      <th>1</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>47890</td>\n    </tr>\n    <tr>\n      <th>2</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>20088</td>\n    </tr>\n    <tr>\n      <th>3</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>83105</td>\n    </tr>\n    <tr>\n      <th>4</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>23489</td>\n    </tr>\n    <tr>\n      <th>5</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>30390</td>\n    </tr>\n    <tr>\n      <th>6</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>283004</td>\n    </tr>\n    <tr>\n      <th>7</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>81937</td>\n    </tr>\n    <tr>\n      <th>8</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>534298</td>\n    </tr>\n    <tr>\n      <th>9</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>107104</td>\n    </tr>\n    <tr>\n      <th>10</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>157440</td>\n    </tr>\n    <tr>\n      <th>11</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>447</td>\n    </tr>\n    <tr>\n      <th>12</th>\n      <td>/kaggle/working/norman_response_compression_ou...</td>\n      <td>True</td>\n      <td>29467</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}},{"name":"stdout","text":"\nDONE\n","output_type":"stream"}],"execution_count":52},{"cell_type":"code","source":"# ============================================================\n# Final downstream file generation for Norman response analysis\n# CLEAN FIXED VERSION (copy-paste safe)\n# ============================================================\n\nfrom pathlib import Path\nimport json\nimport shutil\nimport warnings\n\nimport numpy as np\nimport pandas as pd\n\nfrom scipy import sparse\nfrom scipy.sparse import save_npz, load_npz, csr_matrix\nfrom scipy.stats import spearmanr\n\n\n# ------------------------------------------------------------\n# 0. Paths\n# ------------------------------------------------------------\n\nOUT = Path(\"/kaggle/working/norman_response_compression_outputs\")\nDERIVED = OUT / \"derived_downstream_outputs\"\nDERIVED.mkdir(parents=True, exist_ok=True)\n\nprint(\"OUT:\", OUT)\nprint(\"DERIVED:\", DERIVED)\n\n\n# ------------------------------------------------------------\n# 1. Helpers\n# ------------------------------------------------------------\n\ndef read_csv_if_exists(path):\n    path = Path(path)\n    if path.exists():\n        return pd.read_csv(path)\n    return None\n\n\ndef load_sparse_if_exists(path):\n    path = Path(path)\n    if path.exists():\n        try:\n            return load_npz(path).tocsr()\n        except Exception as e:\n            print(f\"WARNING: failed to load sparse matrix: {path}\")\n            print(e)\n            return None\n    return None\n\n\ndef save_json(obj, path):\n    path = Path(path)\n    with open(path, \"w\") as f:\n        json.dump(obj, f, indent=2, ensure_ascii=False)\n\n\ndef first_existing_column(df, candidates):\n    for c in candidates:\n        if c in df.columns:\n            return c\n    return None\n\n\ndef safe_numeric_series(df, col, default=np.nan):\n    if col is None or col not in df.columns:\n        return pd.Series(np.repeat(default, len(df)), index=df.index)\n    return pd.to_numeric(df[col], errors=\"coerce\")\n\n\ndef dense_row(mat, i):\n    row = mat.getrow(i)\n    return np.asarray(row.toarray()).ravel()\n\n\ndef vector_metrics(obs, pred, eps=1e-12):\n    obs = np.asarray(obs).ravel()\n    pred = np.asarray(pred).ravel()\n    resid = obs - pred\n\n    obs_norm = float(np.linalg.norm(obs))\n    pred_norm = float(np.linalg.norm(pred))\n    resid_norm = float(np.linalg.norm(resid))\n\n    rmse = float(np.sqrt(np.mean(resid ** 2)))\n    mae = float(np.mean(np.abs(resid)))\n\n    denom = obs_norm * pred_norm\n\n    if denom > eps:\n        cosine = float(np.dot(obs, pred) / denom)\n    else:\n        cosine = np.nan\n\n    if np.std(obs) > eps and np.std(pred) > eps:\n        pearson = float(np.corrcoef(obs, pred)[0, 1])\n    else:\n        pearson = np.nan\n\n    try:\n        sp = spearmanr(obs, pred)\n        spearman = float(sp.correlation)\n    except Exception:\n        spearman = np.nan\n\n    if obs_norm > eps:\n        relative_residual_norm = float(resid_norm / obs_norm)\n    else:\n        relative_residual_norm = np.nan\n\n    return {\n        \"observed_l2_norm\": obs_norm,\n        \"predicted_l2_norm\": pred_norm,\n        \"residual_l2_norm\": resid_norm,\n        \"relative_residual_l2_norm\": relative_residual_norm,\n        \"rmse\": rmse,\n        \"mae\": mae,\n        \"cosine_similarity\": cosine,\n        \"pearson_correlation\": pearson,\n        \"spearman_correlation\": spearman,\n    }\n\n\ndef normalize_name(x):\n    if pd.isna(x):\n        return \"\"\n    return str(x).strip()\n\n\ndef is_control_name(x):\n    s = normalize_name(x).lower()\n\n    control_tokens = {\n        \"control\",\n        \"ctrl\",\n        \"non-targeting\",\n        \"nontargeting\",\n        \"nt\",\n        \"negctrl\",\n        \"negative_control\",\n        \"safe-targeting\"\n    }\n\n    if s in control_tokens:\n        return True\n\n    if \"control\" in s:\n        return True\n\n    if \"ctrl\" in s:\n        return True\n\n    if \"non-target\" in s:\n        return True\n\n    if \"nontarget\" in s:\n        return True\n\n    return False\n\n\ndef parse_double_name(name, known_single_names=None):\n\n    s = normalize_name(name)\n\n    if not s:\n        return None, None, \"empty_name\"\n\n    known = set(known_single_names) if known_single_names is not None else set()\n\n    for sep in [\"+\", \"|\", \",\", \";\"]:\n        if sep in s:\n            parts = [p.strip() for p in s.split(sep) if p.strip()]\n            if len(parts) == 2:\n                return parts[0], parts[1], \"parsed\"\n\n    if \"__\" in s:\n        parts = [p.strip() for p in s.split(\"__\") if p.strip()]\n        if len(parts) == 2:\n            return parts[0], parts[1], \"parsed\"\n\n    if \"_\" in s:\n        parts = [p.strip() for p in s.split(\"_\") if p.strip()]\n        if len(parts) == 2:\n            a, b = parts\n            if not known or (a in known and b in known):\n                return a, b, \"parsed\"\n\n    return None, None, \"could_not_parse\"\n\n\n# ------------------------------------------------------------\n# 2. Load core files\n# ------------------------------------------------------------\n\nmeta_path = OUT / \"perturbation_metadata_with_type.csv\"\nhvg_path = OUT / \"R_hvg_response_matrix.npz\"\ngene_path = OUT / \"hvg_genes.csv\"\n\nmeta = read_csv_if_exists(meta_path)\nR_hvg = load_sparse_if_exists(hvg_path)\nhvg_genes = read_csv_if_exists(gene_path)\n\nif meta is None:\n    raise FileNotFoundError(f\"Missing required file: {meta_path}\")\n\nif R_hvg is None:\n    raise FileNotFoundError(\n        f\"\"\"\nCould not load sparse matrix:\n\n{hvg_path}\n\nThis usually means:\n1. the file does not exist\nOR\n2. the file is corrupted\nOR\n3. a dense matrix was accidentally saved with .npz\n\nCheck the file manually with:\n!ls -lh /kaggle/working/norman_response_compression_outputs\n\"\"\"\n    )\n\nif hvg_genes is None:\n    raise FileNotFoundError(f\"Missing required file: {gene_path}\")\n\nif R_hvg.shape[0] != len(meta):\n    raise ValueError(\n        f\"Row mismatch: R_hvg has {R_hvg.shape[0]} rows, \"\n        f\"but metadata has {len(meta)} rows.\"\n    )\n\npert_col = first_existing_column(\n    meta,\n    [\n        \"perturbation\",\n        \"perturbation_name\",\n        \"condition\",\n        \"gene\",\n        \"target\",\n        \"guide_target\"\n    ]\n)\n\nif pert_col is None:\n    raise ValueError(\"Could not find perturbation name column\")\n\ntype_col = first_existing_column(meta, [\"type\", \"perturbation_type\"])\nis_control_col = first_existing_column(meta, [\"is_control\", \"control\"])\nn_cells_col = first_existing_column(meta, [\"n_cells\", \"cell_count\", \"num_cells\"])\n\nprint(\"Metadata shape:\", meta.shape)\nprint(\"R_hvg shape:\", R_hvg.shape)\nprint(\"Perturbation column:\", pert_col)\n\n\n# ------------------------------------------------------------\n# 3. Response strength metrics\n# ------------------------------------------------------------\n\nprint(\"\\nGenerating response strength metrics...\")\n\nR = R_hvg.tocsr()\nabsR = abs(R)\n\nl2_norm = np.sqrt(np.asarray(R.multiply(R).sum(axis=1)).ravel())\nmean_abs = np.asarray(absR.mean(axis=1)).ravel()\n\ntry:\n    max_abs = np.asarray(absR.max(axis=1).toarray()).ravel()\nexcept Exception:\n    max_abs = np.array(\n        [absR.getrow(i).max() for i in range(absR.shape[0])],\n        dtype=float\n    )\n\nresponse_strength = meta.copy()\n\nresponse_strength[\"response_l2_norm_hvg\"] = l2_norm\nresponse_strength[\"mean_abs_response_hvg\"] = mean_abs\nresponse_strength[\"max_abs_response_hvg\"] = max_abs\n\nresponse_strength_path = (\n    DERIVED / \"perturbation_response_strength_metrics.csv\"\n)\n\nresponse_strength.to_csv(response_strength_path, index=False)\n\nprint(\"Saved:\", response_strength_path)\n\n\n# ------------------------------------------------------------\n# 4. File inventory\n# ------------------------------------------------------------\n\nprint(\"\\nGenerating file inventory...\")\n\nall_files = sorted(\n    [p for p in OUT.rglob(\"*\") if p.is_file()],\n    key=lambda p: str(p.relative_to(OUT))\n)\n\ninventory_rows = []\n\nfor p in all_files:\n    inventory_rows.append({\n        \"relative_path\": str(p.relative_to(OUT)),\n        \"absolute_path\": str(p),\n        \"size_bytes\": p.stat().st_size,\n        \"size_kb\": round(p.stat().st_size / 1024, 2),\n    })\n\n