{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ============================================================\n# 0. Robust dependency installation for Kaggle\n# ============================================================\n\nimport sys\nimport subprocess\nimport importlib\nimport importlib.util\nimport time\n\ndef ensure_package(pkg_name, pip_name=None):\n    pip_name = pip_name or pkg_name\n\n    # Already installed\n    if importlib.util.find_spec(pkg_name) is not None:\n        print(f\"[OK] {pkg_name} already installed.\")\n        return True\n\n    print(f\"[INFO] Installing {pip_name} ...\")\n\n    install_commands = [\n        [\n            sys.executable,\n            \"-m\",\n            \"pip\",\n            \"install\",\n            pip_name,\n            \"--quiet\",\n            \"--default-timeout=120\",\n            \"--retries\",\n            \"2\"\n        ]\n    ]\n\n    for cmd in install_commands:\n        try:\n            subprocess.run(\n                cmd,\n                check=True,\n                timeout=300\n            )\n\n            # verify installation\n            if importlib.util.find_spec(pkg_name) is not None:\n                print(f\"[OK] {pkg_name} installed successfully.\")\n                return True\n\n        except subprocess.TimeoutExpired:\n            print(\"[WARNING] pip install timeout exceeded.\")\n\n        except subprocess.CalledProcessError as e:\n            print(f\"[WARNING] pip install failed: {repr(e)}\")\n\n        except Exception as e:\n            print(f\"[WARNING] unexpected install error: {repr(e)}\")\n\n        time.sleep(3)\n\n    return False\n\n\nif not ensure_package(\"qutip\", \"qutip\"):\n    raise RuntimeError(\n        \"\\n[ERROR] qutip installation failed.\\n\"\n        \"\\nPossible causes:\\n\"\n        \"1. Kaggle Internet is OFF\\n\"\n        \"2. Temporary DNS/network failure\\n\"\n        \"3. PyPI connection timeout\\n\"\n        \"\\nFix:\\n\"\n        \"• Kaggle right sidebar → Settings\\n\"\n        \"• Turn Internet ON\\n\"\n        \"• Restart session\\n\"\n        \"• Run all cells again from the beginning\\n\"\n    )\n\nprint(\"[INFO] Dependency setup completed.\")\n\n# ============================================================\n# Paste the ORIGINAL research code below this line unchanged.\n# ============================================================\n# ============================================================\n# Bipartite Lindblad open quantum system:\n# Entropy-production diagnostics vs quantum mutual information\n# and entanglement dynamics under partial observation\n#\n# Self-contained Kaggle-ready script.\n# No external input data files required.\n# ============================================================\n\n# -----------------------------\n# 0. Install dependencies\n# -----------------------------\nimport sys\nimport subprocess\nimport importlib.util\n\ndef ensure_package(pkg_name, pip_name=None):\n    pip_name = pip_name or pkg_name\n    if importlib.util.find_spec(pkg_name) is None:\n        print(f\"Installing {pip_name} ...\")\n        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pip_name])\n    else:\n        print(f\"{pkg_name} already installed.\")\n\nensure_package(\"qutip\", \"qutip\")\n\n# -----------------------------\n# 1. Imports\n# -----------------------------\nimport os\nimport json\nimport math\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\n\nfrom scipy.stats import pearsonr, spearmanr\nfrom scipy.linalg import eigvalsh\n\nimport qutip\nfrom qutip import (\n    basis, tensor, qeye,\n    sigmax, sigmay, sigmaz, sigmam, sigmap,\n    ket2dm, mesolve, steadystate\n)\nfrom qutip.entropy import entropy_vn, negativity\n\n# -----------------------------\n# 2. Output directory\n# -----------------------------\nOUTDIR = \"/kaggle/working/open_quantum_partial_observation_outputs\"\nFIGDIR = os.path.join(OUTDIR, \"figures\")\nos.makedirs(OUTDIR, exist_ok=True)\nos.makedirs(FIGDIR, exist_ok=True)\n\n# -----------------------------\n# 3. Reproducibility settings\n# -----------------------------\nSEED = 123\nnp.random.seed(SEED)\n\nCONFIG = {\n    \"project\": \"bipartite_lindblad_partial_observation\",\n    \"random_seed\": SEED,\n    \"system\": \"two coupled qubits\",\n    \"dynamics\": \"Lindblad master equation\",\n    \"observation\": \"subsystem A observed; subsystem B traced out\",\n    \"entropy_production_diagnostic\": \"-d/dt quantum relative entropy to numerical steady state\",\n    \"important_caveat\": (\n        \"sigma_A and Delta_sigma_Q are operational partial-observation diagnostics, \"\n        \"not claimed to be universal thermodynamic entropy production.\"\n    ),\n    \"hbar\": 1.0,\n    \"time_grid\": {\n        \"t_min\": 0.0,\n        \"t_max\": 30.0,\n        \"n_points\": 301\n    },\n    \"parameter_grid\": {\n        \"J_values\": \"np.linspace(0.0, 2.0, 9)\",\n        \"gamma_phi_values\": \"np.linspace(0.0, 0.5, 6)\"\n    },\n    \"fixed_rates\": {\n        \"gamma_down\": 0.08,\n        \"gamma_up\": 0.02\n    },\n    \"qubit_frequencies\": {\n        \"omega_A\": 1.0,\n        \"omega_B\": 1.0\n    },\n    \"initial_state\": \"|10><10| product state\"\n}\n\nwith open(os.path.join(OUTDIR, \"metadata_config.json\"), \"w\") as f:\n    json.dump(CONFIG, f, indent=2)\n\n# -----------------------------\n# 4. Numerical utilities\n# -----------------------------\nEPS = 1e-12\n\ndef qobj_to_dense(rho):\n    \"\"\"Convert QuTiP Qobj to dense complex numpy array robustly.\"\"\"\n    data = rho.full()\n    return np.asarray(data, dtype=np.complex128)\n\ndef sanitize_density_matrix(mat):\n    \"\"\"\n    Hermitize, normalize trace, and softly clip tiny numerical eigenvalue noise.\n    Used only for numerical stability in entropy/relative-entropy calculations.\n    \"\"\"\n    mat = np.asarray(mat, dtype=np.complex128)\n    mat = 0.5 * (mat + mat.conj().T)\n    tr = np.trace(mat)\n    if abs(tr) > EPS:\n        mat = mat / tr\n    return mat\n\ndef matrix_log_psd(mat, eps=EPS):\n    \"\"\"\n    Matrix logarithm for positive semidefinite density-like matrices.\n    Eigenvalues are clipped at eps to avoid log(0) numerical singularities.\n    \"\"\"\n    mat = sanitize_density_matrix(mat)\n    vals, vecs = np.linalg.eigh(mat)\n    vals_clipped = np.clip(np.real(vals), eps, None)\n    log_vals = np.log(vals_clipped)\n    return (vecs * log_vals) @ vecs.conj().T\n\ndef quantum_relative_entropy(rho, sigma, eps=EPS):\n    \"\"\"\n    D(rho || sigma) = Tr[rho (log rho - log sigma)].\n    This is used as a numerical diagnostic relative to the steady state.\n    \"\"\"\n    r = sanitize_density_matrix(qobj_to_dense(rho) if hasattr(rho, \"full\") else rho)\n    s = sanitize_density_matrix(qobj_to_dense(sigma) if hasattr(sigma, \"full\") else sigma)\n    log_r = matrix_log_psd(r, eps=eps)\n    log_s = matrix_log_psd(s, eps=eps)\n    val = np.trace(r @ (log_r - log_s))\n    return float(np.real_if_close(val))\n\ndef renyi2_entropy_from_qobj(rho, eps=EPS):\n    \"\"\"S2(rho) = -log Tr(rho^2).\"\"\"\n    mat = sanitize_density_matrix(qobj_to_dense(rho))\n    purity = np.real(np.trace(mat @ mat))\n    purity = max(float(purity), eps)\n    return -np.log(purity)\n\ndef safe_entropy_vn(rho):\n    \"\"\"Natural-log von Neumann entropy using QuTiP, with fallback.\"\"\"\n    try:\n        return float(entropy_vn(rho, base=np.e))\n    except Exception:\n        mat = sanitize_density_matrix(qobj_to_dense(rho))\n        vals = np.clip(np.real(np.linalg.eigvalsh(mat)), EPS, None)\n        return float(-np.sum(vals * np.log(vals)))\n\ndef safe_negativity_log2(rho_ab):\n    \"\"\"Logarithmic negativity in log2 convention.\"\"\"\n    try:\n        return float(negativity(rho_ab, subsys=0, method=\"tracenorm\", logarithmic=True))\n    except Exception:\n        try:\n            return float(negativity(rho_ab, subsys=0, method=\"eigenvalues\", logarithmic=True))\n        except Exception:\n            return np.nan\n\ndef safe_pearson(x, y):\n    \"\"\"Pearson correlation with NaN protection.\"\"\"\n    x = np.asarray(x, dtype=float)\n    y = np.asarray(y, dtype=float)\n    mask = np.isfinite(x) & np.isfinite(y)\n    x = x[mask]\n    y = y[mask]\n    if len(x) < 3 or np.std(x) < EPS or np.std(y) < EPS:\n        return np.nan, np.nan\n    r, p = pearsonr(x, y)\n    return float(r), float(p)\n\ndef safe_spearman(x, y):\n    \"\"\"Spearman correlation with NaN protection.\"\"\"\n    x = np.asarray(x, dtype=float)\n    y = np.asarray(y, dtype=float)\n    mask = np.isfinite(x) & np.isfinite(y)\n    x = x[mask]\n    y = y[mask]\n    if len(x) < 3 or np.std(x) < EPS or np.std(y) < EPS:\n        return np.nan, np.nan\n    r, p = spearmanr(x, y)\n    return float(r), float(p)\n\n# -----------------------------\n# 5. Quantum system construction\n# -----------------------------\nI2 = qeye(2)\n\nsx_A = tensor(sigmax(), I2)\nsy_A = tensor(sigmay(), I2)\nsz_A = tensor(sigmaz(), I2)\nsm_A = tensor(sigmam(), I2)\nsp_A = tensor(sigmap(), I2)\n\nsx_B = tensor(I2, sigmax())\nsy_B = tensor(I2, sigmay())\nsz_B = tensor(I2, sigmaz())\nsm_B = tensor(I2, sigmam())\nsp_B = tensor(I2, sigmap())\n\ndef build_hamiltonian(J, omega_A=1.0, omega_B=1.0):\n    \"\"\"\n    Two-qubit Hamiltonian:\n    H = omega_A/2 sigma_z^A + omega_B/2 sigma_z^B\n        + J/2 (sigma_x^A sigma_x^B + sigma_y^A sigma_y^B)\n    \"\"\"\n    H0 = 0.5 * omega_A * sz_A + 0.5 * omega_B * sz_B\n    Hint = 0.5 * J * (sx_A * sx_B + sy_A * sy_B)\n    return H0 + Hint\n\ndef build_collapse_ops(gamma_down=0.08, gamma_up=0.02, gamma_phi=0.0):\n    \"\"\"\n    Local relaxation/excitation plus local pure dephasing.\n    \"\"\"\n    c_ops = []\n    if gamma_down > 0:\n        c_ops += [\n            np.sqrt(gamma_down) * sm_A,\n            np.sqrt(gamma_down) * sm_B\n        ]\n    if gamma_up > 0:\n        c_ops += [\n            np.sqrt(gamma_up) * sp_A,\n            np.sqrt(gamma_up) * sp_B\n        ]\n    if gamma_phi > 0:\n        c_ops += [\n            np.sqrt(gamma_phi) * sz_A,\n            np.sqrt(gamma_phi) * sz_B\n        ]\n    return c_ops\n\ndef solve_master_equation(H, rho0, tlist, c_ops):\n    \"\"\"\n    Wrapper around QuTiP mesolve compatible with QuTiP 4/5 style options.\n    \"\"\"\n    try:\n        result = mesolve(\n            H, rho0, tlist, c_ops=c_ops, e_ops=[],\n            options={\"store_states\": True, \"nsteps\": 10000}\n        )\n    except TypeError:\n        from qutip import Options\n        result = mesolve(\n            H, rho0, tlist, c_ops, [],\n            options=Options(store_states=True, nsteps=10000)\n        )\n    return result\n\ndef compute_steady_state(H, c_ops, fallback_state=None):\n    \"\"\"\n    Numerical steady state. If solver fails, use fallback final state.\n    \"\"\"\n    try:\n        rho_ss = steadystate(H, c_ops)\n        return rho_ss\n    except Exception as e:\n        print(\"steadystate failed; using final state fallback:\", repr(e))\n        if fallback_state is None:\n            raise\n        return fallback_state\n\n# -----------------------------\n# 6. Initial state and time grid\n# -----------------------------\n# Product state |10>, so coupling can generate A-B correlations.\npsi0 = tensor(basis(2, 1), basis(2, 0))\nrho0 = ket2dm(psi0)\n\ntlist = np.linspace(\n    CONFIG[\"time_grid\"][\"t_min\"],\n    CONFIG[\"time_grid\"][\"t_max\"],\n    CONFIG[\"time_grid\"][\"n_points\"]\n)\n\n# -----------------------------\n# 7. Main simulation function\n# -----------------------------\ndef run_single_simulation(J, gamma_phi,\n                          gamma_down=0.08, gamma_up=0.02,\n                          omega_A=1.0, omega_B=1.0):\n    \"\"\"\n    Simulate one parameter condition and compute all time-resolved diagnostics.\n    \"\"\"\n    H = build_hamiltonian(J, omega_A=omega_A, omega_B=omega_B)\n    c_ops = build_collapse_ops(\n        gamma_down=gamma_down,\n        gamma_up=gamma_up,\n        gamma_phi=gamma_phi\n    )\n\n    result = solve_master_equation(H, rho0, tlist, c_ops)\n    states = result.states\n\n    rho_ss = compute_steady_state(H, c_ops, fallback_state=states[-1])\n    rhoA_ss = rho_ss.ptrace(0)\n    rhoB_ss = rho_ss.ptrace(1)\n\n    records = []\n\n    D_AB = []\n    D_A = []\n    D_B = []\n\n    S_AB_list = []\n    S_A_list = []\n    S_B_list = []\n    S2_A_list = []\n    Iq_list = []\n    EN_log2_list = []\n\n    for ti, rho_ab in zip(tlist, states):\n        rho_A = rho_ab.ptrace(0)\n        rho_B = rho_ab.ptrace(1)\n\n        S_AB = safe_entropy_vn(rho_ab)\n        S_A = safe_entropy_vn(rho_A)\n        S_B = safe_entropy_vn(rho_B)\n        Iq = S_A + S_B - S_AB\n        S2_A = renyi2_entropy_from_qobj(rho_A)\n        EN_log2 = safe_negativity_log2(rho_ab)\n\n        D_ab = quantum_relative_entropy(rho_ab, rho_ss)\n        D_a = quantum_relative_entropy(rho_A, rhoA_ss)\n        D_b = quantum_relative_entropy(rho_B, rhoB_ss)\n\n        D_AB.append(D_ab)\n        D_A.append(D_a)\n        D_B.append(D_b)\n\n        S_AB_list.append(S_AB)\n        S_A_list.append(S_A)\n        S_B_list.append(S_B)\n        S2_A_list.append(S2_A)\n        Iq_list.append(Iq)\n        EN_log2_list.append(EN_log2)\n\n    D_AB = np.asarray(D_AB)\n    D_A = np.asarray(D_A)\n    D_B = np.asarray(D_B)\n\n    # Entropy-production-like rates:\n    # sigma(t) = - d/dt D(rho(t)||rho_ss)\n    sigma_AB = -np.gradient(D_AB, tlist)\n    sigma_A = -np.gradient(D_A, tlist)\n    sigma_B = -np.gradient(D_B, tlist)\n    delta_sigma_Q = sigma_AB - sigma_A\n\n    # Dynamics of information/correlation diagnostics\n    S_A_arr = np.asarray(S_A_list)\n    S2_A_arr = np.asarray(S2_A_list)\n    Iq_arr = np.asarray(Iq_list)\n    EN_arr = np.asarray(EN_log2_list)\n\n    dS_A_dt = np.gradient(S_A_arr, tlist)\n    dS2_A_dt = np.gradient(S2_A_arr, tlist)\n    dIq_dt = np.gradient(Iq_arr, tlist)\n    dEN_dt = np.gradient(EN_arr, tlist)\n\n    for idx, ti in enumerate(tlist):\n        records.append({\n            \"J\": J,\n            \"gamma_phi\": gamma_phi,\n            \"time\": ti,\n            \"D_AB_to_ss\": D_AB[idx],\n            \"D_A_to_ss\": D_A[idx],\n            \"D_B_to_ss\": D_B[idx],\n            \"sigma_AB_rate\": sigma_AB[idx],\n            \"sigma_A_rate\": sigma_A[idx],\n            \"sigma_B_rate\": sigma_B[idx],\n            \"delta_sigma_Q_rate\": delta_sigma_Q[idx],\n            \"S_AB\": S_AB_list[idx],\n            \"S_A\": S_A_list[idx],\n            \"S_B\": S_B_list[idx],\n            \"S2_A\": S2_A_list[idx],\n            \"Iq_AB\": Iq_list[idx],\n            \"EN_log2\": EN_log2_list[idx],\n            \"dS_A_dt\": dS_A_dt[idx],\n            \"dS2_A_dt\": dS2_A_dt[idx],\n            \"dIq_dt\": dIq_dt[idx],\n            \"dEN_dt\": dEN_dt[idx]\n        })\n\n    ts_df = pd.DataFrame.from_records(records)\n\n    # Avoid initial derivative artifact by summarizing after first few points.\n    summary_df = ts_df.iloc[5:].copy()\n\n    # Time-series correlations per run\n    corr_pairs = {\n        \"corr_sigmaA_deltaSigmaQ\": (\"sigma_A_rate\", \"delta_sigma_Q_rate\"),\n        \"corr_sigmaAB_deltaSigmaQ\": (\"sigma_AB_rate\", \"delta_sigma_Q_rate\"),\n        \"corr_sigmaAB_dIq\": (\"sigma_AB_rate\", \"dIq_dt\"),\n        \"corr_sigmaAB_dEN\": (\"sigma_AB_rate\", \"dEN_dt\"),\n        \"corr_sigmaAB_dSA\": (\"sigma_AB_rate\", \"dS_A_dt\"),\n        \"corr_sigmaA_dIq\": (\"sigma_A_rate\", \"dIq_dt\"),\n        \"corr_sigmaA_dEN\": (\"sigma_A_rate\", \"dEN_dt\"),\n        \"corr_sigmaA_dSA\": (\"sigma_A_rate\", \"dS_A_dt\")\n    }\n\n    corr_results = {}\n    for name, (xcol, ycol) in corr_pairs.items():\n        r, p = safe_pearson(summary_df[xcol], summary_df[ycol])\n        rs, ps = safe_spearman(summary_df[xcol], summary_df[ycol])\n        corr_results[name + \"_pearson_r\"] = r\n        corr_results[name + \"_pearson_p\"] = p\n        corr_results[name + \"_spearman_r\"] = rs\n        corr_results[name + \"_spearman_p\"] = ps\n\n    run_summary = {\n        \"J\": J,\n        \"gamma_phi\": gamma_phi,\n        \"gamma_down\": gamma_down,\n        \"gamma_up\": gamma_up,\n\n        \"mean_sigma_AB_rate\": float(summary_df[\"sigma_AB_rate\"].mean()),\n        \"mean_sigma_A_rate\": float(summary_df[\"sigma_A_rate\"].mean()),\n        \"mean_delta_sigma_Q_rate\": float(summary_df[\"delta_sigma_Q_rate\"].mean()),\n\n        \"auc_sigma_AB\": float(np.trapz(np.maximum(summary_df[\"sigma_AB_rate\"], 0), summary_df[\"time\"])),\n        \"auc_sigma_A\": float(np.trapz(np.maximum(summary_df[\"sigma_A_rate\"], 0), summary_df[\"time\"])),\n        \"auc_delta_sigma_Q\": float(np.trapz(summary_df[\"delta_sigma_Q_rate\"], summary_df[\"time\"])),\n\n        \"mean_S_A\": float(summary_df[\"S_A\"].mean()),\n        \"mean_S2_A\": float(summary_df[\"S2_A\"].mean()),\n        \"mean_Iq_AB\": float(summary_df[\"Iq_AB\"].mean()),\n        \"mean_EN_log2\": float(summary_df[\"EN_log2\"].mean()),\n\n        \"max_Iq_AB\": float(summary_df[\"Iq_AB\"].max()),\n        \"max_EN_log2\": float(summary_df[\"EN_log2\"].max()),\n\n        \"min_sigma_AB_rate\": float(summary_df[\"sigma_AB_rate\"].min()),\n        \"min_sigma_A_rate\": float(summary_df[\"sigma_A_rate\"].min()),\n        \"min_delta_sigma_Q_rate\": float(summary_df[\"delta_sigma_Q_rate\"].min()),\n\n        **corr_results\n    }\n\n    return ts_df, run_summary\n\n# -----------------------------\n# 8. Parameter sweep\n# -----------------------------\nJ_values = np.linspace(0.0, 2.0, 9)\ngamma_phi_values = np.linspace(0.0, 0.5, 6)\n\nall_ts = []\nall_summaries = []\n\nfor J in J_values:\n    for gamma_phi in gamma_phi_values:\n        print(f\"Running J={J:.3f}, gamma_phi={gamma_phi:.3f}\")\n        ts_df, summary = run_single_simulation(\n            J=J,\n            gamma_phi=gamma_phi,\n            gamma_down=CONFIG[\"fixed_rates\"][\"gamma_down\"],\n            gamma_up=CONFIG[\"fixed_rates\"][\"gamma_up\"],\n            omega_A=CONFIG[\"qubit_frequencies\"][\"omega_A\"],\n            omega_B=CONFIG[\"qubit_frequencies\"][\"omega_B\"]\n        )\n        all_ts.append(ts_df)\n        all_summaries.append(summary)\n\ntime_series_df = pd.concat(all_ts, ignore_index=True)\nsummary_df = pd.DataFrame(all_summaries)\n\n# -----------------------------\n# 9. Cross-run correlation analysis\n# -----------------------------\ncross_pairs = {\n    \"cross_mean_sigmaA_vs_mean_deltaSigmaQ\": (\"mean_sigma_A_rate\", \"mean_delta_sigma_Q_rate\"),\n    \"cross_mean_sigmaAB_vs_mean_deltaSigmaQ\": (\"mean_sigma_AB_rate\", \"mean_delta_sigma_Q_rate\"),\n    \"cross_mean_sigmaAB_vs_mean_Iq\": (\"mean_sigma_AB_rate\", \"mean_Iq_AB\"),\n    \"cross_mean_sigmaAB_vs_mean_EN\": (\"mean_sigma_AB_rate\", \"mean_EN_log2\"),\n    \"cross_mean_sigmaA_vs_mean_Iq\": (\"mean_sigma_A_rate\", \"mean_Iq_AB\"),\n    \"cross_mean_sigmaA_vs_mean_EN\": (\"mean_sigma_A_rate\", \"mean_EN_log2\"),\n    \"cross_auc_sigmaAB_vs_max_Iq\": (\"auc_sigma_AB\", \"max_Iq_AB\"),\n    \"cross_auc_sigmaAB_vs_max_EN\": (\"auc_sigma_AB\", \"max_EN_log2\")\n}\n\ncross_records = []\nfor name, (xcol, ycol) in cross_pairs.items():\n    pr, pp = safe_pearson(summary_df[xcol], summary_df[ycol])\n    sr, sp = safe_spearman(summary_df[xcol], summary_df[ycol])\n    cross_records.append({\n        \"analysis\": name,\n        \"x\": xcol,\n        \"y\": ycol,\n        \"pearson_r\": pr,\n        \"pearson_p\": pp,\n        \"spearman_r\": sr,\n        \"spearman_p\": sp\n    })\n\ncross_corr_df = pd.DataFrame(cross_records)\n\n# -----------------------------\n# 10. Hypothesis decision summary\n# -----------------------------\ndef classify_corr(r):\n    if not np.isfinite(r):\n        return \"undefined\"\n    ar = abs(r)\n    if ar >= 0.7:\n        return \"strong\"\n    elif ar >= 0.4:\n        return \"moderate\"\n    elif ar >= 0.2:\n        return \"weak\"\n    else:\n        return \"negligible\"\n\nhypothesis_rows = []\n\n# H1: sigma_A tracks delta_sigma_Q across runs and within runs.\nh1_cross = cross_corr_df.loc[\n    cross_corr_df[\"analysis\"] == \"cross_mean_sigmaA_vs_mean_deltaSigmaQ\"\n].iloc[0]\n\nh1_within_mean = summary_df[\"corr_sigmaA_deltaSigmaQ_pearson_r\"].mean(skipna=True)\n\nhypothesis_rows.append({\n    \"hypothesis\": \"H1\",\n    \"claim_tested\": \"sigma_A is associated with Delta_sigma_Q\",\n    \"cross_run_pearson_r\": h1_cross[\"pearson_r\"],\n    \"cross_run_strength\": classify_corr(h1_cross[\"pearson_r\"]),\n    \"mean_within_run_pearson_r\": h1_within_mean,\n    \"mean_within_run_strength\": classify_corr(h1_within_mean),\n    \"interpretation\": (\n        \"Supported as a parameter-dependent association if cross-run or within-run \"\n        \"correlations are moderate/strong; not a causal claim.\"\n    )\n})\n\n# H2: sigma does not always track QMI/entanglement dynamics.\nh2_cols = [\n    \"corr_sigmaAB_dIq_pearson_r\",\n    \"corr_sigmaAB_dEN_pearson_r\",\n    \"corr_sigmaA_dIq_pearson_r\",\n    \"corr_sigmaA_dEN_pearson_r\"\n]\nh2_abs_mean = float(np.nanmean(np.abs(summary_df[h2_cols].values)))\nh2_abs_max = float(np.nanmax(np.abs(summary_df[h2_cols].values)))\n\nhypothesis_rows.append({\n    \"hypothesis\": \"H2\",\n    \"claim_tested\": \"entropy-production diagnostics do not universally track QMI/entanglement rates\",\n    \"mean_abs_time_series_corr\": h2_abs_mean,\n    \"max_abs_time_series_corr\": h2_abs_max,\n    \"mean_strength\": clas