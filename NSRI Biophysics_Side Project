======\n# 0. User settings\n# ============================================================\n\nTSD_PROJECT_NAME = \"bipartite_lindblad_partial_observation\"\n\nTSD_INPUT_PATH = None\n# Example:\n# TSD_INPUT_PATH = \"/kaggle/input/your_dataset/time_series_diagnostics.csv\"\n\nTSD_OUTPUT_DIR = \"/kaggle/working/tsd_summary_outputs\"\n\nTSD_REQUIRED_COLUMNS = [\n    \"J\",\n    \"gamma_phi\",\n    \"time\",\n    \"D_AB_to_ss\",\n    \"D_A_to_ss\",\n    \"D_B_to_ss\",\n    \"sigma_AB_rate\",\n    \"sigma_A_rate\",\n    \"sigma_B_rate\",\n    \"delta_sigma_Q_rate\",\n    \"S_AB\",\n    \"S_A\",\n    \"S_B\",\n    \"S2_A\",\n    \"Iq_AB\",\n    \"EN_log2\",\n    \"dS_A_dt\",\n    \"dS2_A_dt\",\n    \"dIq_dt\",\n    \"dEN_dt\",\n]\n\nTSD_PARAM_COLS = [\"J\", \"gamma_phi\"]\n\nTSD_TIME_COL = \"time\"\n\nTSD_VALUE_COLS = [\n    \"D_AB_to_ss\",\n    \"D_A_to_ss\",\n    \"D_B_to_ss\",\n    \"sigma_AB_rate\",\n    \"sigma_A_rate\",\n    \"sigma_B_rate\",\n    \"delta_sigma_Q_rate\",\n    \"S_AB\",\n    \"S_A\",\n    \"S_B\",\n    \"S2_A\",\n    \"Iq_AB\",\n    \"EN_log2\",\n    \"dS_A_dt\",\n    \"dS2_A_dt\",\n    \"dIq_dt\",\n    \"dEN_dt\",\n]\n\nTSD_RATE_COLS = [\n    \"sigma_AB_rate\",\n    \"sigma_A_rate\",\n    \"sigma_B_rate\",\n    \"delta_sigma_Q_rate\",\n]\n\nTSD_CORRELATION_PAIRS = [\n    (\"sigma_A_rate\", \"delta_sigma_Q_rate\"),\n    (\"sigma_AB_rate\", \"delta_sigma_Q_rate\"),\n    (\"sigma_B_rate\", \"delta_sigma_Q_rate\"),\n    (\"sigma_AB_rate\", \"dIq_dt\"),\n    (\"sigma_AB_rate\", \"dEN_dt\"),\n    (\"sigma_AB_rate\", \"dS_A_dt\"),\n    (\"sigma_AB_rate\", \"dS2_A_dt\"),\n    (\"sigma_A_rate\", \"dIq_dt\"),\n    (\"sigma_A_rate\", \"dEN_dt\"),\n    (\"sigma_A_rate\", \"dS_A_dt\"),\n    (\"sigma_A_rate\", \"dS2_A_dt\"),\n    (\"delta_sigma_Q_rate\", \"dIq_dt\"),\n    (\"delta_sigma_Q_rate\", \"dEN_dt\"),\n    (\"Iq_AB\", \"EN_log2\"),\n    (\"S_A\", \"S2_A\"),\n]\n\nTSD_CROSS_CORRELATION_PAIRS = [\n    (\"mean_sigma_A_rate\", \"mean_delta_sigma_Q_rate\"),\n    (\"mean_sigma_AB_rate\", \"mean_delta_sigma_Q_rate\"),\n    (\"mean_sigma_B_rate\", \"mean_delta_sigma_Q_rate\"),\n    (\"mean_sigma_AB_rate\", \"mean_Iq_AB\"),\n    (\"mean_sigma_AB_rate\", \"mean_EN_log2\"),\n    (\"mean_sigma_A_rate\", \"mean_Iq_AB\"),\n    (\"mean_sigma_A_rate\", \"mean_EN_log2\"),\n    (\"auc_sigma_AB_rate\", \"max_Iq_AB\"),\n    (\"auc_sigma_AB_rate\", \"max_EN_log2\"),\n    (\"auc_sigma_A_rate\", \"max_Iq_AB\"),\n    (\"auc_sigma_A_rate\", \"max_EN_log2\"),\n    (\"mean_delta_sigma_Q_rate\", \"mean_Iq_AB\"),\n    (\"mean_delta_sigma_Q_rate\", \"mean_EN_log2\"),\n]\n\nTSD_HEATMAP_METRICS = [\n    \"mean_sigma_AB_rate\",\n    \"mean_sigma_A_rate\",\n    \"mean_delta_sigma_Q_rate\",\n    \"auc_sigma_AB_rate\",\n    \"auc_sigma_A_rate\",\n    \"auc_delta_sigma_Q_rate\",\n    \"mean_Iq_AB\",\n    \"mean_EN_log2\",\n    \"max_Iq_AB\",\n    \"max_EN_log2\",\n]\n\nTSD_TRAJECTORY_METRICS = [\n    \"sigma_AB_rate\",\n    \"sigma_A_rate\",\n    \"delta_sigma_Q_rate\",\n    \"Iq_AB\",\n    \"EN_log2\",\n    \"S_A\",\n    \"S2_A\",\n    \"dIq_dt\",\n    \"dEN_dt\",\n]\n\nTSD_RANDOM_SEED = 123\ntsd_np.random.seed(TSD_RANDOM_SEED)\n\n\n# ============================================================\n# 1. Utility functions\n# ============================================================\n\ndef tsd_ensure_dir(tsd_path):\n    tsd_os.makedirs(tsd_path, exist_ok=True)\n\n\ndef tsd_find_input_file():\n\n    if TSD_INPUT_PATH is not None and tsd_os.path.exists(TSD_INPUT_PATH):\n        return TSD_INPUT_PATH\n\n    tsd_search_roots = [\n        \".\",\n        \"/kaggle/input\",\n        \"/kaggle/working\",\n    ]\n\n    tsd_patterns = [\n        \"**/time_series_diagnostics*.csv\",\n        \"**/time_series_diagnostics*.tsv\",\n        \"**/time_series_diagnostics*.xlsx\",\n        \"**/time_series_diagnostics*.xls\",\n        \"**/time_series_diagnostics*.parquet\",\n        \"**/time_series_diagnostics*.feather\",\n    ]\n\n    tsd_candidates = []\n\n    for tsd_root in tsd_search_roots:\n        if tsd_os.path.exists(tsd_root):\n            for tsd_pattern in tsd_patterns:\n                tsd_candidates.extend(\n                    tsd_glob.glob(\n                        tsd_os.path.join(tsd_root, tsd_pattern),\n                        recursive=True,\n                    )\n                )\n\n    tsd_candidates = sorted(list(set(tsd_candidates)))\n\n    if len(tsd_candidates) == 0:\n        raise FileNotFoundError(\n            \"No time_series_diagnostics file found.\"\n        )\n\n    return tsd_candidates[0]\n\n\ndef tsd_read_table(tsd_path):\n\n    tsd_ext = tsd_os.path.splitext(tsd_path)[1].lower()\n\n    if tsd_ext == \".csv\":\n        return tsd_pd.read_csv(tsd_path)\n\n    if tsd_ext == \".tsv\":\n        return tsd_pd.read_csv(tsd_path, sep=\"\\t\")\n\n    if tsd_ext in [\".xlsx\", \".xls\"]:\n        return tsd_pd.read_excel(tsd_path)\n\n    if tsd_ext == \".parquet\":\n        return tsd_pd.read_parquet(tsd_path)\n\n    if tsd_ext == \".feather\":\n        return tsd_pd.read_feather(tsd_path)\n\n    raise ValueError(f\"Unsupported extension: {tsd_ext}\")\n\n\ndef tsd_clean_columns(tsd_df):\n\n    tsd_df = tsd_df.copy()\n    tsd_df.columns = [str(c).strip() for c in tsd_df.columns]\n\n    return tsd_df\n\n\ndef tsd_validate_columns(tsd_df):\n\n    tsd_missing = [\n        c for c in TSD_REQUIRED_COLUMNS\n        if c not in tsd_df.columns\n    ]\n\n    if len(tsd_missing) > 0:\n        raise ValueError(\n            \"Missing required columns:\\n\"\n            + \"\\n\".join(tsd_missing)\n        )\n\n\ndef tsd_to_numeric(tsd_df):\n\n    tsd_df = tsd_df.copy()\n\n    for tsd_col in TSD_REQUIRED_COLUMNS:\n        tsd_df[tsd_col] = tsd_pd.to_numeric(\n            tsd_df[tsd_col],\n            errors=\"coerce\"\n        )\n\n    return tsd_df\n\n\ndef tsd_safe_auc(tsd_time, tsd_values):\n\n    tsd_time = tsd_np.asarray(tsd_time, dtype=float)\n    tsd_values = tsd_np.asarray(tsd_values, dtype=float)\n\n    tsd_mask = (\n        tsd_np.isfinite(tsd_time)\n        & tsd_np.isfinite(tsd_values)\n    )\n\n    if tsd_mask.sum() < 2:\n        return tsd_np.nan\n\n    tsd_order = tsd_np.argsort(tsd_time[tsd_mask])\n\n    return float(\n        tsd_np.trapz(\n            tsd_values[tsd_mask][tsd_order],\n            tsd_time[tsd_mask][tsd_order],\n        )\n    )\n\n\ndef tsd_strength_from_r(tsd_r):\n\n    if tsd_pd.isna(tsd_r):\n        return \"nan\"\n\n    tsd_abs = abs(float(tsd_r))\n\n    if tsd_abs >= 0.7:\n        return \"strong\"\n\n    if tsd_abs >= 0.3:\n        return \"moderate\"\n\n    if tsd_abs >= 0.1:\n        return \"weak\"\n\n    return \"negligible\"\n\n\ndef tsd_safe_corr(tsd_x, tsd_y, tsd_method=\"pearson\"):\n\n    tsd_x = tsd_pd.Series(tsd_x).astype(float)\n    tsd_y = tsd_pd.Series(tsd_y).astype(float)\n\n    tsd_mask = tsd_x.notna() & tsd_y.notna()\n\n    tsd_x = tsd_x[tsd_mask]\n    tsd_y = tsd_y[tsd_mask]\n\n    if len(tsd_x) < 3:\n        return tsd_np.nan, tsd_np.nan, int(len(tsd_x))\n\n    if (\n        tsd_x.nunique(dropna=True) <= 1\n        or tsd_y.nunique(dropna=True) <= 1\n    ):\n        return tsd_np.nan, tsd_np.nan, int(len(tsd_x))\n\n    if TSD_HAS_SCIPY:\n\n        try:\n\n            if tsd_method == \"pearson\":\n                tsd_r, tsd_p = tsd_stats.pearsonr(tsd_x, tsd_y)\n\n            elif tsd_method == \"spearman\":\n                tsd_r, tsd_p = tsd_stats.spearmanr(tsd_x, tsd_y)\n\n            else:\n                raise ValueError(\"Invalid correlation method\")\n\n            return float(tsd_r), float(tsd_p), int(len(tsd_x))\n\n        except Exception:\n            return tsd_np.nan, tsd_np.nan, int(len(tsd_x))\n\n    tsd_r = tsd_x.corr(tsd_y, method=tsd_method)\n\n    return float(tsd_r), tsd_np.nan, int(len(tsd_x))\n\n\ndef tsd_format_float(tsd_x):\n\n    if tsd_pd.isna(tsd_x):\n        return \"nan\"\n\n    return f\"{float(tsd_x):.6g}\"\n\n\n# ============================================================\n# 2. Load data\n# ============================================================\n\ntsd_ensure_dir(TSD_OUTPUT_DIR)\n\ntsd_input_file = tsd_find_input_file()\n\ntsd_df = tsd_read_table(tsd_input_file)\n\ntsd_df = tsd_clean_columns(tsd_df)\n\ntsd_validate_columns(tsd_df)\n\ntsd_df = tsd_to_numeric(tsd_df)\n\ntsd_df = tsd_df.dropna(\n    subset=TSD_PARAM_COLS + [TSD_TIME_COL]\n).copy()\n\ntsd_df = tsd_df.sort_values(\n    TSD_PARAM_COLS + [TSD_TIME_COL]\n).reset_index(drop=True)\n\n\n# ============================================================\n# 3. Derived quantities\n# ============================================================\n\ntsd_df[\"delta_sigma_Q_rate_recomputed\"] = (\n    tsd_df[\"sigma_AB_rate\"]\n    - tsd_df[\"sigma_A_rate\"]\n)\n\ntsd_df[\"delta_sigma_Q_rate_abs_error\"] = (\n    tsd_df[\"delta_sigma_Q_rate\"]\n    - tsd_df[\"delta_sigma_Q_rate_recomputed\"]\n).abs()\n\ntsd_df[\"run_id\"] = (\n    \"J=\"\n    + tsd_df[\"J\"].map(lambda x: f\"{x:.10g}\")\n    + \"_gamma_phi=\"\n    + tsd_df[\"gamma_phi\"].map(lambda x: f\"{x:.10g}\")\n)\n\ntsd_clean_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"time_series_diagnostics_clean_long.csv\"\n)\n\ntsd_df.to_csv(tsd_clean_path, index=False)\n\n\n# ============================================================\n# 4. Quality control\n# ============================================================\n\ntsd_qc_rows = []\n\ntsd_qc_rows.append({\n    \"item\": \"input_file\",\n    \"value\": tsd_input_file,\n})\n\ntsd_qc_rows.append({\n    \"item\": \"n_rows_after_loading\",\n    \"value\": int(len(tsd_df)),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"n_columns_after_processing\",\n    \"value\": int(tsd_df.shape[1]),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"n_parameter_runs\",\n    \"value\": int(\n        tsd_df[TSD_PARAM_COLS]\n        .drop_duplicates()\n        .shape[0]\n    ),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"time_min\",\n    \"value\": float(tsd_df[TSD_TIME_COL].min()),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"time_max\",\n    \"value\": float(tsd_df[TSD_TIME_COL].max()),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"n_unique_time_points\",\n    \"value\": int(tsd_df[TSD_TIME_COL].nunique()),\n})\n\ntsd_qc_rows.append({\n    \"item\": \"max_delta_sigma_Q_abs_error\",\n    \"value\": float(\n        tsd_df[\"delta_sigma_Q_rate_abs_error\"].max()\n    ),\n})\n\nfor tsd_col in TSD_REQUIRED_COLUMNS:\n\n    tsd_qc_rows.append({\n        \"item\": f\"missing_count_{tsd_col}\",\n        \"value\": int(tsd_df[tsd_col].isna().sum()),\n    })\n\ntsd_qc_df = tsd_pd.DataFrame(tsd_qc_rows)\n\ntsd_qc_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"quality_control_summary.csv\"\n)\n\ntsd_qc_df.to_csv(tsd_qc_path, index=False)\n\n\n# ============================================================\n# 5. Parameter grid overview\n# ============================================================\n\ntsd_param_grid_df = (\n    tsd_df\n    .groupby(TSD_PARAM_COLS, as_index=False)\n    .agg(\n        n_time_points=(\"time\", \"count\"),\n        time_min=(\"time\", \"min\"),\n        time_max=(\"time\", \"max\"),\n    )\n)\n\ntsd_param_grid_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"parameter_grid_overview.csv\"\n)\n\ntsd_param_grid_df.to_csv(\n    tsd_param_grid_path,\n    index=False\n)\n\n\n# ============================================================\n# 6. Run summary\n# ============================================================\n\ndef tsd_summarize_run(tsd_group):\n\n    tsd_group = tsd_group.sort_values(TSD_TIME_COL)\n\n    tsd_out = {\n        \"J\": float(tsd_group[\"J\"].iloc[0]),\n        \"gamma_phi\": float(tsd_group[\"gamma_phi\"].iloc[0]),\n        \"run_id\": str(tsd_group[\"run_id\"].iloc[0]),\n        \"n_time_points\": int(len(tsd_group)),\n        \"time_min\": float(tsd_group[TSD_TIME_COL].min()),\n        \"time_max\": float(tsd_group[TSD_TIME_COL].max()),\n    }\n\n    for tsd_col in TSD_VALUE_COLS:\n\n        tsd_vals = tsd_group[tsd_col]\n\n        tsd_out[f\"mean_{tsd_col}\"] = float(tsd_vals.mean())\n        tsd_out[f\"median_{tsd_col}\"] = float(tsd_vals.median())\n\n        tsd_out[f\"std_{tsd_col}\"] = (\n            float(tsd_vals.std(ddof=1))\n            if tsd_vals.notna().sum() > 1\n            else tsd_np.nan\n        )\n\n        tsd_out[f\"min_{tsd_col}\"] = float(tsd_vals.min())\n        tsd_out[f\"max_{tsd_col}\"] = float(tsd_vals.max())\n\n        tsd_out[f\"final_{tsd_col}\"] = float(tsd_vals.iloc[-1])\n        tsd_out[f\"initial_{tsd_col}\"] = float(tsd_vals.iloc[0])\n\n        tsd_out[f\"range_{tsd_col}\"] = float(\n            tsd_vals.max() - tsd_vals.min()\n        )\n\n        tsd_out[f\"auc_{tsd_col}\"] = tsd_safe_auc(\n            tsd_group[TSD_TIME_COL],\n            tsd_vals,\n        )\n\n    return tsd_pd.Series(tsd_out)\n\n\ntsd_run_summary_df = (\n    tsd_df\n    .groupby(TSD_PARAM_COLS, group_keys=False)\n    .apply(tsd_summarize_run)\n    .reset_index(drop=True)\n)\n\ntsd_run_summary_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"run_summary_by_parameter.csv\"\n)\n\ntsd_run_summary_df.to_csv(\n    tsd_run_summary_path,\n    index=False\n)\n\n\n# ============================================================\n# 7. Correlations\n# ============================================================\n\ntsd_within_corr_rows = []\n\nfor (tsd_J, tsd_gamma), tsd_group in tsd_df.groupby(TSD_PARAM_COLS):\n\n    tsd_group = tsd_group.sort_values(TSD_TIME_COL)\n\n    for tsd_x, tsd_y in TSD_CORRELATION_PAIRS:\n\n        tsd_pr, tsd_pp, tsd_n1 = tsd_safe_corr(\n            tsd_group[tsd_x],\n            tsd_group[tsd_y],\n            \"pearson\"\n        )\n\n        tsd_sr, tsd_sp, tsd_n2 = tsd_safe_corr(\n            tsd_group[tsd_x],\n            tsd_group[tsd_y],\n            \"spearman\"\n        )\n\n        tsd_within_corr_rows.append({\n            \"J\": float(tsd_J),\n            \"gamma_phi\": float(tsd_gamma),\n            \"x\": tsd_x,\n            \"y\": tsd_y,\n            \"pair\": f\"{tsd_x}_vs_{tsd_y}\",\n            \"n\": int(max(tsd_n1, tsd_n2)),\n            \"pearson_r\": tsd_pr,\n            \"pearson_p\": tsd_pp,\n            \"pearson_strength\": tsd_strength_from_r(tsd_pr),\n            \"spearman_r\": tsd_sr,\n            \"spearman_p\": tsd_sp,\n            \"spearman_strength\": tsd_strength_from_r(tsd_sr),\n        })\n\ntsd_within_corr_df = tsd_pd.DataFrame(\n    tsd_within_corr_rows\n)\n\ntsd_within_corr_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"within_run_correlations.csv\"\n)\n\ntsd_within_corr_df.to_csv(\n    tsd_within_corr_path,\n    index=False\n)\n\n\n# ============================================================\n# 8. Figures\n# ============================================================\n\ntsd_fig_dir = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"figures\"\n)\n\ntsd_ensure_dir(tsd_fig_dir)\n\n\ndef tsd_save_heatmap(\n    tsd_summary_df,\n    tsd_metric,\n    tsd_out_path,\n):\n\n    tsd_pivot = tsd_summary_df.pivot(\n        index=\"gamma_phi\",\n        columns=\"J\",\n        values=tsd_metric,\n    )\n\n    tsd_plt.figure(figsize=(9, 5.5))\n\n    if TSD_HAS_SEABORN:\n\n        tsd_sns.heatmap(\n            tsd_pivot,\n            annot=True,\n            fmt=\".3g\",\n            cmap=\"viridis\",\n        )\n\n    else:\n\n        tsd_plt.imshow(\n            tsd_pivot.values,\n            aspect=\"auto\",\n            origin=\"lower\",\n        )\n\n        tsd_plt.colorbar(label=tsd_metric)\n\n    tsd_plt.title(tsd_metric)\n\n    tsd_plt.xlabel(\"J\")\n    tsd_plt.ylabel(\"gamma_phi\")\n\n    tsd_plt.tight_layout()\n\n    tsd_plt.savefig(tsd_out_path, dpi=220)\n\n    tsd_plt.close()\n\n\nfor tsd_metric in TSD_HEATMAP_METRICS:\n\n    if tsd_metric in tsd_run_summary_df.columns:\n\n        tsd_save_heatmap(\n            tsd_run_summary_df,\n            tsd_metric,\n            tsd_os.path.join(\n                tsd_fig_dir,\n                f\"heatmap_{tsd_metric}.png\"\n            ),\n        )\n\n\n# ============================================================\n# 9. Excel workbook\n# ============================================================\n\ntsd_excel_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"time_series_summary_workbook.xlsx\"\n)\n\ntry:\n\n    with tsd_pd.ExcelWriter(\n        tsd_excel_path,\n        engine=\"openpyxl\"\n    ) as tsd_writer:\n\n        tsd_qc_df.to_excel(\n            tsd_writer,\n            index=False,\n            sheet_name=\"quality_control\",\n        )\n\n        tsd_param_grid_df.to_excel(\n            tsd_writer,\n            index=False,\n            sheet_name=\"parameter_grid\",\n        )\n\n        tsd_run_summary_df.to_excel(\n            tsd_writer,\n            index=False,\n            sheet_name=\"run_summary\",\n        )\n\n        tsd_within_corr_df.to_excel(\n            tsd_writer,\n            index=False,\n            sheet_name=\"within_correlations\",\n        )\n\nexcept Exception as tsd_excel_error:\n\n    print(\n        f\"Excel workbook creation failed: \"\n        f\"{tsd_excel_error}\"\n    )\n\n\n# ============================================================\n# 10. Metadata\n# ============================================================\n\ntsd_metadata = {\n    \"project\": TSD_PROJECT_NAME,\n    \"input_file\": tsd_input_file,\n    \"output_dir\": TSD_OUTPUT_DIR,\n    \"n_rows\": int(len(tsd_df)),\n    \"n_columns_processed\": int(tsd_df.shape[1]),\n    \"n_parameter_runs\": int(\n        tsd_df[TSD_PARAM_COLS]\n        .drop_duplicates()\n        .shape[0]\n    ),\n    \"time_min\": float(tsd_df[TSD_TIME_COL].min()),\n    \"time_max\": float(tsd_df[TSD_TIME_COL].max()),\n    \"random_seed\": TSD_RANDOM_SEED,\n    \"has_scipy\": bool(TSD_HAS_SCIPY),\n    \"has_seaborn\": bool(TSD_HAS_SEABORN),\n}\n\ntsd_metadata_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"summary_metadata.json\"\n)\n\nwith open(\n    tsd_metadata_path,\n    \"w\",\n    encoding=\"utf-8\"\n) as tsd_f:\n\n    tsd_json.dump(\n        tsd_metadata,\n        tsd_f,\n        indent=2,\n        ensure_ascii=False,\n    )\n\n\n# ============================================================\n# 11. Output manifest\n# ============================================================\n\ntsd_output_manifest = []\n\nfor tsd_root, tsd_dirs, tsd_files in tsd_os.walk(TSD_OUTPUT_DIR):\n\n    for tsd_name in tsd_files:\n\n        tsd_path = tsd_os.path.join(\n            tsd_root,\n            tsd_name,\n        )\n\n        tsd_output_manifest.append({\n            \"file\": tsd_os.path.relpath(\n                tsd_path,\n                TSD_OUTPUT_DIR,\n            ),\n            \"absolute_path\": tsd_path,\n            \"size_bytes\": int(\n                tsd_os.path.getsize(tsd_path)\n            ),\n        })\n\ntsd_manifest_df = tsd_pd.DataFrame(\n    tsd_output_manifest\n).sort_values(\"file\")\n\ntsd_manifest_path = tsd_os.path.join(\n    TSD_OUTPUT_DIR,\n    \"output_manifest.csv\"\n)\n\ntsd_manifest_df.to_csv(\n    tsd_manifest_path,\n    index=False\n)\n\n\n# ============================================================\n# 12. Final console output\n# ============================================================\n\nprint(\"=\" * 80)\nprint(\"TSD summary pipeline completed successfully.\")\nprint(f\"Input file: {tsd_input_file}\")\nprint(f\"Output directory: {TSD_OUTPUT_DIR}\")\nprint(\"=\" * 80)\n\nprint(tsd_manifest_df.to_string(index=False))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-19T09:14:39.282078Z","iopub.execute_input":"2026-05-19T09:14:39.282972Z","iopub.status.idle":"2026-05-19T09:14:49.396148Z","shell.execute_reply.started":"2026-05-19T09:14:39.282912Z","shell.execute_reply":"2026-05-19T09:14:49.395237Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# ZIP ONLY NEWLY GENERATED OUTPUT FILES\n# Kaggle-safe\n# =============================================