{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.6.6","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ============================================================\n# Stochastic Simulation of Cancer Therapy Resistance\n# Based on Biophysical Thermodynamics\n# ------------------------------------------------------------\n# One-run, self-contained Kaggle-ready Python code\n# No external input files required\n# Outputs: compact summary tables + high-resolution figures\n# ============================================================\n\nimport os\nimport math\nimport json\nimport warnings\nfrom dataclasses import dataclass, asdict\nfrom typing import Dict, List, Tuple\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\nwarnings.filterwarnings(\"ignore\")\n\n# ============================================================\n# 1. Global configuration\n# ============================================================\n\nRANDOM_SEED = 20260701\nrng = np.random.default_rng(RANDOM_SEED)\n\nOUTPUT_DIR = \"/kaggle/working/biophysical_thermodynamic_resistance_outputs\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n# Required publication-ready style\nplt.rcParams.update({\n    \"font.size\": 14,\n    \"axes.labelsize\": 16,\n    \"axes.titlesize\": 18,\n    \"xtick.labelsize\": 12,\n    \"ytick.labelsize\": 12,\n    \"figure.titlesize\": 20,\n    \"figure.dpi\": 300,\n    \"savefig.dpi\": 300,\n    \"axes.linewidth\": 1.4,\n    \"lines.linewidth\": 2.5,\n    \"lines.markersize\": 7,\n    \"legend.fontsize\": 12,\n    \"legend.title_fontsize\": 13,\n    \"pdf.fonttype\": 42,\n    \"ps.fonttype\": 42,\n})\n\nsns.set_theme(style=\"whitegrid\", context=\"talk\")\n\n# ============================================================\n# 2. Model definitions\n# ============================================================\n\n@dataclass(frozen=True)\nclass SimulationConfig:\n    n_steps: int = 260\n    dt: float = 1.0\n    n_replicates: int = 160\n\n    initial_sensitive: int = 250000\n    initial_resistant_total: int = 0\n\n    carrying_capacity: int = 2000000\n\n    base_sensitive_growth: float = 0.030\n    base_resistant_growth: float = 0.026\n    base_death: float = 0.010\n\n    baseline_mutation_rate: float = 1.2e-5\n    mutagenic_multiplier: float = 8.0\n\n    normal_to_mutagenic_base: float = 0.002\n    mutagenic_to_normal_base: float = 0.070\n\n    drug_kill_sensitive: float = 0.060\n    drug_kill_mutagenic: float = 0.035\n    drug_kill_resistant: float = 0.010\n\n    t_eff_baseline: float = 1.0\n    t_eff_dose_coeff: float = 1.05\n    t_eff_replication_coeff: float = 0.85\n    t_eff_oxidative_coeff: float = 0.70\n    t_eff_noise_floor: float = 0.05\n\n    entropy_epsilon: float = 1e-12\n\n    specific_variant_name: str = \"APOBEC_like_specific_resistance\"\n    fixation_fraction_threshold: float = 0.60\n\n@dataclass(frozen=True)\nclass DoseScenario:\n    scenario_name: str\n    dose: float\n    schedule_type: str\n\nCONFIG = SimulationConfig()\n\n# Dose scenarios: low, medium, high continuous therapy\nDOSE_SCENARIOS = [\n    DoseScenario(\"low_continuous_dose\", 0.25, \"continuous\"),\n    DoseScenario(\"medium_continuous_dose\", 0.55, \"continuous\"),\n    DoseScenario(\"high_continuous_dose\", 0.90, \"continuous\"),\n    DoseScenario(\"pulsed_high_dose\", 0.90, \"pulsed\"),\n]\n\n# Mutation channels\n# A = neutral/random-like\n# B = APOBEC-like specific resistant variant\n# C = DSB/SV-like resistant variant\n# D = other resistant route\nMUTATION_CHANNELS = [\n    \"neutral_random_like\",\n    \"APOBEC_like_specific_resistance\",\n    \"DSB_SV_like_resistance\",\n    \"other_resistance_route\",\n]\n\nCHANNEL_BASE_FREE_ENERGY = {\n    \"neutral_random_like\": 0.00,\n    \"APOBEC_like_specific_resistance\": 1.15,\n    \"DSB_SV_like_resistance\": 1.45,\n    \"other_resistance_route\": 1.25,\n}\n\nCHANNEL_STRESS_COUPLING = {\n    \"neutral_random_like\": 0.10,\n    \"APOBEC_like_specific_resistance\": 1.35,\n    \"DSB_SV_like_resistance\": 0.95,\n    \"other_resistance_route\": 0.55,\n}\n\nCHANNEL_RESISTANCE_GROWTH_MODIFIER = {\n    \"neutral_random_like\": 0.000,\n    \"APOBEC_like_specific_resistance\": 0.008,\n    \"DSB_SV_like_resistance\": 0.005,\n    \"other_resistance_route\": 0.004,\n}","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 3. Self-contained input generator\n# ============================================================\n\ndef generate_self_contained_inputs(config: SimulationConfig) -> Dict:\n    \"\"\"\n    Generates all synthetic initial conditions and scenarios internally.\n    No external files are required.\n    \"\"\"\n    initial_population = {\n        \"sensitive_normal_fidelity\": config.initial_sensitive,\n        \"sensitive_mutagenic_repair\": 0,\n        \"neutral_random_like\": 0,\n        \"APOBEC_like_specific_resistance\": 0,\n        \"DSB_SV_like_resistance\": 0,\n        \"other_resistance_route\": 0,\n    }\n\n    scenarios = [asdict(s) for s in DOSE_SCENARIOS]\n\n    model_metadata = {\n        \"study_title\": \"Stochastic Simulation of Cancer Therapy Resistance Based on Biophysical Thermodynamics\",\n        \"core_mechanism\": (\n            \"Dose increases replication and oxidative stress; stress raises effective evolutionary temperature; \"\n            \"temperature and stress reshape the free-energy landscape of mutation channels; \"\n            \"reshaped channel probabilities bias resistant variant emergence.\"\n        ),\n        \"random_seed\": RANDOM_SEED,\n        \"config\": asdict(config),\n        \"mutation_channels\": MUTATION_CHANNELS,\n        \"channel_base_free_energy\": CHANNEL_BASE_FREE_ENERGY,\n        \"channel_stress_coupling\": CHANNEL_STRESS_COUPLING,\n    }\n\n    return {\n        \"initial_population\": initial_population,\n        \"scenarios\": scenarios,\n        \"metadata\": model_metadata,\n    }\n\n# ============================================================\n# 4. Biophysical thermodynamic functions\n# ============================================================\n\ndef schedule_dose(scenario: DoseScenario, step: int) -> float:\n    \"\"\"\n    Continuous and pulsed dose schedules.\n    Pulsed high dose: 14 days on, 14 days off.\n    \"\"\"\n    if scenario.schedule_type == \"continuous\":\n        return scenario.dose\n    if scenario.schedule_type == \"pulsed\":\n        cycle = 28\n        return scenario.dose if (step % cycle) < 14 else 0.0\n    raise ValueError(f\"Unknown schedule type: {scenario.schedule_type}\")\n\ndef compute_stress_variables(dose: float, total_cells: int, config: SimulationConfig) -> Tuple[float, float]:\n    \"\"\"\n    Replication stress and oxidative stress are synthetic mechanistic variables.\n    They increase with dose and crowding pressure.\n    \"\"\"\n    crowding_pressure = min(total_cells / max(config.carrying_capacity, 1), 1.5)\n    replication_stress = np.clip(0.15 + 0.85 * dose + 0.25 * crowding_pressure, 0.0, 2.0)\n    oxidative_stress = np.clip(0.10 + 0.75 * dose + 0.15 * crowding_pressure, 0.0, 2.0)\n    return replication_stress, oxidative_stress\n\ndef compute_effective_evolutionary_temperature(\n    dose: float,\n    replication_stress: float,\n    oxidative_stress: float,\n    config: SimulationConfig\n) -> float:\n    \"\"\"\n    Effective evolutionary temperature proxy.\n    Higher dose and stress increase stochasticity of evolutionary search.\n    \"\"\"\n    t_eff = (\n        config.t_eff_baseline\n        + config.t_eff_dose_coeff * dose\n        + config.t_eff_replication_coeff * replication_stress\n        + config.t_eff_oxidative_coeff * oxidative_stress\n        + config.t_eff_noise_floor\n    )\n    return max(t_eff, 0.05)\n\ndef free_energy_landscape(\n    dose: float,\n    replication_stress: float,\n    oxidative_stress: float\n) -> Dict[str, float]:\n    \"\"\"\n    Dose/stress-dependent free-energy landscape deformation.\n    Lower effective free energy gives higher channel probability.\n    APOBEC-like channel is deliberately stress-coupled to represent\n    specific variant channeling beyond random noise.\n    \"\"\"\n    composite_stress = 0.65 * replication_stress + 0.35 * oxidative_stress\n\n    energies = {}\n    for channel in MUTATION_CHANNELS:\n        base_energy = CHANNEL_BASE_FREE_ENERGY[channel]\n        stress_coupling = CHANNEL_STRESS_COUPLING[channel]\n        nonlinear_channeling = 0.0\n\n        if channel == \"APOBEC_like_specific_resistance\":\n            nonlinear_channeling = 0.75 * (dose ** 2) + 0.45 * max(replication_stress - 0.8, 0.0) ** 2\n        elif channel == \"DSB_SV_like_resistance\":\n            nonlinear_channeling = 0.35 * (oxidative_stress ** 2)\n\n        energies[channel] = base_energy - stress_coupling * composite_stress - nonlinear_channeling\n\n    return energies\n\ndef softmax_channel_probabilities(\n    energies: Dict[str, float],\n    t_eff: float,\n    config: SimulationConfig\n) -> Dict[str, float]:\n    \"\"\"\n    Boltzmann-like mapping:\n    p(path_i) ∝ exp(-F_i / T_eff)\n    T_eff controls stochastic exploration; free-energy deformation controls channeling.\n    \"\"\"\n    energy_array = np.array([energies[ch] for ch in MUTATION_CHANNELS], dtype=float)\n    logits = -energy_array / max(t_eff, config.entropy_epsilon)\n    logits = logits - logits.max()\n    weights = np.exp(logits)\n    probs = weights / weights.sum()\n    return {ch: float(p) for ch, p in zip(MUTATION_CHANNELS, probs)}\n\ndef shannon_entropy(probabilities: Dict[str, float], config: SimulationConfig) -> float:\n    \"\"\"\n    Shannon path entropy over mutation channels.\n    H = -sum p_i log(p_i)\n    \"\"\"\n    p = np.array(list(probabilities.values()), dtype=float)\n    p = np.clip(p, config.entropy_epsilon, 1.0)\n    return float(-np.sum(p * np.log(p)))\n\ndef normalized_entropy(probabilities: Dict[str, float], config: SimulationConfig) -> float:\n    return shannon_entropy(probabilities, config) / np.log(len(probabilities))\n\ndef channeling_index(probabilities: Dict[str, float], specific_channel: str) -> float:\n    \"\"\"\n    Channeling Index:\n    specific channel probability / uniform expectation.\n    If >1, the specific resistant pathway is enriched beyond random uniform channel use.\n    \"\"\"\n    uniform_prob = 1.0 / len(probabilities)\n    return probabilities[specific_channel] / uniform_prob","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 5. Memory-efficient stochastic simulation\n# ============================================================\n\ndef simulate_one_replicate(\n    scenario: DoseScenario,\n    config: SimulationConfig,\n    replicate_seed: int\n) -> Tuple[pd.DataFrame, Dict]:\n    \"\"\"\n    Aggregated stochastic simulation.\n    No individual-cell data are stored.\n    Only compact time-step summaries are retained.\n    \"\"\"\n    local_rng = np.random.default_rng(replicate_seed)\n\n    sensitive_normal = int(config.initial_sensitive)\n    sensitive_mutagenic = 0\n\n    resistant_counts = {ch: 0 for ch in MUTATION_CHANNELS}\n\n    timeline_records = []\n\n    cumulative_specific_variants = 0\n    cumulative_all_variants = 0\n    cumulative_path_entropy = 0.0\n    cumulative_t_eff = 0.0\n\n    time_to_first_specific = np.nan\n    time_to_resistant_fixation = np.nan\n\n    for step in range(config.n_steps):\n        dose = schedule_dose(scenario, step)\n\n        total_resistant = int(sum(resistant_counts.values()))\n        total_sensitive = int(sensitive_normal + sensitive_mutagenic)\n        total_cells = int(total_sensitive + total_resistant)\n\n        if total_cells <= 0:\n            replication_stress = 0.0\n            oxidative_stress = 0.0\n            t_eff = config.t_eff_baseline\n            energies = free_energy_landscape(dose, replication_stress, oxidative_stress)\n            channel_probs = softmax_channel_probabilities(energies, t_eff, config)\n            path_h = shannon_entropy(channel_probs, config)\n            path_h_norm = normalized_entropy(channel_probs, config)\n            channel_idx = channeling_index(channel_probs, config.specific_variant_name)\n\n            timeline_records.append({\n                \"step\": step,\n                \"time\": step * config.dt,\n                \"scenario\": scenario.scenario_name,\n                \"dose\": dose,\n                \"total_cells\": 0,\n                \"sensitive_normal\": 0,\n                \"sensitive_mutagenic\": 0,\n                \"total_sensitive\": 0,\n                \"total_resistant\": 0,\n                \"specific_resistant_count\": 0,\n                \"specific_resistant_fraction\": 0.0,\n                \"replication_stress\": replication_stress,\n                \"oxidative_stress\": oxidative_stress,\n                \"T_eff\": t_eff,\n                \"path_entropy\": path_h,\n                \"normalized_path_entropy\": path_h_norm,\n                \"channeling_index\": channel_idx,\n                \"specific_channel_probability\": channel_probs[config.specific_variant_name],\n                \"cumulative_specific_variants\": cumulative_specific_variants,\n                \"cumulative_all_variants\": cumulative_all_variants,\n            })\n            continue\n\n        replication_stress, oxidative_stress = compute_stress_variables(dose, total_cells, config)\n        t_eff = compute_effective_evolutionary_temperature(dose, replication_stress, oxidative_stress, config)\n        energies = free_energy_landscape(dose, replication_stress, oxidative_stress)\n        channel_probs = softmax_channel_probabilities(energies, t_eff, config)\n\n        path_h = shannon_entropy(channel_probs, config)\n        path_h_norm = normalized_entropy(channel_probs, config)\n        channel_idx = channeling_index(channel_probs, config.specific_variant_name)\n\n        crowding_factor = max(0.0, 1.0 - total_cells / config.carrying_capacity)\n\n        # State transition: normal fidelity -> mutagenic repair\n        p_to_mutagenic = np.clip(\n            config.normal_to_mutagenic_base\n            * (1.0 + 1.35 * dose + 0.85 * replication_stress + 0.55 * oxidative_stress),\n            0.0,\n            0.30\n        )\n\n        # Recovery: mutagenic repair -> normal fidelity\n        p_to_normal = np.clip(\n            config.mutagenic_to_normal_base / (1.0 + 0.75 * dose + 0.45 * replication_stress),\n            0.0,\n            0.25\n        )\n\n        new_mutagenic = local_rng.binomial(sensitive_normal, p_to_mutagenic) if sensitive_normal > 0 else 0\n        recovered_normal = local_rng.binomial(sensitive_mutagenic, p_to_normal) if sensitive_mutagenic > 0 else 0\n\n        sensitive_normal = sensitive_normal - new_mutagenic + recovered_normal\n        sensitive_mutagenic = sensitive_mutagenic + new_mutagenic - recovered_normal\n\n        # Growth and death: aggregated binomial/Poisson updates\n        p_birth_sensitive_normal = np.clip(config.base_sensitive_growth * crowding_factor, 0.0, 0.50)\n        p_birth_sensitive_mutagenic = np.clip(config.base_sensitive_growth * 0.82 * crowding_factor, 0.0, 0.50)\n\n        births_normal = local_rng.binomial(sensitive_normal, p_birth_sensitive_normal) if sensitive_normal > 0 else 0\n        births_mutagenic = local_rng.binomial(sensitive_mutagenic, p_birth_sensitive_mutagenic) if sensitive_mutagenic > 0 else 0\n\n        p_death_normal = np.clip(config.base_death + config.drug_kill_sensitive * dose, 0.0, 0.90)\n        p_death_mutagenic = np.clip(config.base_death + config.drug_kill_mutagenic * dose + 0.004 * oxidative_stress, 0.0, 0.90)\n\n        deaths_normal = local_rng.binomial(sensitive_normal, p_death_normal) if sensitive_normal > 0 else 0\n        deaths_mutagenic = local_rng.binomial(sensitive_mutagenic, p_death_mutagenic) if sensitive_mutagenic > 0 else 0\n\n        sensitive_normal = max(0, sensitive_normal + births_normal - deaths_normal)\n        sensitive_mutagenic = max(0, sensitive_mutagenic + births_mutagenic - deaths_mutagenic)\n\n        # Stress-dependent mutation rate\n        effective_mutation_rate_normal = config.baseline_mutation_rate * (1.0 + 0.30 * (t_eff - config.t_eff_baseline))\n        effective_mutation_rate_mutagenic = (\n            config.baseline_mutation_rate\n            * config.mutagenic_multiplier\n            * (1.0 + 0.65 * (t_eff - config.t_eff_baseline))\n        )\n\n        effective_mutation_rate_normal = np.clip(effective_mutation_rate_normal, 0.0, 0.05)\n        effective_mutation_rate_mutagenic = np.clip(effective_mutation_rate_mutagenic, 0.0, 0.15)\n\n        mutation_trials_normal = max(0, births_normal)\n        mutation_trials_mutagenic = max(0, births_mutagenic)\n\n        n_mutations_normal = local_rng.binomial(mutation_trials_normal, effective_mutation_rate_normal) if mutation_trials_normal > 0 else 0\n        n_mutations_mutagenic = local_rng.binomial(mutation_trials_mutagenic, effective_mutation_rate_mutagenic) if mutation_trials_mutagenic > 0 else 0\n        n_new_mutations = int(n_mutations_normal + n_mutations_mutagenic)\n\n        if n_new_mutations > 0:\n            probs_array = np.array([channel_probs[ch] for ch in MUTATION_CHANNELS])\n            new_channel_counts = local_rng.multinomial(n_new_mutations, probs_array)\n\n            for channel, count in zip(MUTATION_CHANNELS, new_channel_counts):\n                resistant_counts[channel] += int(count)\n\n            specific_new = int(new_channel_counts[MUTATION_CHANNELS.index(config.specific_variant_name)])\n            cumulative_specific_variants += specific_new\n            cumulative_all_variants += n_new_mutations\n\n            if specific_new > 0 and np.isnan(time_to_first_specific):\n                time_to_first_specific = step * config.dt\n\n            # Mutated cells are removed from sensitive compartments in aggregate\n            remove_from_mutagenic = min(sensitive_mutagenic, n_mutations_mutagenic)\n            sensitive_mutagenic -= remove_from_mutagenic\n            remove_from_normal = min(sensitive_normal, n_new_mutations - remove_from_mutagenic)\n            sensitive_normal -= remove_from_normal\n\n        # Resistant clone growth/death by channel\n        for channel in MUTATION_CHANNELS:\n            count = resistant_counts[channel]\n            if count <= 0:\n                continue\n\n            channel_growth = (\n                config.base_resistant_growth\n                + CHANNEL_RESISTANCE_GROWTH_MODIFIER[channel]\n            ) * crowding_factor\n\n            p_birth_resistant = np.clip(channel_growth, 0.0, 0.50)\n            p_death_resistant = np.clip(config.base_death + config.drug_kill_resistant * dose, 0.0, 0.80)\n\n            births_resistant = local_rng.binomial(count, p_birth_resistant)\n            deaths_resistant = local_rng.binomial(count, p_death_resistant)\n            resistant_counts[channel] = max(0, count + births_resistant - deaths_resistant)\n\n        total_resistant = int(sum(resistant_counts.values()))\n        total_sensitive = int(sensitive_normal + sensitive_mutagenic)\n        total_cells = int(total_sensitive + total_resistant)\n\n        specific_count = int(resistant_counts[config.specific_variant_name])\n        specific_resistant_fraction = specific_count / max(total_resistant, 1)\n\n        if (\n            np.isnan(time_to_resistant_fixation)\n            and total_resistant > 0\n            and specific_resistant_fraction >= config.fixation_fraction_threshold\n            and specific_count >= 50\n        ):\n            time_to_resistant_fixation = step * config.dt\n\n        cumulative_path_entropy += path_h\n        cumulative_t_eff += t_eff\n\n        timeline_records.append({\n            \"step\": step,\n            \"time\": step * config.dt,\n            \"scenario\": scenario.scenario_name,\n            \"dose\": dose,\n            \"total_cells\": total_cells,\n            \"sensitive_normal\": sensitive_normal,\n            \"sensitive_mutagenic\": sensitive_mutagenic,\n            \"total_sensitive\": total_sensitive,\n            \"total_resistant\": total_resistant,\n            \"specific_resistant_count\": specific_count,\n            \"specific_resistant_fraction\": specific_resistant_fraction,\n            \"replication_stress\": replication_stress,\n            \"oxidative_stress\": oxidative_stress,\n            \"T_eff\": t_eff,\n            \"path_entropy\": path_h,\n            \"normalized_path_entropy\": path_h_norm,\n            \"channeling_index\": channel_idx,\n            \"specific_channel_probability\": channel_probs[config.specific_variant_name],\n            \"cumulative_specific_variants\": cumulative_specific_variants,\n            \"cumulative_all_variants\": cumulative_all_variants,\n        })\n\n    timeline_df = pd.DataFrame(timeline_records)\n\n    final_row = timeline_df.iloc[-1].to_dict()\n    summary = {\n        \"scenario\": scenario.scenario_name,\n        \"nominal_dose\": scenario.dose,\n        \"schedule_type\": scenario.schedule_type,\n        \"final_surviving_cells\": int(final_row[\"total_cells\"]),\n        \"final_sensitive_cells\": int(final_row[\"total_sensitive\"]),\n        \"final_resistant_cells\": int(final_row[\"total_resistant\"]),\n        \"final_specific_resistant_count\": int(final_row[\"specific_resistant_count\"]),\n        \"final_specific_resistant_fraction_among_resistant\": float(final_row[\"specific_resistant_fraction\"]),\n        \"final_T_eff\": float(final_row[\"T_eff\"]),\n        \"mean_T_eff\": float(timeline_df[\"T_eff\"].mean()),\n        \"final_path_entropy\": float(final_row[\"path_entropy\"]),\n        \"mean_path_entropy\": float(timeline_df[\"path_entropy\"].mean()),\n        \"mean_normalized_path_entropy\": float(timeline_df[\"normalized_path_entropy\"].mean()),\n        \"final_channeling_index\": float(final_row[\"channeling_index\"]),\n        \"mean_channeling_index\": float(timeline_df[\"channeling_index\"].mean()),\n        \"final_specific_channel_probability\": float(final_row[\"specific_channel_probability\"]),\n        \"cumulative_specific_variants\": int(final_row[\"cumulative_specific_variants\"]),\n        \"cumulative_all_variants\": int(final_row[\"cumulative_all_variants\"]),\n        \"observed_specific_variant_share\": (\n            float(final_row[\"cumulative_specific_variants\"] / max(final_row[\"cumulative_all_variants\"], 1))\n        ),\n        \"time_to_first_specific_variant\": time_to_first_specific,\n        \"time_to_specific_resistant_fixation\": time_to_resistant_fixation,\n    }\n\n    return timeline_df, summary\n\ndef run_full_experiment(config: SimulationConfig) -> Tuple[pd.DataFrame, pd.DataFrame]:\n    \"\"\"\n    Runs all dose scenarios and replicates.\n    Stores compact time-average summaries and representative averaged timelines.\n    \"\"\"\n    all_summaries = []\n    timeline_accumulators = []\n\n    run_counter = 0\n\n    for scenario in DOSE_SCENARIOS:\n        scenario_timelines = []\n\n        for rep in range(config.n_replicates):\n            run_counter += 1\n            seed = RANDOM_SEED + run_counter * 101\n            timeline_df, summary = simulate_one_replicate(scenario, config, seed)\n\n            summary[\"replicate\"] = rep\n            summary[\"seed\"] = seed\n            all_summaries.append(summary)\n\n            # Store aggregated timeline only; no cell-level raw data.\n            reduced_timeline = timeline_df[\n                [\n                    \"time\",\n                    \"scenario\",\n                    \"dose\",\n                    \"total_cells\",\n                    \"total_sensitive\",\n                    \"total_resistant\",\n                    \"specific_resistant_count\",\n                    \"specific_resistant_fraction\",\n                    \"replication_stress\",\n                    \"oxidative_stress\",\n                    \"T_eff\",\n                    \"path_entropy\",\n                    \"normalized_path_entropy\",\n                    \"channeling_index\",\n                    \"specific_channel_probability\",\n                    \"cumulative_specific_variants\",\n                    \"cumulative_all_variants\",\n                ]\n            ].copy()\n            reduced_timeline[\"replicate\"] = rep\n            scenario_timelines.append(reduced_timeline)\n\n        scenario_timeline_df = pd.concat(scenario_timelines, ignore_index=True)\n\n        aggregated_timeline = (\n            scenario_timeline_df\n            .groupby([\"scenario\", \"time\"], as_index=False)\n            .agg(\n                mean_dose=(\"dose\", \"mean\"),\n                median_total_cells=(\"total_cells\", \"median\"),\n                mean_total_cells=(\"total_cells\", \"mean\"),\n                median_total_resistant=(\"total_resistant\", \"median\"),\n                mean_total_resistant=(\"total_resistant\", \"mean\"),\n                median_specific_resistant_count=(\"specific_resistant_count\", \"median\"),\n                mean_specific_resistant_count=(\"specific_resistant_count\", \"mean\"),\n                mean_specific_resistant_fraction=(\"specific_resistant_fraction\", \"mean\"),\n                mean_replication_stress=(\"repl