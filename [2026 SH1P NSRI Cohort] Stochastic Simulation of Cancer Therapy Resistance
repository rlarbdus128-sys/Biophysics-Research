# 5. Memory-efficient stochastic simulation
# ============================================================

def simulate_one_replicate(
    scenario: DoseScenario,
    config: SimulationConfig,
    replicate_seed: int
) -> Tuple[pd.DataFrame, Dict]:
    """
    Aggregated stochastic simulation.
    No individual-cell data are stored.
    Only compact time-step summaries are retained.
    """
    local_rng = np.random.default_rng(replicate_seed)

    sensitive_normal = int(config.initial_sensitive)
    sensitive_mutagenic = 0

    resistant_counts = {ch: 0 for ch in MUTATION_CHANNELS}

    timeline_records = []

    cumulative_specific_variants = 0
    cumulative_all_variants = 0
    cumulative_path_entropy = 0.0
    cumulative_t_eff = 0.0

    time_to_first_specific = np.nan
    time_to_resistant_fixation = np.nan

    for step in range(config.n_steps):
        dose = schedule_dose(scenario, step)

        total_resistant = int(sum(resistant_counts.values()))
        total_sensitive = int(sensitive_normal + sensitive_mutagenic)
        total_cells = int(total_sensitive + total_resistant)

        if total_cells <= 0:
            replication_stress = 0.0
            oxidative_stress = 0.0
            t_eff = config.t_eff_baseline
            energies = free_energy_landscape(dose, replication_stress, oxidative_stress)
            channel_probs = softmax_channel_probabilities(energies, t_eff, config)
            path_h = shannon_entropy(channel_probs, config)
            path_h_norm = normalized_entropy(channel_probs, config)
            channel_idx = channeling_index(channel_probs, config.specific_variant_name)

            timeline_records.append({
                "step": step,
                "time": step * config.dt,
                "scenario": scenario.scenario_name,
                "dose": dose,
                "total_cells": 0,
                "sensitive_normal": 0,
                "sensitive_mutagenic": 0,
                "total_sensitive": 0,
                "total_resistant": 0,
                "specific_resistant_count": 0,
                "specific_resistant_fraction": 0.0,
                "replication_stress": replication_stress,
                "oxidative_stress": oxidative_stress,
                "T_eff": t_eff,
                "path_entropy": path_h,
                "normalized_path_entropy": path_h_norm,
                "channeling_index": channel_idx,
                "specific_channel_probability": channel_probs[config.specific_variant_name],
                "cumulative_specific_variants": cumulative_specific_variants,
                "cumulative_all_variants": cumulative_all_variants,
            })
            continue

        replication_stress, oxidative_stress = compute_stress_variables(dose, total_cells, config)
        t_eff = compute_effective_evolutionary_temperature(dose, replication_stress, oxidative_stress, config)
        energies = free_energy_landscape(dose, replication_stress, oxidative_stress)
        channel_probs = softmax_channel_probabilities(energies, t_eff, config)

        path_h = shannon_entropy(channel_probs, config)
        path_h_norm = normalized_entropy(channel_probs, config)
        channel_idx = channeling_index(channel_probs, config.specific_variant_name)

        crowding_factor = max(0.0, 1.0 - total_cells / config.carrying_capacity)

        # State transition: normal fidelity -> mutagenic repair
        p_to_mutagenic = np.clip(
            config.normal_to_mutagenic_base
            * (1.0 + 1.35 * dose + 0.85 * replication_stress + 0.55 * oxidative_stress),
            0.0,
            0.30
        )

        # Recovery: mutagenic repair -> normal fidelity
        p_to_normal = np.clip(
            config.mutagenic_to_normal_base / (1.0 + 0.75 * dose + 0.45 * replication_stress),
            0.0,
            0.25
        )

        new_mutagenic = local_rng.binomial(sensitive_normal, p_to_mutagenic) if sensitive_normal > 0 else 0
        recovered_normal = local_rng.binomial(sensitive_mutagenic, p_to_normal) if sensitive_mutagenic > 0 else 0

        sensitive_normal = sensitive_normal - new_mutagenic + recovered_normal
        sensitive_mutagenic = sensitive_mutagenic + new_mutagenic - recovered_normal

        # Growth and death: aggregated binomial/Poisson updates
        p_birth_sensitive_normal = np.clip(config.base_sensitive_growth * crowding_factor, 0.0, 0.50)
        p_birth_sensitive_mutagenic = np.clip(config.base_sensitive_growth * 0.82 * crowding_factor, 0.0, 0.50)

        births_normal = local_rng.binomial(sensitive_normal, p_birth_sensitive_normal) if sensitive_normal > 0 else 0
        births_mutagenic = local_rng.binomial(sensitive_mutagenic, p_birth_sensitive_mutagenic) if sensitive_mutagenic > 0 else 0

        p_death_normal = np.clip(config.base_death + config.drug_kill_sensitive * dose, 0.0, 0.90)
        p_death_mutagenic = np.clip(config.base_death + config.drug_kill_mutagenic * dose + 0.004 * oxidative_stress, 0.0, 0.90)

        deaths_normal = local_rng.binomial(sensitive_normal, p_death_normal) if sensitive_normal > 0 else 0
        deaths_mutagenic = local_rng.binomial(sensitive_mutagenic, p_death_mutagenic) if sensitive_mutagenic > 0 else 0

        sensitive_normal = max(0, sensitive_normal + births_normal - deaths_normal)
        sensitive_mutagenic = max(0, sensitive_mutagenic + births_mutagenic - deaths_mutagenic)

        # Stress-dependent mutation rate
        effective_mutation_rate_normal = config.baseline_mutation_rate * (1.0 + 0.30 * (t_eff - config.t_eff_baseline))
        effective_mutation_rate_mutagenic = (
            config.baseline_mutation_rate
            * config.mutagenic_multiplier
            * (1.0 + 0.65 * (t_eff - config.t_eff_baseline))
        )

        effective_mutation_rate_normal = np.clip(effective_mutation_rate_normal, 0.0, 0.05)
        effective_mutation_rate_mutagenic = np.clip(effective_mutation_rate_mutagenic, 0.0, 0.15)

        mutation_trials_normal = max(0, births_normal)
        mutation_trials_mutagenic = max(0, births_mutagenic)

        n_mutations_normal = local_rng.binomial(mutation_trials_normal, effective_mutation_rate_normal) if mutation_trials_normal > 0 else 0
        n_mutations_mutagenic = local_rng.binomial(mutation_trials_mutagenic, effective_mutation_rate_mutagenic) if mutation_trials_mutagenic > 0 else 0
        n_new_mutations = int(n_mutations_normal + n_mutations_mutagenic)

        if n_new_mutations > 0:
            probs_array = np.array([channel_probs[ch] for ch in MUTATION_CHANNELS])
            new_channel_counts = local_rng.multinomial(n_new_mutations, probs_array)

            for channel, count in zip(MUTATION_CHANNELS, new_channel_counts):
                resistant_counts[channel] += int(count)

            specific_new = int(new_channel_counts[MUTATION_CHANNELS.index(config.specific_variant_name)])
            cumulative_specific_variants += specific_new
            cumulative_all_variants += n_new_mutations

            if specific_new > 0 and np.isnan(time_to_first_specific):
                time_to_first_specific = step * config.dt

            # Mutated cells are removed from sensitive compartments in aggregate
            remove_from_mutagenic = min(sensitive_mutagenic, n_mutations_mutagenic)
            sensitive_mutagenic -= remove_from_mutagenic
            remove_from_normal = min(sensitive_normal, n_new_mutations - remove_from_mutagenic)
            sensitive_normal -= remove_from_normal

        # Resistant clone growth/death by channel
        for channel in MUTATION_CHANNELS:
            count = resistant_counts[channel]
            if count <= 0:
                continue

            channel_growth = (
                config.base_resistant_growth
                + CHANNEL_RESISTANCE_GROWTH_MODIFIER[channel]
            ) * crowding_factor

            p_birth_resistant = np.clip(channel_growth, 0.0, 0.50)
            p_death_resistant = np.clip(config.base_death + config.drug_kill_resistant * dose, 0.0, 0.80)

            births_resistant = local_rng.binomial(count, p_birth_resistant)
            deaths_resistant = local_rng.binomial(count, p_death_resistant)
            resistant_counts[channel] = max(0, count + births_resistant - deaths_resistant)

        total_resistant = int(sum(resistant_counts.values()))
        total_sensitive = int(sensitive_normal + sensitive_mutagenic)
        total_cells = int(total_sensitive + total_resistant)

        specific_count = int(resistant_counts[config.specific_variant_name])
        specific_resistant_fraction = specific_count / max(total_resistant, 1)

        if (
            np.isnan(time_to_resistant_fixation)
            and total_resistant > 0
            and specific_resistant_fraction >= config.fixation_fraction_threshold
            and specific_count >= 50
        ):
            time_to_resistant_fixation = step * config.dt

        cumulative_path_entropy += path_h
        cumulative_t_eff += t_eff

        timeline_records.append({
            "step": step,
            "time": step * config.dt,
            "scenario": scenario.scenario_name,
            "dose": dose,
            "total_cells": total_cells,
            "sensitive_normal": sensitive_normal,
            "sensitive_mutagenic": sensitive_mutagenic,
            "total_sensitive": total_sensitive,
            "total_resistant": total_resistant,
            "specific_resistant_count": specific_count,
            "specific_resistant_fraction": specific_resistant_fraction,
            "replication_stress": replication_stress,
            "oxidative_stress": oxidative_stress,
            "T_eff": t_eff,
            "path_entropy": path_h,
            "normalized_path_entropy": path_h_norm,
            "channeling_index": channel_idx,
            "specific_channel_probability": channel_probs[config.specific_variant_name],
            "cumulative_specific_variants": cumulative_specific_variants,
            "cumulative_all_variants": cumulative_all_variants,
        })

    timeline_df = pd.DataFrame(timeline_records)

    final_row = timeline_df.iloc[-1].to_dict()
    summary = {
        "scenario": scenario.scenario_name,
        "nominal_dose": scenario.dose,
        "schedule_type": scenario.schedule_type,
        "final_surviving_cells": int(final_row["total_cells"]),
        "final_sensitive_cells": int(final_row["total_sensitive"]),
        "final_resistant_cells": int(final_row["total_resistant"]),
        "final_specific_resistant_count": int(final_row["specific_resistant_count"]),
        "final_specific_resistant_fraction_among_resistant": float(final_row["specific_resistant_fraction"]),
        "final_T_eff": float(final_row["T_eff"]),
        "mean_T_eff": float(timeline_df["T_eff"].mean()),
        "final_path_entropy": float(final_row["path_entropy"]),
        "mean_path_entropy": float(timeline_df["path_entropy"].mean()),
        "mean_normalized_path_entropy": float(timeline_df["normalized_path_entropy"].mean()),
        "final_channeling_index": float(final_row["channeling_index"]),
        "mean_channeling_index": float(timeline_df["channeling_index"].mean()),
        "final_specific_channel_probability": float(final_row["specific_channel_probability"]),
        "cumulative_specific_variants": int(final_row["cumulative_specific_variants"]),
        "cumulative_all_variants": int(final_row["cumulative_all_variants"]),
        "observed_specific_variant_share": (
            float(final_row["cumulative_specific_variants"] / max(final_row["cumulative_all_variants"], 1))
        ),
        "time_to_first_specific_variant": time_to_first_specific,
        "time_to_specific_resistant_fixation": time_to_resistant_fixation,
    }

    return timeline_df, summary

def run_full_experiment(config: SimulationConfig) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """
    Runs all dose scenarios and replicates.
    Stores compact time-average summaries and representative averaged timelines.
    """
    all_summaries = []
    timeline_accumulators = []

    run_counter = 0

    for scenario in DOSE_SCENARIOS:
        scenario_timelines = []

        for rep in range(config.n_replicates):
            run_counter += 1
            seed = RANDOM_SEED + run_counter * 101
            timeline_df, summary = simulate_one_replicate(scenario, config, seed)

            summary["replicate"] = rep
            summary["seed"] = seed
            all_summaries.append(summary)

            # Store aggregated timeline only; no cell-level raw data.
            reduced_timeline = timeline_df[
                [
                    "time",
                    "scenario",
                    "dose",
                    "total_cells",
                    "total_sensitive",
                    "total_resistant",
                    "specific_resistant_count",
                    "specific_resistant_fraction",
                    "replication_stress",
                    "oxidative_stress",
                    "T_eff",
                    "path_entropy",
                    "normalized_path_entropy",
                    "channeling_index",
                    "specific_channel_probability",
                    "cumulative_specific_variants",
                    "cumulative_all_variants",
                ]
            ].copy()
            reduced_timeline["replicate"] = rep
            scenario_timelines.append(reduced_timeline)

        scenario_timeline_df = pd.concat(scenario_timelines, ignore_index=True)

        aggregated_timeline = (
            scenario_timeline_df
            .groupby(["scenario", "time"], as_index=False)
            .agg(
                mean_dose=("dose", "mean"),
                median_total_cells=("total_cells", "median"),
                mean_total_cells=("total_cells", "mean"),
                median_total_resistant=("total_resistant", "median"),
                mean_total_resistant=("total_resistant", "mean"),
                median_specific_resistant_count=("specific_resistant_count", "median"),
                mean_specific_resistant_count=("specific_resistant_count", "mean"),
                mean_specific_resistant_fraction=("specific_resistant_fraction", "mean"),
                mean_replication_stress=("replication_stress", "mean"),
                mean_oxidative_stress=("oxidative_stress", "mean"),
                mean_T_eff=("T_eff", "mean"),
                mean_path_entropy=("path_entropy", "mean"),
                mean_normalized_path_entropy=("normalized_path_entropy", "mean"),
                mean_channeling_index=("channeling_index", "mean"),
                mean_specific_channel_probability=("specific_channel_probability", "mean"),
                mean_cumulative_specific_variants=("cumulative_specific_variants", "mean"),
                mean_cumulative_all_variants=("cumulative_all_variants", "mean"),
            )
        )

        timeline_accumulators.append(aggregated_timeline)

    run_level_summary = pd.DataFrame(all_summaries)
    timeline_summary = pd.concat(timeline_accumulators, ignore_index=True)

    return run_level_summary, timeline_summary
