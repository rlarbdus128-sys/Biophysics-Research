    n_steps: int = 260
    dt: float = 1.0
    n_replicates: int = 160

    initial_sensitive: int = 250000
    initial_resistant_total: int = 0

    carrying_capacity: int = 2000000

    base_sensitive_growth: float = 0.030
    base_resistant_growth: float = 0.026
    base_death: float = 0.010

