def generate_self_contained_inputs(config: SimulationConfig) -> Dict:
    """
    Generates all synthetic initial conditions and scenarios internally.
    No external files are required.
    """
    initial_population = {
        "sensitive_normal_fidelity": config.initial_sensitive,
        "sensitive_mutagenic_repair": 0,
        "neutral_random_like": 0,
        "APOBEC_like_specific_resistance": 0,
        "DSB_SV_like_resistance": 0,
        "other_resistance_route": 0,
    }

    scenarios = [asdict(s) for s in DOSE_SCENARIOS]

    model_metadata = {
        "study_title": "Stochastic Simulation of Cancer Therapy Resistance Based on Biophysical Thermodynamics",
        "core_mechanism": (
            "Dose increases replication and oxidative stress; stress raises effective evolutionary temperature; "
            "temperature and stress reshape the free-energy landscape of mutation channels; "
            "reshaped channel probabilities bias resistant variant emergence."
        ),
        "random_seed": RANDOM_SEED,
        "config": asdict(config),
        "mutation_channels": MUTATION_CHANNELS,
        "channel_base_free_energy": CHANNEL_BASE_FREE_ENERGY,
        "channel_stress_coupling": CHANNEL_STRESS_COUPLING,
    }

    return {
        "initial_population": initial_population,
        "scenarios": scenarios,
        "metadata": model_metadata,
    }

# ============================================================
# 4. Biophysical thermodynamic functions
# ============================================================

def schedule_dose(scenario: DoseScenario, step: int) -> float:
    """
    Continuous and pulsed dose schedules.
    Pulsed high dose: 14 days on, 14 days off.
    """
    if scenario.schedule_type == "continuous":
        return scenario.dose
    if scenario.schedule_type == "pulsed":
        cycle = 28
        return scenario.dose if (step % cycle) < 14 else 0.0
    raise ValueError(f"Unknown schedule type: {scenario.schedule_type}")

def compute_stress_variables(dose: float, total_cells: int, config: SimulationConfig) -> Tuple[float, float]:
    """
    Replication stress and oxidative stress are synthetic mechanistic variables.
    They increase with dose and crowding pressure.
    """
    crowding_pressure = min(total_cells / max(config.carrying_capacity, 1), 1.5)
    replication_stress = np.clip(0.15 + 0.85 * dose + 0.25 * crowding_pressure, 0.0, 2.0)
    oxidative_stress = np.clip(0.10 + 0.75 * dose + 0.15 * crowding_pressure, 0.0, 2.0)
    return replication_stress, oxidative_stress

def compute_effective_evolutionary_temperature(
    dose: float,
    replication_stress: float,
    oxidative_stress: float,
    config: SimulationConfig
) -> float:
    """
    Effective evolutionary temperature proxy.
    Higher dose and stress increase stochasticity of evolutionary search.
    """
    t_eff = (
        config.t_eff_baseline
        + config.t_eff_dose_coeff * dose
        + config.t_eff_replication_coeff * replication_stress
        + config.t_eff_oxidative_coeff * oxidative_stress
        + config.t_eff_noise_floor
    )
    return max(t_eff, 0.05)

def free_energy_landscape(
    dose: float,
    replication_stress: float,
    oxidative_stress: float
) -> Dict[str, float]:
    """
    Dose/stress-dependent free-energy landscape deformation.
    Lower effective free energy gives higher channel probability.
    APOBEC-like channel is deliberately stress-coupled to represent
    specific variant channeling beyond random noise.
    """
    composite_stress = 0.65 * replication_stress + 0.35 * oxidative_stress

    energies = {}
    for channel in MUTATION_CHANNELS:
        base_energy = CHANNEL_BASE_FREE_ENERGY[channel]
        stress_coupling = CHANNEL_STRESS_COUPLING[channel]
        nonlinear_channeling = 0.0

        if channel == "APOBEC_like_specific_resistance":
            nonlinear_channeling = 0.75 * (dose ** 2) + 0.45 * max(replication_stress - 0.8, 0.0) ** 2
        elif channel == "DSB_SV_like_resistance":
            nonlinear_channeling = 0.35 * (oxidative_stress ** 2)

        energies[channel] = base_energy - stress_coupling * composite_stress - nonlinear_channeling

    return energies

def softmax_channel_probabilities(
    energies: Dict[str, float],
    t_eff: float,
    config: SimulationConfig
) -> Dict[str, float]:
    """
    Boltzmann-like mapping:
    p(path_i) ∝ exp(-F_i / T_eff)
    T_eff controls stochastic exploration; free-energy deformation controls channeling.
    """
    energy_array = np.array([energies[ch] for ch in MUTATION_CHANNELS], dtype=float)
    logits = -energy_array / max(t_eff, config.entropy_epsilon)
    logits = logits - logits.max()
    weights = np.exp(logits)
    probs = weights / weights.sum()
    return {ch: float(p) for ch, p in zip(MUTATION_CHANNELS, probs)}

def shannon_entropy(probabilities: Dict[str, float], config: SimulationConfig) -> float:
    """
    Shannon path entropy over mutation channels.
    H = -sum p_i log(p_i)
    """
    p = np.array(list(probabilities.values()), dtype=float)
    p = np.clip(p, config.entropy_epsilon, 1.0)
    return float(-np.sum(p * np.log(p)))

def normalized_entropy(probabilities: Dict[str, float], config: SimulationConfig) -> float:
    return shannon_entropy(probabilities, config) / np.log(len(probabilities))

def channeling_index(probabilities: Dict[str, float], specific_channel: str) -> float:
    """
    Channeling Index:
    specific channel probability / uniform expectation.
    If >1, the specific resistant pathway is enriched beyond random uniform channel use.
    """
    uniform_prob = 1.0 / len(probabilities)
    return probabilities[specific_channel] / uniform_prob
