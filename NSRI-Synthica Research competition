    "\n",
    "# 2. 현재 폴더 및 하위 폴더의 모든 파일 목록 출력\n",
    "print(\"파일 및 폴더 구조:\")\n",
    "for root, dirs, files in os.walk(cwd):\n",
    "    # 너무 깊이 들어가는 것을 방지 (필요시 조절)\n",
    "    level = root.replace(cwd, '').count(os.sep)\n",
    "    indent = ' ' * 4 * (level)\n",
    "    print(f\"{indent}[폴더] {os.path.basename(root)}/\")\n",
    "    \n",
    "    sub_indent = ' ' * 4 * (level + 1)\n",
    "    for f in files:\n",
    "        # 파일 크기도 함께 표시하여 실제로 데이터가 들어있는지 확인\n",
    "        f_path = os.path.join(root, f)\n",
    "        f_size = os.path.getsize(f_path) / 1024  # KB 단위\n",
    "        print(f\"{sub_indent}{f} ({f_size:.2f} KB)\")\n",
