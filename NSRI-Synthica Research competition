    "# ============================================================\n",
    "# Replica-SWAP information control and boundary stochastic irreversibility\n",
    "# Self-contained Kaggle-ready computational pilot\n",
    "#\n",
    "# Main outputs:\n",
    "# - exact second Renyi entropy and SWAP expectation checks\n",
    "# - monitored replica-SWAP trajectory ensembles\n",
    "# - boundary path entropy-production-like log-ratios\n",
    "# - work-like variables under replica-SWAP drive\n",
    "# - correlation/covariance between W_lambda and Sigma_A\n",
    "# - transition current matrices and figures\n",
    "# ============================================================\n",
    "import os\n",
    "import json\n",
    "import math\n",
    "import time\n",
    "import itertools\n",
    "import warnings\n",
    "from collections import Counter, defaultdict\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import scipy.linalg as la\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# -----------------------------\n",
    "# Global reproducibility config\n",
    "# -----------------------------\n",
    "CONFIG = {\n",
    "    \"project_name\": \"replica_swap_boundary_irreversibility_pilot\",\n",
    "    \"random_seed\": 123,\n",
    "    \"L_single\": 4,\n",
    "    \"J_ising\": 1.0,\n",
    "    \"h_field\": 1.0,\n",
    "    \"beta\": 1.5,\n",
    "    \"subregion_fraction\": 0.5,\n",
    "    \"protocol_time\": 1.0,\n",
    "    \"n_steps\": 8,\n",
    "    \"n_forward_trajectories\": 1200,\n",
    "    \"n_reverse_trajectories\": 1200,\n",
    "    \"kappa_values\": [0.0, 0.25, 0.50, 0.75, 1.00],\n",
    "    \"lambda_start\": 0.0,\n",
    "    \"lambda_end\": 1.0,\n",
    "    \"laplace_smoothing\": 1.0,\n",
    "    \"output_dir\": \"/kaggle/working/replica_swap_outputs\"\n",
    "}\n",
    "\n",
    "np.random.seed(CONFIG[\"random_seed\"])\n",
    "os.makedirs(CONFIG[\"output_dir\"], exist_ok=True)\n",
    "\n",
    "# -----------------------------\n",
    "# Basic linear algebra utilities\n",
    "# -----------------------------\n",
    "def kron_all(ops):\n",
    "    out = ops[0]\n",
    "    for op in ops[1:]:\n",
    "        out = np.kron(out, op)\n",
    "    return out\n",
    "\n",
    "def pauli_matrices():\n",
    "    I = np.eye(2, dtype=complex)\n",
    "    X = np.array([[0, 1], [1, 0]], dtype=complex)\n",
    "    Y = np.array([[0, -1j], [1j, 0]], dtype=complex)\n",
    "    Z = np.array([[1, 0], [0, -1]], dtype=complex)\n",
    "    return I, X, Y, Z\n",
    "\n",
    "def local_operator(op, site, L):\n",
    "    I, X, Y, Z = pauli_matrices()\n",
    "    ops = []\n",
    "    for i in range(L):\n",
    "        ops.append(op if i == site else I)\n",
    "    return kron_all(ops)\n",
    "\n",
    "def tfim_hamiltonian(L, J=1.0, h=1.0, periodic=True):\n",
    "    I, X, Y, Z = pauli_matrices()\n",
    "    dim = 2 ** L\n",
    "    H = np.zeros((dim, dim), dtype=complex)\n",
    "\n",
    "    for i in range(L):\n",
    "        j = (i + 1) % L\n",
    "        if (not periodic) and i == L - 1:\n",
    "            continue\n",
    "        Zi = local_operator(Z, i, L)\n",
    "        Zj = local_operator(Z, j, L)\n",
    "        H += -J * (Zi @ Zj)\n",
    "\n",
    "    for i in range(L):\n",
    "        Xi = local_operator(X, i, L)\n",
    "        H += -h * Xi\n",
    "\n",
    "    return H\n",
    "\n",
    "def thermal_probs(evals, beta):\n",
    "    shifted = evals - np.min(evals)\n",
    "    w = np.exp(-beta * shifted)\n",
    "    return w / np.sum(w)\n",
    "\n",
    "def sample_from_probs(probs, rng):\n",
    "    return int(rng.choice(len(probs), p=np.real(probs)))\n",
    "\n",
    "def matrix_sqrt_psd(rho):\n",
    "    vals, vecs = la.eigh((rho + rho.conj().T) / 2)\n",
    "    vals = np.clip(np.real(vals), 0, None)\n",
    "    return vecs @ np.diag(np.sqrt(vals)) @ vecs.conj().T\n",
    "\n",
    "# -----------------------------\n",
    "# Partial trace and entropies\n",
    "# -----------------------------\n",
    "def partial_trace_pure_state(psi, dims, keep):\n",
    "    dims = list(dims)\n",
    "    keep = list(keep)\n",
    "    trace = [i for i in range(len(dims)) if i not in keep]\n",
    "\n",
    "    psi_tensor = psi.reshape(dims)\n",
    "    perm = keep + trace\n",
    "    psi_perm = np.transpose(psi_tensor, perm)\n",
    "    dim_keep = int(np.prod([dims[i] for i in keep]))\n",
    "    dim_trace = int(np.prod([dims[i] for i in trace]))\n",
    "    psi_mat = psi_perm.reshape(dim_keep, dim_trace)\n",
    "    rho_keep = psi_mat @ psi_mat.conj().T\n",
    "    return rho_keep\n",
    "\n",
    "def partial_trace_density(rho, dims, keep):\n",
    "    dims = list(dims)\n",
    "    keep = list(keep)\n",
    "    n = len(dims)\n",
    "    trace = [i for i in range(n) if i not in keep]\n",
    "    perm = keep + trace\n",
    "\n",
    "    rho_tensor = rho.reshape(dims + dims)\n",
    "    row_perm = perm\n",
    "    col_perm = [p + n for p in perm]\n",
    "    rho_perm = np.transpose(rho_tensor, row_perm + col_perm)\n",
    "\n",
    "    dim_keep = int(np.prod([dims[i] for i in keep]))\n",
    "    dim_trace = int(np.prod([dims[i] for i in trace]))\n",
    "\n",
    "    rho_perm = rho_perm.reshape(dim_keep, dim_trace, dim_keep, dim_trace)\n",
    "    rho_keep = np.einsum(\"aibi->ab\", rho_perm)\n",
    "    return rho_keep\n",
    "\n",
    "def von_neumann_entropy(rho, eps=1e-14):\n",
    "    rho = (rho + rho.conj().T) / 2\n",
    "    vals = la.eigvalsh(rho)\n",
    "    vals = np.clip(np.real(vals), 0, None)\n",
    "    vals = vals / np.sum(vals)\n",
    "    vals = vals[vals > eps]\n",
    "    return float(-np.sum(vals * np.log(vals)))\n",
    "\n",
    "def second_renyi_entropy(rho, eps=1e-14):\n",
    "    purity = np.real(np.trace(rho @ rho))\n",
    "    purity = max(purity, eps)\n",
    "    return float(-np.log(purity))\n",
    "\n",
    "# -----------------------------\n",
    "# SWAP_A operator on two replicas\n",
    "# -----------------------------\n",
    "def index_to_bits(idx, N):\n",
    "    return [(idx >> (N - 1 - k)) & 1 for k in range(N)]\n",
    "\n",
    "def bits_to_index(bits):\n",
    "    idx = 0\n",
    "    N = len(bits)\n",
    "    for k, b in enumerate(bits):\n",
    "        idx |= (int(b) << (N - 1 - k))\n",
    "    return idx\n",
    "\n",
    "def swap_A_operator(L, A_sites):\n",
    "    N = 2 * L\n",
    "    D = 2 ** N\n",
    "    S = np.zeros((D, D), dtype=complex)\n",
    "\n",
    "    for idx in range(D):\n",
    "        bits = index_to_bits(idx, N)\n",
    "        new_bits = bits.copy()\n",
    "        for s in A_sites:\n",
    "            new_bits[s], new_bits[L + s] = new_bits[L + s], new_bits[s]\n",
    "        new_idx = bits_to_index(new_bits)\n",
    "        S[new_idx, idx] = 1.0\n",
    "\n",
    "    return S\n",
    "\n",
    "# -----------------------------\n",
    "# Boundary measurement utilities\n",
    "# -----------------------------\n",
    "def build_boundary_masks(total_qubits, boundary_sites):\n",
    "    n_outcomes = 2 ** len(boundary_sites)\n",
    "    masks = {k: [] for k in range(n_outcomes)}\n",
    "\n",
    "    for idx in range(2 ** total_qubits):\n",
    "        bits = index_to_bits(idx, total_qubits)\n",
    "        out_bits = [bits[s] for s in boundary_sites]\n",
    "        outcome = bits_to_index(out_bits)\n",
    "        masks[outcome].append(idx)\n",
    "\n",
    "    masks = {k: np.array(v, dtype=int) for k, v in masks.items()}\n",
    "    return masks\n",
    "\n",
    "def measure_boundary_state(psi, masks, rng):\n",
    "    probs = np.zeros(len(masks), dtype=float)\n",
    "    for outcome, idxs in masks.items():\n",
    "        probs[outcome] = float(np.sum(np.abs(psi[idxs]) ** 2))\n",
    "    probs = np.clip(probs, 0, None)\n",
    "    s = probs.sum()\n",
    "    if s <= 0:\n",
    "        probs[:] = 1.0 / len(probs)\n",
    "    else:\n",
    "        probs /= s\n",
    "\n",
    "    outcome = sample_from_probs(probs, rng)\n",
    "    new_psi = np.zeros_like(psi)\n",
    "    idxs = masks[outcome]\n",
    "    norm = np.sqrt(np.sum(np.abs(psi[idxs]) ** 2))\n",
    "    if norm <= 0:\n",
    "        new_psi = psi.copy()\n",
    "    else:\n",
    "        new_psi[idxs] = psi[idxs] / norm\n",
    "\n",
    "    return outcome, new_psi, probs\n",
    "\n",
    "# -----------------------------\n",
    "# Protocol Hamiltonians\n",
    "# -----------------------------\n",
    "def build_replica_hamiltonians(L, J, h, A_sites):\n",
    "    H_single = tfim_hamiltonian(L, J=J, h=h, periodic=True)\n",
    "    I_single = np.eye(2 ** L, dtype=complex)\n",
    "    H0 = np.kron(H_single, I_single) + np.kron(I_single, H_single)\n",
    "    SWAP_A = swap_A_operator(L, A_sites)\n",
    "    return H_single, H0, SWAP_A\n",
    "\n",
    "def H_lambda(H0, SWAP_A, kappa, lam):\n",
    "    return H0 + kappa * lam * SWAP_A\n",
    "\n",
    "def precompute_unitaries(H0, SWAP_A, kappa, lam_schedule, dt):\n",
    "    U_list = []\n",
    "    H_list_mid = []\n",
    "    for a, b in zip(lam_schedule[:-1], lam_schedule[1:]):\n",
    "        lam_mid = 0.5 * (a + b)\n",
    "        H_mid = H_lambda(H0, SWAP_A, kappa, lam_mid)\n",
    "        U = la.expm(-1j * H_mid * dt)\n",
    "        U_list.append(U)\n",
    "        H_list_mid.append(H_mid)\n",
    "    return U_list, H_list_mid\n",
    "\n",
    "# -----------------------------\n",
    "# Work and monitored trajectories\n",
    "# -----------------------------\n",
    "def run_monitored_ensemble(\n",
    "    H0,\n",
    "    SWAP_A,\n",
    "    kappa,\n",
    "    beta,\n",
    "    lam_start,\n",
    "    lam_end,\n",
    "    protocol_time,\n",
    "    n_steps,\n",
    "    n_traj,\n",
    "    boundary_masks,\n",
    "    rng,\n",
    "    direction=\"forward\"\n",
    "):\n",
    "    if direction == \"forward\":\n",
    "        lam_schedule = np.linspace(lam_start, lam_end, n_steps + 1)\n",
    "    elif direction == \"reverse\":\n",
    "        lam_schedule = np.linspace(lam_end, lam_start, n_steps + 1)\n",
    "    else:\n",
    "        raise ValueError(\"direction must be forward or reverse\")\n",
    "\n",
    "    dt = protocol_time / n_steps\n",
    "\n",
    "    H_initial = H_lambda(H0, SWAP_A, kappa, lam_schedule[0])\n",
    "    H_final = H_lambda(H0, SWAP_A, kappa, lam_schedule[-1])\n",
    "\n",
    "    eval_i, evec_i = la.eigh((H_initial + H_initial.conj().T) / 2)\n",
    "    eval_f, evec_f = la.eigh((H_final + H_final.conj().T) / 2)\n",
    "\n",
    "    p_i = thermal_probs(eval_i, beta)\n",
    "    U_list, _ = precompute_unitaries(H0, SWAP_A, kappa, lam_schedule, dt)\n",
    "\n",
    "    records = []\n",
    "\n",
    "    for tr in range(n_traj):\n",
    "        n0 = sample_from_probs(p_i, rng)\n",
    "        E0 = float(np.real(eval_i[n0]))\n",
    "        psi = evec_i[:, n0].copy()\n",
    "\n",
    "        boundary_path = []\n",
    "\n",
    "        # Initial boundary measurement\n",
    "        out, psi, _ = measure_boundary_state(psi, boundary_masks, rng)\n",
    "        boundary_path.append(int(out))\n",
    "\n",
    "        # Evolve and monitor boundary at every protocol step\n",
    "        for U in U_list:\n",
    "            psi = U @ psi\n",
    "            psi = psi / np.linalg.norm(psi)\n",
    "            out, psi, _ = measure_boundary_state(psi, boundary_masks, rng)\n",
    "            boundary_path.append(int(out))\n",
    "\n",
    "        # Final energy measurement after monitored evolution\n",
    "        amp_f = evec_f.conj().T @ psi\n",
    "        p_f = np.abs(amp_f) ** 2\n",
    "        p_f = np.clip(np.real(p_f), 0, None)\n",
    "        p_f = p_f / np.sum(p_f)\n",
    "        mf = sample_from_probs(p_f, rng)\n",
    "        Ef = float(np.real(eval_f[mf]))\n",
    "        W = Ef - E0\n",
    "\n",
    "        records.append({\n",
    "            \"direction\": direction,\n",
    "            \"kappa\": float(kappa),\n",
    "            \"traj_id\": tr,\n",
    "            \"initial_energy_index\": int(n0),\n",
    "            \"final_energy_index\": int(mf),\n",
    "            \"E_initial\": E0,\n",
    "            \"E_final\": Ef,\n",
    "            \"W\": float(W),\n",
    "            \"path\": \"-\".join(map(str, boundary_path)),\n",
    "            \"path_tuple\": tuple(boundary_path)\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "def run_unmonitored_tpm_ensemble(\n",
    "    H0,\n",
    "    SWAP_A,\n",
    "    kappa,\n",
    "    beta,\n",
    "    lam_start,\n",
    "    lam_end,\n",
    "    protocol_time,\n",
    "    n_steps,\n",
    "    n_traj,\n",
    "    rng\n",
    "):\n",
    "    lam_schedule = np.linspace(lam_start, lam_end, n_steps + 1)\n",
    "    dt = protocol_time / n_steps\n",
    "\n",
    "    H_initial = H_lambda(H0, SWAP_A, kappa, lam_schedule[0])\n",
    "    H_final = H_lambda(H0, SWAP_A, kappa, lam_schedule[-1])\n",
    "\n",
    "    eval_i, evec_i = la.eigh((H_initial + H_initial.conj().T) / 2)\n",
    "    eval_f, evec_f = la.eigh((H_final + H_final.conj().T) / 2)\n",
    "\n",
    "    p_i = thermal_probs(eval_i, beta)\n",
    "    U_list, _ = precompute_unitaries(H0, SWAP_A, kappa, lam_schedule, dt)\n",
    "\n",
    "    U_total = np.eye(H0.shape[0], dtype=complex)\n",
    "    for U in U_list:\n",
    "        U_total = U @ U_total\n",
    "\n",
    "    Z_i_abs = np.sum(np.exp(-beta * eval_i))\n",
    "    Z_f_abs = np.sum(np.exp(-beta * eval_f))\n",
    "    delta_F_exact = float(-(1.0 / beta) * np.log(np.real(Z_f_abs / Z_i_abs)))\n",
    "\n",
    "    W_samples = []\n",
    "    for _ in range(n_traj):\n",
    "        n0 = sample_from_probs(p_i, rng)\n",
    "        psi = evec_i[:, n0].copy()\n",
    "        E0 = float(np.real(eval_i[n0]))\n",
    "\n",
    "        psi_f = U_total @ psi\n",
    "        psi_f = psi_f / np.linalg.norm(psi_f)\n",
    "        amp_f = evec_f.conj().T @ psi_f\n",
    "        p_f = np.abs(amp_f) ** 2\n",
    "        p_f = np.clip(np.real(p_f), 0, None)\n",
    "        p_f = p_f / np.sum(p_f)\n",
    "\n",
    "        mf = sample_from_probs(p_f, rng)\n",
    "        Ef = float(np.real(eval_f[mf]))\n",
    "        W_samples.append(Ef - E0)\n",
    "\n",
    "    W_samples = np.array(W_samples, dtype=float)\n",
    "    jarz = float(-(1.0 / beta) * np.log(np.mean(np.exp(-beta * W_samples))))\n",
    "\n",
    "    return {\n",
    "        \"kappa\": float(kappa),\n",
    "        \"delta_F_exact_unmonitored\": delta_F_exact,\n",
    "        \"delta_F_jarzynski_estimate_unmonitored\": jarz,\n",
    "        \"jarzynski_error\": jarz - delta_F_exact,\n",
    "        \"mean_W_unmonitored\": float(np.mean(W_samples)),\n",
    "        \"std_W_unmonitored\": float(np.std(W_samples)),\n",
    "        \"n_tpm_samples\": int(n_traj)\n",
    "    }\n",
    "\n",
    "# -----------------------------\n",
    "# Path probability log-ratio\n",
    "# -----------------------------\n",
    "def estimate_path_sigmas(forward_df, reverse_df, smoothing=1.0):\n",
    "    f_counts = Counter(forward_df[\"path\"].tolist())\n",
    "    r_counts = Counter(reverse_df[\"path\"].tolist())\n",
    "\n",
    "    all_paths = set(f_counts.keys()).union(set(r_counts.keys()))\n",
    "    n_unique = len(all_paths)\n",
    "\n",
    "    Nf = len(forward_df)\n",
    "    Nr = len(reverse_df)\n",
    "\n",
    "    def reverse_path_string(path_string):\n",
    "        parts = path_string.split(\"-\")\n",
    "        return \"-\".join(parts[::-1])\n",
    "\n",
    "    sigma_values = []\n",
    "    pf_values = []\n",
    "    pr_rev_values = []\n",
    "\n",
    "    for path in forward_df[\"path\"].tolist():\n",
    "        rev_path = reverse_path_string(path)\n",
    "\n",
    "        pf = (f_counts.get(path, 0) + smoothing) / (Nf + smoothing * n_unique)\n",
    "        pr = (r_counts.get(rev_path, 0) + smoothing) / (Nr + smoothing * n_unique)\n",
    "\n",
    "        sigma = math.log(pf / pr)\n",
    "\n",
    "        sigma_values.append(float(sigma))\n",
    "        pf_values.append(float(pf))\n",
    "        pr_rev_values.append(float(pr))\n",
    "\n",
    "    out = forward_df.copy()\n",
    "    out[\"Sigma_A_path_logratio\"] = sigma_values\n",
    "    out[\"P_forward_path_smoothed\"] = pf_values\n",
    "    out[\"P_reverse_reversed_path_smoothed\"] = pr_rev_values\n",
    "\n",
    "    path_table = []\n",
    "    for path in sorted(all_paths):\n",
    "        rev_path = reverse_path_string(path)\n",
    "        pf = (f_counts.get(path, 0) + smoothing) / (Nf + smoothing * n_unique)\n",
    "        pr_rev = (r_counts.get(rev_path, 0) + smoothing) / (Nr + smoothing * n_unique)\n",
    "        path_table.append({\n",
    "            \"path\": path,\n",
    "            \"reverse_of_path\": rev_path,\n",
    "            \"forward_count\": int(f_counts.get(path, 0)),\n",
    "            \"reverse_reversed_count\": int(r_counts.get(rev_path, 0)),\n",
    "            \"P_forward_smoothed\": float(pf),\n",
    "            \"P_reverse_reversed_smoothed\": float(pr_rev),\n",
    "            \"Sigma_path\": float(math.log(pf / pr_rev))\n",
    "        })\n",
    "\n",
    "    return out, pd.DataFrame(path_table)\n",
    "\n",
    "def transition_current_from_paths(df, n_outcomes, n_steps):\n",
    "    counts = np.zeros((n_outcomes, n_outcomes), dtype=float)\n",
    "\n",
    "    for path in df[\"path\"].tolist():\n",
    "        xs = list(map(int, path.split(\"-\")))\n",
    "        for a, b in zip(xs[:-1], xs[1:]):\n",
    "            counts[a, b] += 1\n",
    "\n",
    "    total = counts.sum()\n",
    "    if total > 0:\n",
    "        Pij = counts / total\n",
    "    else:\n",
    "        Pij = counts\n",
    "\n",
    "    J = Pij - Pij.T\n",
    "\n",
    "    eps = 1e-12\n",
    "    ep = 0.0\n",
    "    for i in range(n_outcomes):\n",
    "        for j in range(n_outcomes):\n",
    "            if i == j:\n",
    "                continue\n",
    "            if Pij[i, j] > 0 and Pij[j, i] > 0:\n",
    "                ep += Pij[i, j] * np.log((Pij[i, j] + eps) / (Pij[j, i] + eps))\n",
    "\n",
    "    return counts, Pij, J, float(ep)\n",
    "\n",
    "def safe_corr(x, y):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    if np.std(x) < 1e-14 or np.std(y) < 1e-14:\n",
    "        return np.nan\n",
    "    return float(np.corrcoef(x, y)[0, 1])\n",
    "\n",
    "def bootstrap_corr_ci(x, y, n_boot=500, seed=123):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    n = len(x)\n",
    "    vals = []\n",
    "    for _ in range(n_boot):\n",
    "        idx = rng.integers(0, n, size=n)\n",
    "        c = safe_corr(x[idx], y[idx])\n",
    "        if not np.isnan(c):\n",
    "            vals.append(c)\n",
    "    if len(vals) == 0:\n",
    "        return np.nan, np.nan\n",
    "    return float(np.percentile(vals, 2.5)), float(np.percentile(vals, 97.5))\n",
    "\n",
    "def permutation_pvalue_corr(x, y, n_perm=500, seed=123):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    obs = safe_corr(x, y)\n",
    "    if np.isnan(obs):\n",
    "        return np.nan\n",
    "    vals = []\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    for _ in range(n_perm):\n",
    "        yp = rng.permutation(y)\n",
    "        vals.append(safe_corr(x, yp))\n",
    "    vals = np.asarray(vals)\n",
    "    p = np.mean(np.abs(vals) >= abs(obs))\n",
    "    return float(p)\n",
    "\n",
    "# -----------------------------\n",
    "# Exact Renyi and SWAP checks\n",
    "# -----------------------------\n",
    "def compute_renyi_swap_checks(H_single, SWAP_A, L, A_sites, beta):\n",
    "    evals, evecs = la.eigh((H_single + H_single.conj().T) / 2)\n",
    "    psi0 = evecs[:, 0]\n",
    "    dims_single = [2] * L\n",
    "    rhoA = partial_trace_pure_state(psi0, dims_single, A_sites)\n",
    "\n",
    "    S2 = second_renyi_entropy(rhoA)\n",
    "    purity = float(np.real(np.trace(rhoA @ rhoA)))\n",
    "\n",
    "    # Two-copy pure state expectation of SWAP_A\n",
    "    psi2 = np.kron(psi0, psi0)\n",
    "    swap_exp = float(np.real(np.vdot(psi2, SWAP_A @ psi2)))\n",
    "\n",
    "    # Thermal single-copy S2 diagnostic\n",
    "    weights = np.exp(-beta * evals)\n",
    "    weights = weights / np.sum(weights)\n",
    "    rho_th = evecs @ np.diag(weights) @ evecs.conj().T\n",
    "    rhoA_th = partial_trace_density(rho_th, dims_single, A_sites)\n",
    "    S2_th = second_renyi_entropy(rhoA_th)\n",
    "    purity_th = float(np.real(np.trace(rhoA_th @ rhoA_th)))\n",
    "\n",
    "    return pd.DataFrame([{\n",
    "        \"L_single\": L,\n",
    "        \"A_sites\": \",\".join(map(str, A_sites)),\n",
    "        \"ground_state_S2_A\": S2,\n",
    "        \"ground_state_purity_Tr_rhoA2\": purity,\n",
    "        \"two_copy_SWAP_A_expectation\": swap_exp,\n",
    "        \"swap_minus_purity_ground\": swap_exp - purity,\n",
    "        \"thermal_S2_A\": S2_th,\n",
    "        \"thermal_purity_Tr_rhoA2\": purity_th,\n",
    "        \"beta\": beta\n",
    "    }])\n",
    "\n",
    "# -----------------------------\n",
    "# Main execution\n",
    "# -----------------------------\n",
