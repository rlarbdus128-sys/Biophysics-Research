    "import os\n",
    "import re\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from scipy.stats import pearsonr, spearmanr\n",
    "\n",
    "# =========================\n",
    "# User settings (Kaggle 경로로 수정)\n",
    "# =========================\n",
    "# 앞선 탐색 결과에 따라 실제 파일이 있는 하위 폴더 경로를 적용했습니다.\n",
    "INPUT_FILE = \"replica_swap_outputs/trajectory_samples_all_kappa.csv\"\n",
    "OUTPUT_DIR = \"trajectory_summary_outputs\"\n",
    "\n",
    "N_BOOT = 5000\n",
    "N_PERM = 5000\n",
    "RANDOM_SEED = 123\n",
    "HIGH_Q = 0.90\n",
    "\n",
    "np.random.seed(RANDOM_SEED)\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "# =========================\n",
    "# Loading and column detection (원래 로직 유지)\n",
    "# =========================\n",
    "def load_table(path):\n",
    "    ext = os.path.splitext(path)[1].lower()\n",
    "    if ext in [\".xlsx\", \".xls\"]:\n",
    "        return pd.read_excel(path)\n",
    "    elif ext in [\".csv\", \".txt\"]:\n",
    "        return pd.read_csv(path)\n",
    "    else:\n",
    "        raise ValueError(f\"Unsupported file extension: {ext}\")\n",
    "\n",
    "def find_col(df, candidates, required=True):\n",
    "    cols = list(df.columns)\n",
    "    lower_map = {str(c).lower(): c for c in cols}\n",
    "    for cand in candidates:\n",
    "        if cand.lower() in lower_map:\n",
    "            return lower_map[cand.lower()]\n",
    "    for cand in candidates:\n",
    "        cand_l = cand.lower()\n",
    "        for c in cols:\n",
    "            if cand_l in str(c).lower():\n",
    "                return c\n",
    "    if required:\n",
    "        raise ValueError(f\"Could not find required column among candidates {candidates}.\")\n",
    "    return None\n",
    "\n",
    "# 데이터 로드 시도 (파일이 없으면 현재 폴더에서도 한 번 더 확인)\n",
    "if not os.path.exists(INPUT_FILE):\n",
    "    INPUT_FILE = \"trajectory_samples_all_kappa.csv\"\n",
    "\n",
    "df = load_table(INPUT_FILE)\n",
    "\n",
    "kappa_col = find_col(df, [\"kappa\", \"κ\"])\n",
    "W_col = find_col(df, [\"W_lambda\", \"Wλ\", \"W_lam\", \"work\", \"W\"])\n",
    "Sigma_col = find_col(df, [\"Sigma_A\", \"Sigma_path\", \"Sigma\", \"sigma_A\", \"entropy\"])\n",
    "path_col = find_col(df, [\"path\", \"boundary_path\", \"trajectory_path\"], required=False)\n",
    "traj_col = find_col(df, [\"trajectory_id\", \"traj_id\", \"id\"], required=False)\n",
    "\n",
    "df = df.copy()\n",
    "df[kappa_col] = pd.to_numeric(df[kappa_col], errors=\"coerce\")\n",
    "df[W_col] = pd.to_numeric(df[W_col], errors=\"coerce\")\n",
    "df[Sigma_col] = pd.to_numeric(df[Sigma_col], errors=\"coerce\")\n",
    "df = df.dropna(subset=[kappa_col, W_col, Sigma_col])\n",
    "\n",
    "# 원래 코드의 변수명 그대로 유지\n",
    "df[\"kappa\"] = df[kappa_col].astype(float)\n",
    "df[\"W\"] = df[W_col].astype(float)\n",
    "df[\"Sigma\"] = df[Sigma_col].astype(float)\n",
    "if path_col is not None:\n",
    "    df[\"path\"] = df[path_col].astype(str)\n",
    "else:\n",
    "    df[\"path\"] = \"NA\"\n",
    "\n",
    "# =========================\n",
    "# Helper statistics (원래 표현 유지)\n",
    "# =========================\n",
    "def safe_pearson(x, y):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    if len(x) < 3 or np.std(x) == 0 or np.std(y) == 0:\n",
    "        return np.nan\n",
    "    return pearsonr(x, y)[0]\n",
    "\n",
    "def safe_spearman(x, y):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    if len(x) < 3 or np.std(x) == 0 or np.std(y) == 0:\n",
    "        return np.nan\n",
    "    return spearmanr(x, y).correlation\n",
    "\n",
    "def quantiles(x):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    return {\n",
    "        \"q01\": np.quantile(x, 0.01), \"q05\": np.quantile(x, 0.05),\n",
    "        \"q25\": np.quantile(x, 0.25), \"q50\": np.quantile(x, 0.50),\n",
    "        \"q75\": np.quantile(x, 0.75), \"q95\": np.quantile(x, 0.95), \"q99\": np.quantile(x, 0.99),\n",
    "    }\n",
    "\n",
    "def trimmed_arrays(x, y, trim=0.05):\n",
    "    x, y = np.asarray(x, dtype=float), np.asarray(y, dtype=float)\n",
    "    xlo, xhi = np.quantile(x, [trim, 1 - trim])\n",
    "    ylo, yhi = np.quantile(y, [trim, 1 - trim])\n",
    "    mask = (x >= xlo) & (x <= xhi) & (y >= ylo) & (y <= yhi)\n",
    "    return x[mask], y[mask], mask\n",
    "\n",
    "def winsorize(x, p=0.05):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    lo, hi = np.quantile(x, [p, 1 - p])\n",
    "    return np.clip(x, lo, hi)\n",
    "\n",
    "def path_switch_count(path):\n",
    "    if path == \"NA\" or pd.isna(path): return np.nan\n",
    "    parts = [p for p in re.split(r\"[-,\\s]+\", str(path).strip()) if p != \"\"]\n",
    "    return sum(parts[i] != parts[i - 1] for i in range(1, len(parts))) if len(parts) > 1 else 0\n",
    "\n",
    "def path_start(path):\n",
    "    parts = [p for p in re.split(r\"[-,\\s]+\", str(path).strip()) if p != \"\"]\n",
    "    return parts[0] if parts else \"NA\"\n",
    "\n",
    "def path_end(path):\n",
    "    parts = [p for p in re.split(r\"[-,\\s]+\", str(path).strip()) if p != \"\"]\n",
    "    return parts[-1] if parts else \"NA\"\n",
    "\n",
    "def is_persistent(path):\n",
    "    if path == \"NA\" or pd.isna(path): return False\n",
    "    parts = [p for p in re.split(r\"[-,\\s]+\", str(path).strip()) if p != \"\"]\n",
    "    return len(parts) > 0 and len(set(parts)) == 1\n",
    "\n",
    "# =========================\n",
    "# 1. trajectory_summary_by_kappa\n",
    "# =========================\n",
    "summary_rows = []\n",
    "for k, g in df.groupby(\"kappa\"):\n",
    "    W, S = g[\"W\"].values, g[\"Sigma\"].values\n",
    "    Wq, Sq = quantiles(W), quantiles(S)\n",
    "    pear, spear = safe_pearson(W, S), safe_spearman(W, S)\n",
    "    W_trim, S_trim, _ = trimmed_arrays(W, S, 0.05)\n",
    "    trimmed_pear = safe_pearson(W_trim, S_trim)\n",
    "    W_win, S_win = winsorize(W, 0.05), winsorize(S, 0.05)\n",
    "    winsor_pear = safe_pearson(W_win, S_win)\n",
    "\n",
    "    high_W = W >= np.quantile(W, HIGH_Q)\n",
    "    high_S = S >= np.quantile(S, HIGH_Q)\n",
    "    overlap = np.mean(high_W & high_S)\n",
    "    expected_overlap = np.mean(high_W) * np.mean(high_S)\n",
    "    overlap_enrichment = overlap / expected_overlap if expected_overlap > 0 else np.nan\n",
    "\n",
    "    row = {\n",
    "        \"kappa\": k, \"n\": len(g),\n",
    "        \"W_mean\": np.mean(W), \"W_std\": np.std(W, ddof=1), \"W_min\": np.min(W), \"W_max\": np.max(W),\n",
    "        \"Sigma_mean\": np.mean(S), \"Sigma_std\": np.std(S, ddof=1), \"Sigma_min\": np.min(S), \"Sigma_max\": np.max(S),\n",
    "        \"Pearson_W_Sigma\": pear, \"Spearman_W_Sigma\": spear,\n",
    "        \"trimmed_Pearson_5pct\": trimmed_pear, \"winsorized_Pearson_5pct\": winsor_pear,\n",
    "        \"frac_positive_Sigma\": np.mean(S > 0), \"frac_negative_Sigma\": np.mean(S < 0), \"frac_zero_Sigma\": np.mean(S == 0),\n",
    "        \"high_W_fraction\": np.mean(high_W), \"high_Sigma_fraction\": np.mean(high_S),\n",
    "        \"high_W_high_Sigma_overlap\": overlap, \"high_overlap_expected_if_independent\": expected_overlap,\n",
    "        \"high_overlap_enrichment\": overlap_enrichment,\n",
    "    }\n",
    "    for qname, qval in Wq.items(): row[f\"W_{qname}\"] = qval\n",
    "    for qname, qval in Sq.items(): row[f\"Sigma_{qname}\"] = qval\n",
    "    summary_rows.append(row)\n",
    "\n",
    "summary_df = pd.DataFrame(summary_rows).sort_values(\"kappa\")\n",
    "summary_df.to_csv(os.path.join(OUTPUT_DIR, \"trajectory_summary_by_kappa.csv\"), index=False)\n",
    "\n",
    "# =========================\n",
    "# 2. bootstrap_correlation_by_kappa\n",
    "# =========================\n",
    "boot_rows = []\n",
    "rng = np.random.default_rng(RANDOM_SEED)\n",
    "for k, g in df.groupby(\"kappa\"):\n",
    "    W, S, n = g[\"W\"].values, g[\"Sigma\"].values, len(g)\n",
    "    boot_pear, boot_spear = [], []\n",
    "    for _ in range(N_BOOT):\n",
    "        idx = rng.integers(0, n, size=n)\n",
    "        boot_pear.append(safe_pearson(W[idx], S[idx]))\n",
    "        boot_spear.append(safe_spearman(W[idx], S[idx]))\n",
    "    \n",
    "    boot_pear, boot_spear = np.asarray(boot_pear), np.asarray(boot_spear)\n",
    "    boot_rows.append({\n",
    "        \"kappa\": k, \"n\": n, \"N_BOOT\": N_BOOT,\n",
    "        \"Pearson_observed\": safe_pearson(W, S), \"Pearson_boot_mean\": np.nanmean(boot_pear),\n",
    "        \"Pearson_boot_ci_low\": np.nanquantile(boot_pear, 0.025), \"Pearson_boot_ci_high\": np.nanquantile(boot_pear, 0.975),\n",
    "        \"Spearman_observed\": safe_spearman(W, S), \"Spearman_boot_mean\": np.nanmean(boot_spear),\n",
    "        \"Spearman_boot_ci_low\": np.nanquantile(boot_spear, 0.025), \"Spearman_boot_ci_high\": np.nanquantile(boot_spear, 0.975),\n",
    "    })\n",
    "pd.DataFrame(boot_rows).sort_values(\"kappa\").to_csv(os.path.join(OUTPUT_DIR, \"bootstrap_correlation_by_kappa.csv\"), index=False)\n",
    "\n",
    "# =========================\n",
    "# 3. permutation_test_by_kappa\n",
    "# =========================\n",
    "perm_rows = []\n",
    "rng = np.random.default_rng(RANDOM_SEED + 1)\n",
    "for k, g in df.groupby(\"kappa\"):\n",
    "    W, S = g[\"W\"].values, g[\"Sigma\"].values\n",
    "    obs = safe_pearson(W, S)\n",
    "    perm_corrs = [safe_pearson(W, rng.permutation(S)) for _ in range(N_PERM)]\n",
    "    perm_corrs = np.asarray(perm_corrs)\n",
    "    perm_rows.append({\n",
    "        \"kappa\": k, \"n\": len(g), \"N_PERM\": N_PERM, \"observed_Pearson\": obs,\n",
    "        \"perm_p_two_sided\": np.mean(np.abs(perm_corrs) >= abs(obs)) if not np.isnan(obs) else np.nan,\n",
    "        \"perm_mean\": np.nanmean(perm_corrs), \"perm_ci_low\": np.nanquantile(perm_corrs, 0.025), \"perm_ci_high\": np.nanquantile(perm_corrs, 0.975),\n",
    "    })\n",
    "pd.DataFrame(perm_rows).sort_values(\"kappa\").to_csv(os.path.join(OUTPUT_DIR, \"permutation_test_by_kappa.csv\"), index=False)\n",
    "\n",
    "# =========================\n",
    "# 4. outlier_sensitivity_by_kappa (원래 cut_types 로직 유지)\n",
    "# =========================\n",
    "def apply_cut(g, cut_type):\n",
    "    W, S = g[\"W\"].values, g[\"Sigma\"].values\n",
    "    if cut_type == \"none\": mask = np.ones(len(g), dtype=bool)\n",
    "    elif cut_type == \"remove_W_topbottom_1pct\":\n",
    "        lo, hi = np.quantile(W, [0.01, 0.99])\n",
    "        mask = (W >= lo) & (W <= hi)\n",
    "    elif cut_type == \"remove_W_topbottom_5pct\":\n",
    "        lo, hi = np.quantile(W, [0.05, 0.95])\n",
    "        mask = (W >= lo) & (W <= hi)\n",
    "    elif cut_type == \"remove_Sigma_topbottom_1pct\":\n",
    "        lo, hi = np.quantile(S, [0.01, 0.99])\n",
    "        mask = (S >= lo) & (S <= hi)\n",
    "    elif cut_type == \"remove_Sigma_topbottom_5pct\":\n",
    "        lo, hi = np.quantile(S, [0.05, 0.95])\n",
    "        mask = (S >= lo) & (S <= hi)\n",
    "    elif cut_type == \"remove_absSigma_top_1pct\":\n",
    "        mask = np.abs(S) <= np.quantile(np.abs(S), 0.99)\n",
    "    elif cut_type == \"remove_absSigma_top_5pct\":\n",
    "        mask = np.abs(S) <= np.quantile(np.abs(S), 0.95)\n",
    "    return g.loc[mask].copy()\n",
    "\n",
    "cut_types = [\"none\", \"remove_W_topbottom_1pct\", \"remove_W_topbottom_5pct\", \"remove_Sigma_topbottom_1pct\", \"remove_Sigma_topbottom_5pct\", \"remove_absSigma_top_1pct\", \"remove_absSigma_top_5pct\"]\n",
    "out_rows = []\n",
    "for k, g in df.groupby(\"kappa\"):\n",
    "    n0 = len(g)\n",
    "    for cut in cut_types:\n",
    "        gg = apply_cut(g, cut)\n",
    "        out_rows.append({\n",
    "            \"kappa\": k, \"cut_type\": cut, \"n_original\": n0, \"n_kept\": len(gg), \"kept_fraction\": len(gg)/n0,\n",
    "            \"Pearson\": safe_pearson(gg[\"W\"], gg[\"Sigma\"]), \"Spearman\": safe_spearman(gg[\"W\"], gg[\"Sigma\"])\n",
    "        })\n",
    "pd.DataFrame(out_rows).to_csv(os.path.join(OUTPUT_DIR, \"outlier_sensitivity_by_kappa.csv\"), index=False)\n",
    "\n",
    "# =========================\n",
    "# 5. path_class_contribution_by_kappa\n",
    "# =========================\n",
    "path_rows = []\n",
    "for k, g in df.groupby(\"kappa\"):\n",
    "    W_all, S_all = g[\"W\"].values, g[\"Sigma\"].values\n",
    "    W_mean_all, S_mean_all = np.mean(W_all), np.mean(S_all)\n",
    "    cov_total = np.mean((W_all - W_mean_all) * (S_all - S_mean_all))\n",
    "    n_total = len(g)\n",
    "    for path, gp in g.groupby(\"path\"):\n",
    "        Wp, Sp = gp[\"W\"].values, gp[\"Sigma\"].values\n",
    "        contrib_cov = np.sum((Wp - W_mean_all) * (Sp - S_mean_all)) / n_total\n",
    "        path_rows.append({\n",
    "            \"kappa\": k, \"path\": path, \"n_path\": len(gp), \"path_fraction\": len(gp)/n_total,\n",
    "            \"W_mean_path\": np.mean(Wp), \"Sigma_mean_path\": np.mean(Sp),\n",
    "            \"contribution_to_mean_Sigma\": (len(gp)/n_total) * np.mean(Sp),\n",
    "            \"contribution_to_cov_W_Sigma\": contrib_cov, \"cov_total_kappa\": cov_total,\n",
    "            \"is_persistent_path\": is_persistent(path), \"n_switches\": path_switch_count(path),\n",
    "            \"start_state\": path_start(path), \"end_state\": path_end(path),\n",
    "        })\n",
    "path_df = pd.DataFrame(path_rows)\n",
    "path_df.to_csv(os.path.join(OUTPUT_DIR, \"path_class_contribution_by_kappa.csv\"), index=False)\n",
    "\n",
    "# =========================\n",
    "# 6. baseline_subtracted_by_kappa\n",
    "# =========================\n",
    "base_kappa = 0.0\n",
    "base_row = summary_df.loc[np.isclose(summary_df[\"kappa\"], base_kappa)]\n",
    "if not base_row.empty:\n",
    "    base = base_row.iloc[0].to_dict()\n",
    "    base_rows = []\n",
    "    for _, row in summary_df.iterrows():\n",
    "        base_rows.append({\n",
    "            \"kappa\": row[\"kappa\"],\n",
    "            \"delta_Pearson_vs_kappa0\": row[\"Pearson_W_Sigma\"] - base[\"Pearson_W_Sigma\"],\n",
    "            \"delta_W_mean_vs_kappa0\": row[\"W_mean\"] - base[\"W_mean\"],\n",
    "            \"delta_Sigma_mean_vs_kappa0\": row[\"Sigma_mean\"] - base[\"Sigma_mean\"],\n",
    "        })\n",
    "    pd.DataFrame(base_rows).to_csv(os.path.join(OUTPUT_DIR, \"baseline_subtracted_by_kappa.csv\"), index=False)\n",
    "\n",
    "print(f\"Done. Outputs saved to: {OUTPUT_DIR}\")"
   ]
