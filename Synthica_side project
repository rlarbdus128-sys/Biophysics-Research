{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31328,"isInternetEnabled":false,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"!pip install -q pyyaml scipy pandas matplotlib","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-18T10:54:09.999727Z","iopub.execute_input":"2026-05-18T10:54:10.000192Z","iopub.status.idle":"2026-05-18T10:54:14.030067Z","shell.execute_reply.started":"2026-05-18T10:54:10.000147Z","shell.execute_reply":"2026-05-18T10:54:14.028899Z"}},"outputs":[],"execution_count":39},{"cell_type":"code","source":"# ============================================\n# CREATE PROJECT DIRECTORY STRUCTURE\n# ============================================\n\nimport os\nfrom pathlib import Path\n\nproject_dir = Path(\"renyi_work_project\")\noutput_dir = project_dir / \"outputs\"\n\nproject_dir.mkdir(exist_ok=True)\noutput_dir.mkdir(exist_ok=True)\n\nprint(\"Project directories created.\")\n\n\n# ============================================\n# WRITE requirements.txt\n# ============================================\n\nrequirements_text = \"\"\"numpy\nscipy\npandas\nmatplotlib\npyyaml\n\"\"\"\n\nwith open(project_dir / \"requirements.txt\", \"w\", encoding=\"utf-8\") as f:\n    f.write(requirements_text)\n\nprint(\"requirements.txt written.\")\n\n\n# ============================================\n# WRITE config.yaml\n# ============================================\n\nconfig_text = \"\"\"project:\n  name: renyi_work_pilot\n  random_seed: 123\n  output_dir: outputs\n\nmodel:\n  type: transverse_field_ising\n  boundary_condition: periodic\n  J: 1.0\n\n  L_values:\n    - 6\n    - 8\n    - 10\n\n  h_values:\n    - 0.20\n    - 0.40\n    - 0.60\n    - 0.80\n    - 1.00\n    - 1.20\n    - 1.40\n    - 1.60\n    - 1.80\n    - 2.00\n\nentanglement:\n  subsystem_fraction: 0.5\n\nwork_protocol:\n  enabled: true\n  L: 8\n  beta: 2.0\n  h_initial: 0.50\n  h_final: 1.50\n  protocol_time: 1.0\n  n_time_steps: 40\n\n  n_trajectories:\n    - 100\n    - 500\n    - 2000\n    - 10000\n\nplots:\n  dpi: 180\n\"\"\"\n\nwith open(project_dir / \"config.yaml\", \"w\", encoding=\"utf-8\") as f:\n    f.write(config_text)\n\nprint(\"config.yaml written.\")\n\n\n# ============================================\n# WRITE CLEAN run_renyi_work_project.py\n# ============================================\n\npython_code = r'''\nimport argparse\nimport json\nimport math\nimport os\nimport gc\nfrom pathlib import Path\n\nimport yaml\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\n\nfrom scipy.sparse import coo_matrix\nfrom scipy.sparse.linalg import eigsh\nfrom scipy.linalg import eigh\nfrom scipy.linalg import expm\n\n\ndef load_config(path):\n    with open(path, \"r\", encoding=\"utf-8\") as handle:\n        return yaml.safe_load(handle)\n\n\ndef ensure_dir(path):\n    Path(path).mkdir(parents=True, exist_ok=True)\n\n\ndef spin_z_value(state, site):\n    bit = (state >> site) & 1\n    return 1.0 if bit == 1 else -1.0\n\n\ndef tfim_hamiltonian_sparse(L, J, h, periodic=True):\n    dim = 2 ** L\n\n    rows = []\n    cols = []\n    data = []\n\n    for state in range(dim):\n\n        diagonal = 0.0\n\n        for site in range(L):\n\n            next_site = site + 1\n\n            if next_site == L:\n                if periodic:\n                    next_site = 0\n                else:\n                    continue\n\n            zi = spin_z_value(state, site)\n            zj = spin_z_value(state, next_site)\n\n            diagonal -= J * zi * zj\n\n        rows.append(state)\n        cols.append(state)\n        data.append(diagonal)\n\n        for site in range(L):\n            flipped = state ^ (1 << site)\n\n            rows.append(flipped)\n            cols.append(state)\n            data.append(-h)\n\n    return coo_matrix(\n        (data, (rows, cols)),\n        shape=(dim, dim)\n    ).tocsr()\n\n\ndef tfim_hamiltonian_dense(L, J, h, periodic=True):\n    return tfim_hamiltonian_sparse(\n        L, J, h, periodic\n    ).toarray()\n\n\ndef ground_state_sparse(H):\n\n    values, vectors = eigsh(H, k=1, which=\"SA\")\n\n    energy = float(values[0])\n\n    vector = vectors[:, 0]\n    vector = vector / np.linalg.norm(vector)\n\n    return energy, vector\n\n\ndef renyi2_entropy_contiguous_subsystem(psi, L, LA):\n\n    dimA = 2 ** LA\n    dimB = 2 ** (L - LA)\n\n    matrix = psi.reshape((dimA, dimB))\n\n    rhoA = matrix @ np.conjugate(matrix).T\n\n    purity = np.real(np.trace(rhoA @ rhoA))\n\n    if purity <= 0:\n        return float(\"nan\"), float(purity)\n\n    S2 = -math.log(float(purity))\n\n    return float(S2), float(purity)\n\n\ndef von_neumann_entropy_contiguous_subsystem(psi, L, LA):\n\n    dimA = 2 ** LA\n    dimB = 2 ** (L - LA)\n\n    matrix = psi.reshape((dimA, dimB))\n\n    rhoA = matrix @ np.conjugate(matrix).T\n\n    evals = np.linalg.eigvalsh(rhoA)\n    evals = np.real(evals)\n    evals = np.maximum(evals, 0.0)\n\n    entropy = 0.0\n\n    for value in evals:\n        if value > 1.0e-14:\n            entropy -= float(value) * math.log(float(value))\n\n    return float(entropy)\n\n\ndef compute_entanglement_scan(cfg):\n\n    model = cfg[\"model\"]\n    ent = cfg[\"entanglement\"]\n\n    L_values = model[\"L_values\"]\n    h_values = model[\"h_values\"]\n\n    J = float(model[\"J\"])\n\n    periodic = (\n        model[\"boundary_condition\"] == \"periodic\"\n    )\n\n    frac = float(ent[\"subsystem_fraction\"])\n\n    records = []\n\n    for L in L_values:\n\n        LA = int(round(frac * L))\n\n        if LA < 1:\n            LA = 1\n\n        if LA >= L:\n            LA = L // 2\n\n        for h in h_values:\n\n            print(f\"Entanglement scan: L={L}, h={h}\")\n\n            H = tfim_hamiltonian_sparse(\n                L, J, float(h), periodic\n            )\n\n            energy, psi0 = ground_state_sparse(H)\n\n            S2, purity = (\n                renyi2_entropy_contiguous_subsystem(\n                    psi0, L, LA\n                )\n            )\n\n            SvN = (\n                von_neumann_entropy_contiguous_subsystem(\n                    psi0, L, LA\n                )\n            )\n\n            records.append(\n                {\n                    \"L\": int(L),\n                    \"LA\": int(LA),\n                    \"h\": float(h),\n                    \"ground_energy\": float(energy),\n                    \"ground_energy_per_site\":\n                        float(energy) / float(L),\n                    \"S2_half\": float(S2),\n                    \"purity_half\": float(purity),\n                    \"SvN_half\": float(SvN),\n                }\n            )\n\n            del H\n            gc.collect()\n\n    return pd.DataFrame.from_records(records)\n\n\ndef thermal_free_energy_from_dense_hamiltonian(H, beta):\n\n    evals = eigh(H, eigvals_only=True)\n\n    emin = float(np.min(evals))\n\n    shifted = np.exp(\n        -beta * (evals - emin)\n    )\n\n    logZ = (\n        -beta * emin\n        + math.log(float(np.sum(shifted)))\n    )\n\n    F = -logZ / beta\n\n    return float(F), evals\n\n\ndef build_unitary_linear_h_protocol(\n    L,\n    J,\n    h_initial,\n    h_final,\n    total_time,\n    n_steps,\n    periodic\n):\n\n    dim = 2 ** L\n\n    U = np.eye(dim, dtype=complex)\n\n    dt = total_time / float(n_steps)\n\n    for step in range(n_steps):\n\n        frac = (\n            (float(step) + 0.5)\n            / float(n_steps)\n        )\n\n        h = (\n            h_initial\n            + frac * (h_final - h_initial)\n        )\n\n        H = tfim_hamiltonian_dense(\n            L, J, h, periodic\n        )\n\n        U_step = expm((-1.0j * dt) * H)\n\n        U = U_step @ U\n\n        del H\n        del U_step\n\n        gc.collect()\n\n    return U\n\n\ndef jarzynski_projective_work_protocol(cfg):\n\n    model = cfg[\"model\"]\n    work = cfg[\"work_protocol\"]\n\n    seed = int(cfg[\"project\"][\"random_seed\"])\n\n    rng = np.random.default_rng(seed)\n\n    L = int(work[\"L\"])\n    beta = float(work[\"beta\"])\n\n    h_initial = float(work[\"h_initial\"])\n    h_final = float(work[\"h_final\"])\n\n    protocol_time = float(\n        work[\"protocol_time\"]\n    )\n\n    n_time_steps = int(\n        work[\"n_time_steps\"]\n    )\n\n    n_trajectory_values = (\n        work[\"n_trajectories\"]\n    )\n\n    J = float(model[\"J\"])\n\n    periodic = (\n        model[\"boundary_condition\"] == \"periodic\"\n    )\n\n    print(\"Building dense Hamiltonians...\")\n\n    H0 = tfim_hamiltonian_dense(\n        L, J, h_initial, periodic\n    )\n\n    H1 = tfim_hamiltonian_dense(\n        L, J, h_final, periodic\n    )\n\n    F0, _ = thermal_free_energy_from_dense_hamiltonian(\n        H0, beta\n    )\n\n    F1, _ = thermal_free_energy_from_dense_hamiltonian(\n        H1, beta\n    )\n\n    exact_delta_F = F1 - F0\n\n    evals0, evecs0 = eigh(H0)\n    evals1, evecs1 = eigh(H1)\n\n    shifted = np.exp(\n        -beta * (\n            evals0 - np.min(evals0)\n        )\n    )\n\n    probs0 = shifted / np.sum(shifted)\n\n    print(\"Building protocol unitary...\")\n\n    U = build_unitary_linear_h_protocol(\n        L,\n        J,\n        h_initial,\n        h_final,\n        protocol_time,\n        n_time_steps,\n        periodic,\n    )\n\n    max_trajectories = int(\n        max(n_trajectory_values)\n    )\n\n    raw_records = []\n    work_values = []\n\n    dim = 2 ** L\n\n    print(\"Running trajectories...\")\n\n    for traj in range(max_trajectories):\n\n        if traj % 1000 == 0:\n            print(f\"Trajectory {traj}\")\n\n        n = int(\n            rng.choice(dim, p=probs0)\n        )\n\n        initial_vec = evecs0[:, n]\n\n        evolved = U @ initial_vec\n\n        amplitudes = (\n            np.conjugate(evecs1).T @ evolved\n        )\n\n        probs_final = np.abs(amplitudes) ** 2\n\n        probs_final = (\n            probs_final\n            / np.sum(probs_final)\n        )\n\n        m = int(\n            rng.choice(dim, p=probs_final)\n        )\n\n        Ei = float(evals0[n])\n        Ef = float(evals1[m])\n\n        W = Ef - Ei\n\n        work_values.append(W)\n\n        raw_records.append(\n            {\n                \"trajectory\": int(traj),\n                \"initial_index\": int(n),\n                \"final_index\": int(m),\n                \"E_initial\": float(Ei),\n                \"E_final\": float(Ef),\n                \"work\": float(W),\n            }\n        )\n\n    work_array = np.array(\n        work_values,\n        dtype=float\n    )\n\n    summary_records = []\n\n    for ntraj in n_trajectory_values:\n\n        ntraj = int(ntraj)\n\n        subset = work_array[:ntraj]\n\n        exp_average = float(\n            np.mean(np.exp(-beta * subset))\n        )\n\n        jarzynski_delta_F = (\n            -math.log(exp_average)\n            / beta\n        )\n\n        mean_work = float(np.mean(subset))\n\n        dissipated_work = (\n            mean_work - exact_delta_F\n        )\n\n        error = (\n            jarzynski_delta_F\n            - exact_delta_F\n        )\n\n        summary_records.append(\n            {\n                \"L\": int(L),\n                \"beta\": float(beta),\n                \"h_initial\": float(h_initial),\n                \"h_final\": float(h_final),\n                \"protocol_time\":\n                    float(protocol_time),\n                \"n_time_steps\":\n                    int(n_time_steps),\n                \"n_trajectories\":\n                    int(ntraj),\n                \"exact_delta_F\":\n                    float(exact_delta_F),\n                \"jarzynski_delta_F\":\n                    float(jarzynski_delta_F),\n                \"jarzynski_error\":\n                    float(error),\n                \"mean_work\":\n                    float(mean_work),\n                \"dissipated_work_estimate\":\n                    float(dissipated_work),\n            }\n        )\n\n    raw_df = pd.DataFrame.from_records(\n        raw_records\n    )\n\n    summary_df = pd.DataFrame.from_records(\n        summary_records\n    )\n\n    return raw_df, summary_df\n\n\ndef compute_bridge_statistics(\n    entropy_df,\n    work_summary_df\n):\n\n    records = []\n\n    for L, sub in entropy_df.groupby(\"L\"):\n\n        h_values = sub[\"h\"].to_numpy()\n\n        S2_values = (\n            sub[\"S2_half\"].to_numpy()\n        )\n\n        energy_values = (\n            sub[\"ground_energy_per_site\"]\n            .to_numpy()\n        )\n\n        if len(h_values) > 1:\n\n            corr_S2_h = float(\n                np.corrcoef(\n                    h_values,\n                    S2_values\n                )[0, 1]\n            )\n\n            corr_S2_energy = float(\n                np.corrcoef(\n                    energy_values,\n                    S2_values\n                )[0, 1]\n            )\n\n        else:\n\n            corr_S2_h = float(\"nan\")\n            corr_S2_energy = float(\"nan\")\n\n        records.append(\n            {\n                \"L\": int(L),\n                \"corr_S2_with_h\":\n                    float(corr_S2_h),\n                \"corr_S2_with_energy_per_site\":\n                    float(corr_S2_energy),\n                \"S2_min\":\n                    float(np.min(S2_values)),\n                \"S2_max\":\n                    float(np.max(S2_values)),\n                \"S2_range\":\n                    float(\n                        np.max(S2_values)\n                        - np.min(S2_values)\n                    ),\n            }\n        )\n\n    if (\n        work_summary_df is not None\n        and len(work_summary_df) > 0\n    ):\n\n        final_row = (\n            work_summary_df\n            .tail(1)\n            .to_dict(orient=\"records\")[0]\n        )\n\n        for record in records:\n\n            record.update(\n                {\n                    \"final_jarzynski_error\":\n                        float(\n                            final_row[\n                                \"jarzynski_error\"\n                            ]\n                        ),\n                    \"final_dissipated_work_estimate\":\n                        float(\n                            final_row[\n                                \"dissipated_work_estimate\"\n                            ]\n                        ),\n                }\n            )\n\n    return pd.DataFrame.from_records(records)\n\n\ndef plot_entropy_vs_h(\n    entropy_df,\n    output_dir,\n    dpi\n):\n\n    fig, ax = plt.subplots(\n        figsize=(7, 5)\n    )\n\n    for L, sub in entropy_df.groupby(\"L\"):\n\n        ax.plot(\n            sub[\"h\"].to_numpy(),\n            sub[\"S2_half\"].to_numpy(),\n            marker=\"o\",\n            label=f\"L={L}\",\n        )\n\n    ax.set_xlabel(\n        \"transverse field h\"\n    )\n\n    ax.set_ylabel(\n        \"half-chain second Renyi entropy S2\"\n    )\n\n    ax.set_title(\n        \"Half-chain Renyi-2 entanglement entropy\"\n    )\n\n    ax.legend()\n\n    ax.grid(True, alpha=0.3)\n\n    path = (\n        Path(output_dir)\n        / \"fig_entropy_vs_h.png\"\n    )\n\n    fig.tight_layout()\n\n    fig.savefig(path, dpi=dpi)\n\n    plt.close(fig)\n\n    gc.collect()\n\n\ndef plot_purity_vs_h(\n    entropy_df,\n    output_dir,\n    dpi\n):\n\n    fig, ax = plt.subplots(\n        figsize=(7, 5)\n    )\n\n    for L, sub in entropy_df.groupby(\"L\"):\n\n        ax.plot(\n            sub[\"h\"].to_numpy(),\n            sub[\"purity_half\"].to_numpy(),\n            marker=\"o\",\n            label=f\"L={L}\",\n        )\n\n    ax.set_xlabel(\n        \"transverse field h\"\n    )\n\n    ax.set_ylabel(\n        \"half-chain purity\"\n    )\n\n    ax.set_title(\n        \"Reduced-state purity\"\n    )\n\n    ax.legend()\n\n    ax.grid(True, alpha=0.3)\n\n    path = (\n        Path(output_dir)\n        / \"fig_purity_vs_h.png\"\n    )\n\n    fig.tight_layout()\n\n    fig.savefig(path, dpi=dpi)\n\n    plt.close(fig)\n\n    gc.collect()\n\n\ndef plot_jarzynski_convergence(\n    work_summary_df,\n    output_dir,\n    dpi\n):\n\n    fig, ax = plt.subplots(\n        figsize=(7, 5)\n    )\n\n    ax.axhline(\n        float(\n            work_summary_df[\n                \"exact_delta_F\"\n            ].iloc[0]\n        ),\n        color=\"black\",\n        linestyle=\"--\",\n        label=\"exact delta F\",\n    )\n\n    ax.plot(\n        work_summary_df[\n            \"n_trajectories\"\n        ].to_numpy(),\n        work_summary_df[\n            \"jarzynski_delta_F\"\n        ].to_numpy(),\n        marker=\"o\",\n        label=\"Jarzynski estimate\",\n    )\n\n    ax.set_xscale(\"log\")\n\n    ax.set_xlabel(\n        \"number of trajectories\"\n    )\n\n    ax.set_ylabel(\n        \"free-energy difference\"\n    )\n\n    ax.set_title(\n        \"Jarzynski estimator convergence\"\n    )\n\n    ax.legend()\n\n    ax.grid(True, alpha=0.3)\n\n    path = (\n        Path(output_dir)\n        / \"fig_jarzynski_convergence.png\"\n    )\n\n    fig.tight_layout()\n\n    fig.savefig(path, dpi=dpi)\n\n    plt.close(fig)\n\n    gc.collect()\n\n\ndef plot_work_histogram(\n    work_raw_df,\n    output_dir,\n    dpi\n):\n\n    fig, ax = plt.subplots(\n        figsize=(7, 5)\n    )\n\n    ax.hist(\n        work_raw_df[\"work\"].to_numpy(),\n        bins=60,\n        alpha=0.8,\n    )\n\n    ax.set_xlabel(\"work W\")\n\n    ax.set_ylabel(\"count\")\n\n    ax.set_title(\n        \"Projective work distribution\"\n    )\n\n    ax.grid(True, alpha=0.3)\n\n    path = 